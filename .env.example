# ── Configuration SMTP Brevo ────────────────────────────────────────────────
# Compte Brevo : https://app.brevo.com
# Clé SMTP : Paramètres → SMTP & API → Clés SMTP → Générer une clé
#
# SMTP_USER = votre adresse email de connexion Brevo (login du compte)
# SMTP_PASS = clé SMTP Brevo (≠ mot de passe du compte)
# MAIL_FROM = adresse expéditeur vérifiée dans Brevo (Expéditeurs & domaines)

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=votre.login@brevo.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# ── Adresses mail ────────────────────────────────────────────────────────────
# MAIL_FROM : adresse affichée à la réception (doit être vérifiée dans Brevo)
# MAIL_TO   : adresse qui reçoit les demandes de devis

MAIL_FROM=contact@votre-domaine.fr
MAIL_TO=client@exemple.fr
