# Environnement de préprod — copier en .env.staging et remplir SMTP_PASS
# Ce fichier est un modèle, il peut être commité (pas de mot de passe)

# Active le mode préprod (noindex + robots.txt bloquant)
PUBLIC_STAGING=true

# URL du sous-domaine de préprod (sans slash final)
SITE_URL=https://conesa.roofline.fr

# SMTP — à adapter selon l'environnement
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=com.roofline@gmail.com
SMTP_PASS=
MAIL_FROM=com.roofline@gmail.com
MAIL_TO=com.roofline@gmail.com
