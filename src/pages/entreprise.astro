        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Questions fréquentes</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Tout savoir sur Conesa
        </h2>
      </div>

      <div class="border-t border-gray-200">
        {faqs.map(faq => (
          <div class="faq-item border-b border-gray-200">
            <button
              class="faq-trigger w-full flex items-center justify-between gap-6 py-5 px-1 text-left rounded-sm"
            >
              <span class="faq-question font-semibold text-[#1E4B8C] text-base leading-snug" style="font-family:'Montserrat',sans-serif;">
                {faq.q}
              </span>
              <svg
                class="faq-icon shrink-0 w-5 h-5 text-gray-400"
                style="transition: transform 0.45s ease, color 0.3s ease;"
                fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq-body overflow-hidden" style="max-height:0; transition: max-height 0.45s ease;">
              <p class="pb-6 pt-1 px-1 text-gray-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       CTA FINAL
  ══════════════════════════════════════ -->
  <section class="py-24 bg-[#F0F5FC]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="bg-[#1E4B8C] rounded-3xl p-12 lg:p-16 relative overflow-hidden">
        <div class="absolute inset-0 opacity-[0.05]" style="background-image:repeating-linear-gradient(45deg,#fff 0,#fff 1px,transparent 0,transparent 50%);background-size:30px 30px;"></div>
        <div class="absolute bottom-0 right-0 w-48 h-48 bg-[#E8650A] opacity-10 rounded-tl-full"></div>
        <div class="relative">
          <span class="inline-block bg-[#E8650A]/20 text-[#E8650A] border border-[#E8650A]/30 rounded-full px-4 py-1.5 text-sm font-semibold mb-6">
            Devis gratuit &amp; sans engagement
          </span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-6 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Construisons ensemble<br>votre projet
          </h2>
          <p class="text-blue-200 text-lg leading-relaxed mb-10 max-w-xl mx-auto">
            Artisan de confiance dans le Tarn depuis 1969, notre équipe est à votre écoute pour étudier votre projet et vous proposer la solution adaptée.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="#contact" class="inline-flex items-center justify-center gap-2 bg-[#E8650A] hover:bg-orange-700 text-white font-bold px-8 py-4 rounded-xl transition-all duration-200 hover:scale-105 shadow-lg shadow-orange-900/30">
              Demander un devis gratuit
            </a>
            <a href="tel:0563541697" class="inline-flex items-center justify-center gap-2 border-2 border-white/30 text-white hover:bg-white/10 font-semibold px-8 py-4 rounded-xl transition-all duration-200">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Nous contacter
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>


<script>
  document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
    const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger')!;
    const body    = item.querySelector<HTMLElement>('.faq-body')!;
    const icon    = item.querySelector<SVGElement>('.faq-icon')!;

    trigger.addEventListener('click', () => {
      const isOpen = item.dataset.open === 'true';

      document.querySelectorAll<HTMLElement>('.faq-item').forEach(other => {
        other.dataset.open = 'false';
        const b  = other.querySelector<HTMLElement>('.faq-body')!;
        const ic = other.querySelector<SVGElement>('.faq-icon')!;
        b.style.maxHeight = '0';
        ic.style.transform = '';
        ic.style.color = '';
      });

      if (!isOpen) {
        item.dataset.open = 'true';
        body.style.maxHeight = body.scrollHeight + 'px';
        icon.style.transform = 'rotate(180deg)';
        icon.style.color = '#E8650A';
      }
    });
  });
</script>
