---
import BaseLayout from '../layouts/BaseLayout.astro';
import ZonesIntervention from '../components/ZonesIntervention.astro';

const valeurs = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`,
    titre: "La confiance",
    desc: "Transparence, écoute et accompagnement sont au cœur de chaque projet. Nous entretenons une relation directe et honnête avec chacun de nos clients.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`,
    titre: "La qualité",
    desc: "Nous sélectionnons des matériaux et des solutions adaptés pour garantir des réalisations durables et performantes qui traversent le temps.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    titre: "La proximité",
    desc: "Entreprise familiale et locale, nous privilégions une relation directe avec nos clients et un suivi rigoureux de chaque chantier dans le Tarn.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    titre: "L'engagement",
    desc: "Nous nous impliquons pleinement dans chaque projet pour apporter des réponses concrètes et un résultat à la hauteur de vos attentes.",
  },
];

const expertises = [
  { label: "Isolation Thermique Extérieure", desc: "Amélioration des performances énergétiques et rénovation de façade.", href: "/isolation" },
  { label: "Ravalement de façade",           desc: "Protection et valorisation durable des façades.",                  href: "/renovation#facade" },
  { label: "Peinture intérieure & extérieure", desc: "Travaux de finition et d'embellissement.",                       href: "/renovation#peinture" },
  { label: "Entretien de toiture",            desc: "Nettoyage, démoussage et protection.",                            href: "/renovation#toiture" },
  { label: "Revêtements de sols",             desc: "Solutions adaptées aux projets résidentiels et professionnels.",  href: "/renovation#sols" },
  { label: "Travaux après sinistre",          desc: "Remise en état et rénovation des espaces endommagés.",            href: "/renovation#sinistre" },
];

const realisations = [
  { src: "/images/Réalisations/Isolation par l'extérieur.JPG", alt: "Isolation thermique extérieure", label: "Isolation extérieure" },
  { src: "/images/Réalisations/Ravalement de façade.webp",     alt: "Ravalement de façade",           label: "Ravalement de façade" },
  { src: "/images/Réalisations/peinture-façade.png",           alt: "Peinture de façade",             label: "Peinture façade" },
  { src: "/images/Réalisations/Rénovation façade.JPG",         alt: "Rénovation de façade",           label: "Rénovation façade" },
];

const faqs = [
  {
    q: "Depuis quand existe l'entreprise Conesa ?",
    a: "L'entreprise Conesa a été créée en 1969. Depuis plus de 55 ans, elle accompagne les propriétaires du Tarn dans leurs projets de rénovation, d'isolation thermique extérieure et d'entretien de l'habitat. Plusieurs générations se sont succédé à sa direction, garantissant une continuité du savoir-faire et des valeurs familiales.",
  },
  {
    q: "Dans quelles villes intervenez-vous ?",
    a: "Nous intervenons dans l'ensemble du département du Tarn (81) : Albi, Gaillac, Castres, Graulhet, Carmaux, Lavaur, Réalmont, Mazamet, Saint-Sulpice et toutes leurs communes environnantes. Contactez-nous pour vérifier notre disponibilité dans votre secteur.",
  },
  {
    q: "Réalisez-vous uniquement des travaux d'isolation extérieure ?",
    a: "Non, l'isolation thermique extérieure est l'une de nos spécialités, mais notre domaine d'intervention est bien plus large. Nous réalisons également le ravalement et la rénovation de façades, les travaux de peinture intérieure et extérieure, l'entretien de toiture, la pose de revêtements de sols et les travaux de remise en état après sinistre.",
  },
  {
    q: "Êtes-vous certifiés RGE ?",
    a: "Oui, Conesa est certifiée RGE (Reconnu Garant de l'Environnement) et Qualibat. Ces certifications attestent de notre engagement en faveur de la qualité et de la performance énergétique. Elles vous permettent également de bénéficier des aides financières disponibles (MaPrimeRénov', CEE, éco-prêt à taux zéro) pour vos projets de rénovation énergétique.",
  },
  {
    q: "Comment obtenir un devis ?",
    a: "Remplissez notre formulaire en ligne, appelez-nous ou envoyez-nous un email. Nous vous répondons sous 24h pour organiser une visite gratuite sur site. À l'issue de cette visite, nous vous remettons un devis détaillé, gratuit et sans engagement.",
  },
  {
    q: "Accompagnez-vous les particuliers et les professionnels ?",
    a: "Oui, nous intervenons aussi bien pour des particuliers que pour des professionnels : copropriétés, commerces, bâtiments tertiaires. Nos équipes s'adaptent aux contraintes et aux exigences spécifiques de chaque type de chantier.",
  },
  {
    q: "Quels types de projets réalisez-vous ?",
    a: "Nous réalisons tous types de projets de rénovation : isolation thermique extérieure, ravalement de façade, peinture intérieure et extérieure, entretien de toiture, pose de revêtements de sols et travaux après sinistre. Nous pouvons intervenir sur un seul poste ou coordonner une rénovation globale de votre bien.",
  },
  {
    q: "Comment se déroule un chantier ?",
    a: "Après votre prise de contact, nous organisons une visite sur site pour étudier votre projet. Nous établissons ensuite un devis détaillé et un planning de chantier. Les travaux sont réalisés par nos équipes avec un suivi régulier. En fin de chantier, nous procédons à une réception des travaux pour nous assurer de votre entière satisfaction.",
  },
];
---

<BaseLayout
  title="L'Entreprise Conesa — Isolation & Rénovation dans le Tarn depuis 1969"
  description="Entreprise familiale créée en 1969, Conesa intervient dans tout le Tarn pour vos travaux d'isolation thermique extérieure, de rénovation de façade, peinture et toiture. Certifiée RGE et Qualibat."
>

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[#0A1E3D]" style="padding-top: 160px; padding-bottom: 96px;">
    <img
      src="/images/Entreprise/hero entreprise familiale conesa.png"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-top"
      onerror="this.style.display='none'"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,30,61,0.92) 0%, rgba(30,75,140,0.75) 55%, rgba(10,30,61,0.65) 100%);"></div>
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="absolute top-0 left-0 w-1 h-full bg-[#E8650A] opacity-60"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">

        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 text-sm font-medium text-white mb-8">
          <span class="w-2 h-2 bg-[#E8650A] rounded-full"></span>
          Entreprise familiale dans le Tarn depuis 1969
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-[3rem] font-extrabold text-white leading-[1.1] mb-6" style="font-family:'Montserrat',sans-serif;">
          Une entreprise familiale<br>au service de l'habitat
          <span class="text-[#E8650A]"> depuis plus de 55 ans</span>
        </h1>

        <p class="text-blue-100 text-lg leading-relaxed mb-4 max-w-xl">
          Depuis plusieurs générations, Conesa accompagne les particuliers et les professionnels dans leurs projets de rénovation, d'isolation et d'embellissement de l'habitat dans tout le Tarn.
        </p>
        <p class="text-blue-200 text-base leading-relaxed mb-10 max-w-xl">
          Une réputation fondée sur la qualité, la confiance et la proximité avec des centaines de familles du département.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="#realisations" class="inline-flex items-center justify-center gap-2 bg-[#E8650A] hover:bg-orange-700 text-white font-bold px-8 py-4 rounded-xl transition-all duration-200 hover:scale-105 shadow-lg shadow-orange-900/30">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            Découvrir nos réalisations
          </a>
          <a href="#contact" class="inline-flex items-center justify-center gap-2 border-2 border-white/30 text-white hover:bg-white/10 font-semibold px-8 py-4 rounded-xl transition-all duration-200">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Demander un devis gratuit
          </a>
        </div>

        <div class="flex flex-wrap items-center gap-6 pt-8 border-t border-white/10">
          <div class="flex items-center gap-2.5">
            <img src="/images/Entreprise/Certification RGE Qualibat.png" alt="RGE Qualibat" class="h-11 w-auto bg-white rounded-lg p-1 shadow" onerror="this.style.display='none'"/>
            <span class="text-blue-100 text-sm">Certifié RGE & Qualibat</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       HISTOIRE — PHOTO ÉQUIPE
  ══════════════════════════════════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Notre histoire</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 mb-8 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Une histoire de famille et de savoir-faire
          </h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>Depuis sa création en 1969, l'entreprise Conesa a su évoluer avec son époque tout en conservant les valeurs qui ont fait sa réputation : le sérieux, la proximité et le travail bien fait.</p>
            <p>Au fil des décennies, nous avons accompagné plusieurs générations de propriétaires dans la rénovation, l'entretien et la valorisation de leur patrimoine immobilier.</p>
            <p>Cette expérience nous permet aujourd'hui d'apporter des solutions adaptées aux enjeux actuels de la rénovation énergétique et de l'amélioration de l'habitat.</p>
          </div>

          <div class="grid grid-cols-3 gap-4 mt-10">
            {[
              { val: "1969", label: "Année de création" },
              { val: "3", label: "générations familiales" },
              { val: "81", label: "Tarn, notre territoire" },
            ].map(item => (
              <div class="text-center">
                <p class="text-2xl font-extrabold text-[#1E4B8C]" style="font-family:'Montserrat',sans-serif;">{item.val}</p>
                <p class="text-gray-500 text-xs mt-1 leading-snug">{item.label}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Photo équipe / chantier -->
        <div class="relative">
          <div class="rounded-3xl overflow-hidden aspect-[4/3] bg-[#E8F0FB]">
            <img
              src="/images/Entreprise/Camion conesa.png"
              alt="L'équipe Conesa sur chantier"
              class="w-full h-full object-cover"
              onerror="this.style.display='none'"
            />
          </div>
          <!-- Badge flottant -->
          <div class="absolute -bottom-5 -left-5 bg-[#1E4B8C] text-white rounded-2xl p-5 shadow-xl">
            <p class="text-3xl font-extrabold" style="font-family:'Montserrat',sans-serif;">55+</p>
            <p class="text-blue-200 text-xs font-medium">ans d'expertise</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       NOS VALEURS
  ══════════════════════════════════════ -->
  <section class="py-24 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Ce qui nous définit</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Nos valeurs
        </h2>
        <p class="text-gray-600 mt-4 text-lg max-w-2xl mx-auto">
          Depuis 1969, ces principes guident chacune de nos interventions et notre relation avec nos clients.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {valeurs.map(v => (
          <div class="bg-white rounded-2xl p-7 shadow-sm border border-gray-100 group hover:border-[#1E4B8C]/20 hover:shadow-md transition-all duration-300">
            <div class="w-14 h-14 bg-[#E8F0FB] group-hover:bg-[#1E4B8C] rounded-xl flex items-center justify-center text-[#1E4B8C] group-hover:text-white transition-colors duration-300 mb-5">
              <Fragment set:html={v.icon} />
            </div>
            <h3 class="font-bold text-[#1E4B8C] text-base mb-3" style="font-family:'Montserrat',sans-serif;">{v.titre}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       PHOTO CHANTIER + CERTIFICATIONS
  ══════════════════════════════════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Photo chantier -->
        <div class="relative">
          <div class="rounded-3xl overflow-hidden max-w-xs sm:max-w-sm lg:max-w-full mx-auto">
            <img
              src="/images/Entreprise/Certification RGE Qualibat.png"
              alt="Certification RGE Qualibat Conesa"
              class="w-full h-auto block"
              onerror="this.style.display='none'"
            />
          </div>
          
        </div>

        <!-- Certifications -->
        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Qualifications</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 mb-6 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Des certifications reconnues dans le bâtiment
          </h2>
          <p class="text-gray-600 leading-relaxed mb-8">
            Afin de garantir des prestations conformes aux standards les plus exigeants, Conesa dispose de certifications reconnues dans le secteur du bâtiment et de la rénovation énergétique. Ces qualifications témoignent de notre engagement en faveur de la qualité et du respect des bonnes pratiques.
          </p>

          <div class="space-y-4 mb-8">
            {[
              { titre: "RGE — Reconnu Garant de l'Environnement", desc: "Vous permet d'accéder aux aides financières de l'État (MaPrimeRénov', CEE, éco-prêt à taux zéro)." },
              { titre: "Qualibat", desc: "Certification nationale qui atteste de la compétence, du sérieux et de la solidité financière de l'entreprise." },
              { titre: "Qualifications professionnelles du bâtiment", desc: "Reconnaissance de notre savoir-faire dans les métiers de la rénovation et de l'isolation." },
            ].map(c => (
              <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-100 hover:border-[#1E4B8C]/20 hover:shadow-sm transition-all">
                <span class="w-6 h-6 bg-[#E8650A] rounded-full flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
                <div>
                  <p class="font-semibold text-[#1E4B8C] text-sm mb-1" style="font-family:'Montserrat',sans-serif;">{c.titre}</p>
                  <p class="text-gray-500 text-sm leading-relaxed">{c.desc}</p>
                </div>
              </div>
            ))}
          </div>

          <a href="#contact" class="inline-flex items-center gap-2 bg-[#1E4B8C] hover:bg-[#153566] text-white font-bold px-8 py-4 rounded-xl transition-colors duration-200">
            Demander un devis gratuit
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       NOS EXPERTISES
  ══════════════════════════════════════ -->
  <section class="py-24 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Nos savoir-faire</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Nos domaines d'expertise
        </h2>
        <p class="text-gray-600 mt-4 text-lg max-w-2xl mx-auto">
          Au fil des années, l'entreprise a développé une expertise complète dans les métiers de la rénovation et de l'amélioration de l'habitat.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {expertises.map((e, i) => (
          <a
            href={e.href}
            class="group bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:border-[#1E4B8C]/20 hover:shadow-md transition-all duration-300 flex items-start gap-4"
          >
            <div class="w-10 h-10 bg-[#E8F0FB] group-hover:bg-[#1E4B8C] rounded-lg flex items-center justify-center shrink-0 transition-colors duration-300">
              <span class="text-[#1E4B8C] group-hover:text-white font-extrabold text-sm transition-colors duration-300" style="font-family:'Montserrat',sans-serif;">
                {String(i + 1).padStart(2, '0')}
              </span>
            </div>
            <div>
              <h3 class="font-bold text-[#1E4B8C] text-sm mb-1.5" style="font-family:'Montserrat',sans-serif;">{e.label}</h3>
              <p class="text-gray-500 text-xs leading-relaxed">{e.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       CHIFFRES CLÉS (bande)
  ══════════════════════════════════════ -->
  <section class="bg-[#1E4B8C] py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-4 gap-4 text-center text-white">
        {[
          { val: "1969", label: "Année de création" },
          { val: "RGE",  label: "& Qualibat certifié" },
          { val: "100%", label: "Familiale & locale" },
          { val: "24h",  label: "Réponse garantie" },
        ].map(s => (
          <div>
            <p class="text-xl sm:text-3xl lg:text-5xl font-extrabold mb-1 lg:mb-2" style="font-family:'Montserrat',sans-serif;">{s.val}</p>
            <p class="text-blue-200 text-[10px] sm:text-xs lg:text-sm leading-snug">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       RÉALISATIONS — GALERIE PHOTOS
  ══════════════════════════════════════ -->
  <section id="realisations" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Nos projets</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Nos réalisations
        </h2>
        <p class="text-gray-600 mt-4 text-lg max-w-2xl mx-auto">
          Chaque projet réalisé est le reflet de notre engagement et de notre savoir-faire. Des résultats durables et esthétiques, partout dans le Tarn.
        </p>
      </div>

      <!-- Grille photos : 2 grandes + 4 petites -->
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-4">
        {realisations.map((r, i) => (
          <div class={`relative group rounded-2xl overflow-hidden bg-[#E8F0FB] ${i === 0 ? 'row-span-2' : ''}`}
               style={i === 0 ? 'aspect-ratio: auto;' : ''}>
            <div class={`w-full ${i === 0 ? 'h-full min-h-[400px]' : 'aspect-[4/3]'}`}>
              <img
                src={r.src}
                alt={r.alt}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                onerror="this.style.display='none'"
              />
            </div>
            <!-- Label au survol -->
            <div class="absolute inset-0 bg-gradient-to-t from-[#0A1E3D]/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-5">
              <span class="text-white font-semibold text-sm" style="font-family:'Montserrat',sans-serif;">{r.label}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="#contact" class="inline-flex items-center gap-2 bg-[#E8650A] hover:bg-orange-700 text-white font-bold px-8 py-4 rounded-xl transition-all duration-200 hover:scale-105">
