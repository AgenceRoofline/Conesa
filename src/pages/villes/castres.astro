---
import BaseLayout from '../../layouts/BaseLayout.astro';

const prestations = [
  {
    id: "ite",
    titre: "Isolation Thermique Extérieure",
    intro: "L'isolation thermique extérieure est aujourd'hui l'une des solutions les plus efficaces pour améliorer les performances énergétiques d'une habitation. Elle permet de réduire les pertes de chaleur, d'améliorer le confort thermique été comme hiver et de moderniser l'apparence extérieure du bâtiment.",
    items: ["Réduction des factures énergétiques", "Confort thermique renforcé", "Valorisation du bien immobilier", "Rénovation esthétique de la façade"],
    href: "/isolation",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
  },
  {
    id: "facade",
    titre: "Ravalement et rénovation de façade",
    intro: "La façade constitue la première protection de votre habitation face aux agressions extérieures. Nous réalisons différents travaux permettant de préserver son état et son apparence.",
    items: ["Nettoyage de façade", "Traitement des fissures", "Réparation des enduits", "Application de revêtements", "Protection hydrofuge", "Ravalement complet"],
    href: "/renovation#facade",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
  },
  {
    id: "peinture",
    titre: "Peinture intérieure et extérieure",
    intro: "La peinture participe directement au confort et à l'ambiance de votre logement. Nous réalisons vos travaux de peinture ainsi que différentes prestations décoratives pour personnaliser vos espaces.",
    items: ["Peinture intérieure", "Peinture extérieure", "Enduits décoratifs", "Revêtements muraux", "Finitions personnalisées"],
    href: "/renovation#peinture",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>`,
  },
  {
    id: "toiture",
    titre: "Entretien et nettoyage de toiture",
    intro: "La toiture est l'un des éléments les plus exposés de votre habitation. Afin de préserver sa durée de vie et son étanchéité, nous réalisons des interventions adaptées à chaque type de couverture.",
    items: ["Nettoyage de toiture", "Démoussage", "Traitement antimousse", "Traitement hydrofuge", "Contrôle de l'état général"],
    href: "/renovation#toiture",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>`,
  },
  {
    id: "sols",
    titre: "Revêtements de sols",
    intro: "Le choix d'un revêtement de sol adapté permet d'améliorer le confort et l'esthétique de vos espaces de vie. Nous vous accompagnons dans la pose et la rénovation de différents types de revêtements.",
    items: ["Sols souples", "PVC & vinyles", "Moquettes", "Parquets stratifiés", "Rénovation de sols existants"],
    href: "/renovation#sols",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm0 8a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zm12 0a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>`,
  },
  {
    id: "sinistre",
    titre: "Travaux après sinistre",
    intro: "Après un dégât des eaux, un incendie ou tout autre sinistre, nous assurons la remise en état des espaces endommagés. Nos équipes interviennent afin de restaurer les surfaces dans les meilleurs délais.",
    items: ["Diagnostic et évaluation", "Remise en état des murs et plafonds", "Travaux de peinture et finitions", "Réfection des revêtements", "Coordination des interventions"],
    href: "/renovation#sinistre",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>`,
  },
];

const secteurs = [
  "Mazamet", "Aussillon", "Saïx", "Soual",
  "Labruguière", "Roquecourbe", "Valdurenque", "Pont-de-Larn", "Payrin-Augmontel", "Aiguefonde",
];

const faqs = [
  { q: "Intervenez-vous à Castres et dans les communes voisines ?",
    a: `Oui. Nos équipes interviennent régulièrement à Castres ainsi qu'à <strong>Mazamet, Aussillon, Saïx, Soual, Labruguière, Roquecourbe, Valdurenque, Pont-de-Larn, Payrin-Augmontel</strong> et <strong>Aiguefonde</strong>.<br><br>Nous accompagnons les particuliers et les professionnels pour leurs projets d'<a href="/isolation" class="font-semibold text-[#E8650A] hover:underline">isolation thermique extérieure</a>, de <a href="/renovation#facade" class="font-semibold text-[#E8650A] hover:underline">rénovation de façade</a>, de <a href="/renovation#peinture" class="font-semibold text-[#E8650A] hover:underline">peinture</a>, d'<a href="/renovation#toiture" class="font-semibold text-[#E8650A] hover:underline">entretien de toiture</a> et de rénovation de l'habitat.` },
  { q: "Réalisez-vous des travaux à Mazamet et Aussillon ?",
    a: `Oui. Nous intervenons régulièrement dans tout le bassin castrais et mazamétain pour des travaux de <a href="/isolation" class="font-semibold text-[#E8650A] hover:underline">rénovation énergétique</a>, de <a href="/renovation#facade" class="font-semibold text-[#E8650A] hover:underline">façade</a>, de <a href="/renovation#peinture" class="font-semibold text-[#E8650A] hover:underline">peinture</a> et d'<a href="/renovation#toiture" class="font-semibold text-[#E8650A] hover:underline">entretien de l'habitat</a>.` },
  { q: "Les habitations du secteur de Castres peuvent-elles bénéficier d'une rénovation énergétique ?",
    a: `Oui. Chaque projet est étudié individuellement afin de proposer des solutions adaptées au bâtiment et aux objectifs de performance énergétique recherchés. En tant qu'entreprise <a href="/entreprise" class="font-semibold text-[#E8650A] hover:underline">certifiée RGE et Qualibat</a>, nous permettons l'accès aux aides comme <strong>MaPrimeRénov'</strong>, les <strong>CEE</strong> et la <strong>TVA réduite à 5,5 %</strong>.` },
  { q: "Intervenez-vous également pour les professionnels à Castres ?",
    a: `Oui. Nous accompagnons aussi les <strong>entreprises, commerces, bureaux et bâtiments professionnels</strong> pour leurs travaux de rénovation et d'entretien. <a href="#contact" class="font-semibold text-[#E8650A] hover:underline">Contactez-nous pour en savoir plus →</a>` },
  { q: "Comment obtenir un devis pour un projet à Castres ?",
    a: `Il suffit de nous contacter afin d'échanger sur votre projet. Nous réalisons ensuite une <strong>étude personnalisée et un devis gratuit</strong>, sans engagement, adapté à vos besoins et à votre habitation. <a href="#contact" class="font-semibold text-[#E8650A] hover:underline">Demander un devis →</a>` },
];
---

<BaseLayout
  title="Entreprise de rénovation à Castres — Conesa, isolation, façade, peinture, toiture"
  description="Conesa intervient à Castres pour tous vos travaux de rénovation : isolation thermique extérieure, ravalement de façade, peinture, entretien de toiture et revêtements de sols. Entreprise familiale certifiée RGE depuis 1969. Devis gratuit."
>

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[#0A1E3D]" style="padding-top: 160px; padding-bottom: 96px;">
    <img
      src="/images/Villes/Castres/Hero Castres.png"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-top"
      onerror="this.style.display='none'"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,30,61,0.93) 0%, rgba(30,75,140,0.78) 55%, rgba(10,30,61,0.70) 100%);"></div>
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="absolute top-0 left-0 w-1 h-full bg-[#E8650A] opacity-60"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">

        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 text-sm font-medium text-white mb-8">
          <span class="w-2 h-2 bg-[#E8650A] rounded-full"></span>
          Entreprise locale — Tarn (81) — depuis 1969
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-[3.2rem] font-extrabold text-white leading-[1.1] mb-6" style="font-family:'Montserrat',sans-serif;">
          Entreprise de rénovation
          <span class="text-[#E8650A]"> à Castres</span>
        </h1>

        <p class="text-blue-100 text-lg leading-relaxed mb-4 max-w-xl">
          Vous recherchez une entreprise spécialisée dans la rénovation de l'habitat à Castres ?
        </p>
        <p class="text-blue-200 text-base leading-relaxed mb-10 max-w-xl">
          Conesa accompagne les particuliers et les professionnels dans leurs projets de rénovation, d'entretien et d'amélioration de l'habitat à Castres et dans le sud du Tarn. <a href="/isolation" class="font-semibold text-[#E8650A] hover:underline">Isolation thermique extérieure</a>, <a href="/renovation#facade" class="font-semibold text-[#E8650A] hover:underline">rénovation de façade</a>, <a href="/renovation#peinture" class="font-semibold text-[#E8650A] hover:underline">peinture</a>, <a href="/renovation#toiture" class="font-semibold text-[#E8650A] hover:underline">toiture</a>, <a href="/renovation#sols" class="font-semibold text-[#E8650A] hover:underline">sols</a> ou <a href="/renovation#sinistre" class="font-semibold text-[#E8650A] hover:underline">travaux après sinistre</a> : un seul interlocuteur pour tous vos chantiers.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="#contact" class="inline-flex items-center justify-center gap-2 bg-[#E8650A] hover:bg-orange-700 text-white font-bold px-8 py-4 rounded-xl transition-all duration-200 hover:scale-105 shadow-lg shadow-orange-900/30">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Demander un devis gratuit
          </a>
          <a href="tel:0563541697" class="inline-flex items-center justify-center gap-2 border-2 border-white/30 text-white hover:bg-white/10 font-semibold px-8 py-4 rounded-xl transition-all duration-200">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Être rappelé
          </a>
        </div>

        <div class="flex flex-wrap items-center gap-6 pt-8 border-t border-white/10">
          <div class="flex items-center gap-2.5">
            <img src="/images/labels/Logo-RGE.png" alt="RGE Qualibat" class="h-11 w-auto bg-white rounded-lg p-1 shadow" onerror="this.style.display='none'"/>
            <span class="text-blue-100 text-sm">Certifié RGE & Qualibat</span>
          </div>
          <div class="flex items-center gap-2 text-blue-200 text-sm">
            <svg class="w-4 h-4 text-[#E8650A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Castres & agglomération castraise
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       VOS PROJETS DE RÉNOVATION À CASTRES
  ══════════════════════════════════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Rénovation à Castres</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 mb-8 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Vos projets de rénovation à Castres
          </h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>Entre les <strong class="font-semibold text-gray-800">quartiers résidentiels de Castres</strong>, les maisons traditionnelles du sud du Tarn et les habitations situées aux portes de la <strong class="font-semibold text-gray-800">Montagne Noire</strong>, le patrimoine immobilier du secteur présente des caractéristiques variées nécessitant des solutions de rénovation adaptées.</p>
            <p>L'exposition aux intempéries, les variations de température et le vieillissement naturel des matériaux peuvent progressivement impacter les <a href="/renovation#facade" class="font-semibold text-[#E8650A] hover:underline">façades</a>, les <a href="/renovation#toiture" class="font-semibold text-[#E8650A] hover:underline">toitures</a> et le confort thermique du logement.</p>
            <p>Grâce à notre expertise, nous accompagnons les propriétaires castrais dans tous leurs projets de rénovation afin d'améliorer durablement leur habitat. <a href="/entreprise" class="font-semibold text-[#E8650A] hover:underline">En savoir plus sur Conesa</a></p>
          </div>
        </div>

        <div class="flex flex-col gap-5">
          <div class="grid grid-cols-2 gap-4">
            {[
              { val: "55+", label: "ans d'expérience",    bg: "bg-[#1E4B8C]", text: "text-white",        sub: "text-blue-200" },
              { val: "RGE", label: "& Qualibat certifié", bg: "bg-[#E8650A]", text: "text-white",        sub: "text-orange-100" },
              { val: "6",   label: "métiers du bâtiment", bg: "bg-[#F0F5FC]", text: "text-[#1E4B8C]",    sub: "text-gray-500" },
              { val: "24h", label: "Réponse garantie",    bg: "bg-[#F0F5FC]", text: "text-[#1E4B8C]",    sub: "text-gray-500" },
            ].map(s => (
              <div class={`${s.bg} rounded-2xl p-6 text-center`}>
                <p class={`text-4xl font-extrabold mb-1 ${s.text}`} style="font-family:'Montserrat',sans-serif;">{s.val}</p>
                <p class={`text-sm ${s.sub}`}>{s.label}</p>
              </div>
            ))}
          </div>
          <div class="rounded-2xl overflow-hidden aspect-[16/9]">
            <img
              src="/images/Villes/Castres/Projet rénovation Castres.png"
              alt="Projet de rénovation à Castres — Conesa"
              class="w-full h-full object-cover"
              onerror="this.style.display='none'"
            />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       NOS PRESTATIONS À CASTRES
  ══════════════════════════════════════ -->
  <section class="py-24 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Nos savoir-faire</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Nos prestations à Castres
        </h2>
        <p class="text-gray-600 mt-4 text-lg max-w-2xl mx-auto">
          Un interlocuteur unique pour l'ensemble de vos travaux de rénovation et d'entretien de l'habitat.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {prestations.map(p => (
          <a href={p.href} class="group bg-white rounded-2xl p-7 shadow-sm border border-gray-100 hover:border-[#1E4B8C]/30 hover:shadow-md transition-all duration-300 flex flex-col">
            <div class="w-12 h-12 bg-[#E8F0FB] group-hover:bg-[#1E4B8C] rounded-xl flex items-center justify-center text-[#1E4B8C] group-hover:text-white transition-colors duration-300 mb-5 shrink-0">
              <Fragment set:html={p.icon} />
            </div>
            <h3 class="font-bold text-[#1E4B8C] text-base mb-3 leading-snug" style="font-family:'Montserrat',sans-serif;">{p.titre}</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-4">{p.intro}</p>
            <ul class="space-y-1.5 mt-auto">
              {p.items.map(item => (
                <li class="flex items-center gap-2 text-gray-600 text-xs">
                  <span class="w-1.5 h-1.5 bg-[#E8650A] rounded-full shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       POURQUOI FAIRE APPEL À CONESA ?
  ══════════════════════════════════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Notre engagement</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 mb-6 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Pourquoi faire appel à Conesa à Castres ?
          </h2>
          <div class="space-y-4 text-gray-600 leading-relaxed mb-8">
            <p>Faire appel à une <strong class="font-semibold text-gray-800">entreprise locale</strong> permet de bénéficier d'un accompagnement de proximité et d'une parfaite connaissance des habitations du secteur castrais.</p>
            <p>Nos équipes interviennent régulièrement à <strong class="font-semibold text-gray-800">Castres</strong> et dans son agglomération pour des projets de rénovation de toutes tailles.<br> <a href="/entreprise" class="font-semibold text-[#E8650A] hover:underline">Découvrir l'entreprise Conesa</a></p>
          </div>

          <div class="space-y-3 mb-8">
            {[
              "Entreprise familiale depuis 1969",
              "Certifications RGE et Qualibat",
              "Accompagnement personnalisé",
              "Devis gratuit & sans engagement",
              "Interlocuteur unique pour tous vos travaux",
              "Intervention dans tout le Tarn",
            ].map(e => (
              <div class="flex items-center gap-3">
                <span class="w-5 h-5 bg-[#E8650A] rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
                <span class="text-gray-700 text-sm">{e}</span>
              </div>
            ))}
          </div>

          <a href="#contact" class="inline-flex items-center gap-2 bg-[#1E4B8C] hover:bg-[#153566] text-white font-bold px-8 py-4 rounded-xl transition-colors duration-200">
            Demander un devis gratuit
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- Citation -->
        <div class="bg-[#F0F5FC] rounded-2xl p-8 relative">
          <svg class="w-10 h-10 text-[#E8650A] opacity-20 mb-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
          <p class="text-[#1E4B8C] text-xl font-semibold leading-relaxed mb-6" style="font-family:'Montserrat',sans-serif;">
            Une rénovation bien réalisée, c'est moins de factures, plus de confort et un patrimoine préservé durablement.
          </p>
