  <script>
    // ── Carousel étapes (mobile / tablette) ──────────────────────────────────
    {
      const TOTAL_ET  = 5;
      const etRoot    = document.getElementById('et-root') as HTMLElement | null;
      const etTrack   = document.getElementById('et-track') as HTMLElement | null;
      const etDotsEl  = document.getElementById('et-dots') as HTMLElement | null;
      const etPrevBtn = document.getElementById('et-prev') as HTMLButtonElement | null;
      const etNextBtn = document.getElementById('et-next') as HTMLButtonElement | null;

      if (etRoot && etTrack) {
        let etCurrent = 0;

        function etPerPage(): number {
          return parseInt(getComputedStyle(etRoot!).getPropertyValue('--per-page').trim()) || 1;
        }
        function etMaxIdx(): number {
          return Math.max(0, TOTAL_ET - etPerPage());
        }
        function etGoTo(idx: number): void {
          etCurrent = Math.max(0, Math.min(idx, etMaxIdx()));
          etTrack!.style.transform = `translateX(-${etCurrent * (100 / etPerPage())}%)`;
          etSyncDots();
          etSyncArrows();
        }
        function etSyncDots(): void {
          if (!etDotsEl) return;
          Array.from(etDotsEl.querySelectorAll<HTMLButtonElement>('.et-dot')).forEach((d, i) => {
            d.className = i === etCurrent
              ? 'et-dot w-6 h-2.5 rounded-full transition-all duration-300 bg-[#E8650A]'
              : 'et-dot w-2.5 h-2.5 rounded-full transition-all duration-300 bg-gray-300 hover:bg-gray-400';
          });
        }
        function etSyncArrows(): void {
          if (etPrevBtn) etPrevBtn.style.opacity = etCurrent === 0 ? '0.35' : '1';
          if (etNextBtn) etNextBtn.style.opacity = etCurrent >= etMaxIdx() ? '0.35' : '1';
        }
        function etBuildDots(): void {
          if (!etDotsEl) return;
          etDotsEl.innerHTML = '';
          const total = etMaxIdx() + 1;
          for (let i = 0; i < total; i++) {
            const btn = document.createElement('button');
            btn.className = i === etCurrent
              ? 'et-dot w-6 h-2.5 rounded-full transition-all duration-300 bg-[#E8650A]'
              : 'et-dot w-2.5 h-2.5 rounded-full transition-all duration-300 bg-gray-300 hover:bg-gray-400';
            btn.setAttribute('aria-label', `Étape ${i + 1}`);
            btn.addEventListener('click', () => etGoTo(i));
            etDotsEl.appendChild(btn);
          }
        }

        etPrevBtn?.addEventListener('click', () => etGoTo(etCurrent - 1));
        etNextBtn?.addEventListener('click', () => etGoTo(etCurrent + 1));

        window.addEventListener('resize', () => {
          if (etCurrent > etMaxIdx()) etCurrent = etMaxIdx();
          etBuildDots();
          etGoTo(etCurrent);
        });

        etBuildDots();
        etGoTo(0);

        // Swipe tactile
        let etTouchX = 0;
        etTrack.addEventListener('touchstart', (e) => { etTouchX = e.touches[0].clientX; }, { passive: true });
        etTrack.addEventListener('touchend', (e) => {
          const delta = etTouchX - e.changedTouches[0].clientX;
          if (Math.abs(delta) > 50) delta > 0 ? etGoTo(etCurrent + 1) : etGoTo(etCurrent - 1);
        }, { passive: true });
      }
    }
  </script>

