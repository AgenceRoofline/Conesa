---
import BaseLayout from '../layouts/BaseLayout.astro';
import ZonesIntervention from '../components/ZonesIntervention.astro';

const avantages = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    titre: "Réduction des consommations énergétiques",
    desc: "En limitant les pertes de chaleur par les murs, l'ITE permet de diminuer les besoins en chauffage et contribue à réduire les factures énergétiques.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>`,
    titre: "Confort été comme hiver",
    desc: "La maison conserve mieux la chaleur en hiver et reste plus agréable lors des fortes chaleurs estivales.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
    titre: "Rénovation esthétique de la façade",
    desc: "L'isolation extérieure permet de rénover entièrement l'apparence du logement grâce à un large choix de finitions et d'enduits.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
    titre: "Valorisation du patrimoine",
    desc: "Un logement performant énergétiquement bénéficie généralement d'une meilleure valorisation sur le marché immobilier.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    titre: "Protection durable des murs",
    desc: "L'ITE protège les façades des intempéries et contribue à prolonger leur durée de vie.",
  },
];

const etapes = [
  { num: "01", titre: "Étude du projet", desc: "Analyse de votre habitation, de l'état des façades et de vos objectifs énergétiques." },
  { num: "02", titre: "Préparation des supports", desc: "Nettoyage des murs, traitement des éventuelles fissures et préparation des surfaces." },
  { num: "03", titre: "Pose de l'isolant", desc: "Installation de l'isolant selon les normes en vigueur et les performances recherchées." },
  { num: "04", titre: "Finitions de façade", desc: "Application des enduits ou revêtements décoratifs pour un rendu esthétique durable." },
  { num: "05", titre: "Contrôle et réception", desc: "Vérification complète des travaux avant la livraison du chantier." },
];

const aides = [
  {
    titre: "MaPrimeRénov'",
    desc: "Aide de l'État destinée aux travaux d'amélioration énergétique. Son montant dépend de vos revenus et du gain énergétique obtenu.",
    couleur: "#1E4B8C",
  },
  {
    titre: "Certificats d'Économies d'Énergie (CEE)",
    desc: "Prime versée par les fournisseurs d'énergie pour encourager les travaux de rénovation. Cumulable avec MaPrimeRénov'.",
    couleur: "#E8650A",
  },
  {
    titre: "Éco-prêt à taux zéro",
    desc: "Financement sans intérêts pour certains projets de rénovation énergétique. Jusqu'à 50 000 € remboursables sur 20 ans.",
    couleur: "#1E4B8C",
  },
  {
    titre: "TVA réduite à 5,5 %",
    desc: "Taux de TVA avantageux applicable aux travaux de rénovation énergétique, sous conditions.",
    couleur: "#E8650A",
  },
];

const engagements = [
  "Artisan local depuis 1969",
  "Entreprise familiale locale",
  "Certifications RGE et Qualibat",
  "Accompagnement personnalisé",
  "Intervention dans tout le Tarn",
  "Devis gratuit",
];

const faqs = [
  {
    q: "Quel est le prix d'une isolation thermique extérieure ?",
    a: "Le coût varie selon la surface traitée, les matériaux isolants choisis et la configuration du logement. Comptez généralement entre 100 et 200 €/m² posé. Contactez-nous pour un devis gratuit et personnalisé adapté à votre projet.",
  },
  {
    q: "Quelles aides puis-je obtenir pour mon projet d'ITE ?",
    a: "Plusieurs aides sont cumulables : MaPrimeRénov', les Certificats d'Économies d'Énergie (CEE), l'Éco-prêt à taux zéro et la TVA à 5,5 %. Étant certifié RGE, Conesa vous permet d'accéder à l'ensemble de ces dispositifs. Nous vous guidons dans vos démarches.",
  },
  {
    q: "Combien de temps durent les travaux d'isolation extérieure ?",
    a: "La durée varie selon la superficie de la façade et les conditions météorologiques. En règle générale, comptez entre 1 et 3 semaines pour une maison individuelle. Nous vous communiquons un planning précis dès l'établissement du devis.",
  },
  {
    q: "Faut-il quitter son logement pendant le chantier ?",
    a: "Non, les travaux d'isolation thermique extérieure se déroulent entièrement à l'extérieur du bâtiment. Vous pouvez occuper normalement votre logement pendant toute la durée du chantier.",
  },
  {
    q: "L'isolation extérieure modifie-t-elle l'apparence de ma maison ?",
    a: "Oui, et c'est souvent un avantage apprécié. L'ITE permet de rénover entièrement la façade. Vous disposez d'un large choix de finitions, d'enduits et de coloris pour personnaliser l'aspect extérieur de votre habitation.",
  },
  {
    q: "Quelle est la durée de vie d'une isolation thermique extérieure ?",
    a: "Réalisée avec des matériaux de qualité et dans les règles de l'art, une isolation extérieure présente une durée de vie de 30 ans et plus. Un entretien régulier de la façade contribue à prolonger cette longévité.",
  },
  {
    q: "Intervenez-vous dans tout le Tarn ?",
    a: "Oui, nos équipes interviennent dans l'ensemble du département du Tarn (81) : Albi, Gaillac, Castres, Graulhet, Carmaux, Lavaur, Réalmont, Mazamet, Saint-Sulpice et leurs communes environnantes.",
  },
  {
    q: "Comment obtenir un devis pour mon projet d'ITE ?",
    a: "Remplissez notre formulaire en ligne, appelez-nous ou envoyez-nous un email. Nous vous recontactons sous 24h pour fixer un rendez-vous et établir un devis gratuit, détaillé et sans engagement.",
  },
];
---

<BaseLayout
  title="Isolation Thermique Extérieure dans le Tarn"
  description="Conesa — Spécialiste de l'isolation thermique extérieure dans le Tarn depuis plus de 55 ans. Certifié RGE et Qualibat. Devis gratuit."
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": { "@type": "Answer", "text": faq.a }
    }))
  })} />

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[#0A1E3D]" style="padding-top: 160px; padding-bottom: 96px;">
    <!-- IMAGE DE FOND — remplacer le src par le chemin de votre photo -->
    <img
      src="/images/Page-isolation-ext/hero isolation extérieure.png"
      alt="Isolation thermique extérieure d'une maison dans le Tarn — Conesa"
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
      fetchpriority="high"
      onerror="this.style.display='none'"
    />
    <!-- Overlay sombre pour lisibilité du texte -->
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,30,61,0.90) 0%, rgba(30,75,140,0.75) 60%, rgba(10,30,61,0.70) 100%);"></div>
    <!-- Grille de points (par-dessus l'overlay) -->
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 28px 28px;"></div>
    <!-- Trait orange décoratif -->
    <div class="absolute top-0 left-0 w-1 h-full bg-[#E8650A] opacity-60"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">

        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 text-sm font-medium text-white mb-8">
          <span class="w-2 h-2 bg-[#E8650A] rounded-full"></span>
          Certifié RGE &amp; Qualibat — Entreprise familiale depuis 1969
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-[3rem] font-extrabold text-white leading-[1.1] mb-6" style="font-family:'Montserrat',sans-serif;">
          Isolation Thermique<br>Extérieure
          <span class="text-[#E8650A]"> dans le Tarn</span>
        </h1>

        <p class="text-blue-100 text-lg leading-relaxed mb-4 max-w-xl">
          Vous souhaitez améliorer le confort de votre habitation, réduire vos dépenses énergétiques et moderniser l'apparence de votre façade ? L'isolation thermique extérieure est aujourd'hui l'une des solutions les plus performantes pour améliorer durablement votre logement.
        </p>
        <p class="text-blue-200 text-base leading-relaxed mb-10 max-w-xl">
          Depuis plus de 55 ans, Conesa accompagne les particuliers dans leurs projets de rénovation énergétique à Albi, Gaillac, Castres et dans tout le Tarn.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="#contact" class="inline-flex items-center justify-center gap-2 bg-[#E8650A] hover:bg-orange-700 text-white font-bold px-8 py-4 rounded-xl transition-all duration-200 hover:scale-105 shadow-lg shadow-orange-900/30">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Demander un devis gratuit
          </a>
          <a href="#aides" class="inline-flex items-center justify-center gap-2 border-2 border-white/30 text-white hover:bg-white/10 font-semibold px-8 py-4 rounded-xl transition-all duration-200">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Découvrir les aides financières
          </a>
        </div>

        <div class="flex items-center gap-6 pt-8 border-t border-white/10">
          <div class="flex items-center gap-2.5">
            <img src="/images/labels/Logo-RGE.png" alt="RGE Qualibat" class="h-11 w-auto bg-white rounded-lg p-1 shadow" loading="lazy" decoding="async" onerror="this.style.display='none'"/>
            <span class="text-blue-100 text-sm">Certifié RGE & Qualibat</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       QU'EST-CE QUE L'ITE ?
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Définition</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 mb-8 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Qu'est-ce que l'isolation thermique extérieure ?
          </h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>L'isolation thermique extérieure (ITE) consiste à appliquer un matériau isolant directement sur les murs extérieurs d'une habitation avant de le recouvrir d'une finition adaptée, comme un enduit ou un revêtement décoratif.</p>
            <p>Cette technique permet de créer une enveloppe isolante continue autour du bâtiment afin de limiter les déperditions de chaleur et d'améliorer les performances énergétiques du logement.</p>
            <p>Contrairement à une isolation réalisée par l'intérieur, l'ITE permet de conserver l'intégralité de la surface habitable tout en rénovant l'aspect extérieur de la maison.</p>
            <p>Elle constitue une solution idéale pour les propriétaires souhaitant réaliser une rénovation énergétique complète tout en valorisant leur patrimoine.</p>
          </div>
        </div>

        <!-- Visuel chiffres clés -->
        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "30%", label: "de pertes de chaleur par les murs en moyenne" },
            { val: "30 ans", label: "de durée de vie minimale d'une ITE bien posée" },
            { val: "55+", label: "ans d'expérience de Conesa en rénovation" },
            { val: "100%", label: "de la surface habitable conservée" },
          ].map(item => (
            <div class="bg-[#F0F5FC] rounded-2xl p-6 text-center">
              <p class="text-3xl font-extrabold text-[#1E4B8C] mb-2" style="font-family:'Montserrat',sans-serif;">{item.val}</p>
              <p class="text-gray-600 text-sm leading-snug">{item.label}</p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       AVANTAGES
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Bénéfices</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Les avantages de l'isolation thermique extérieure
        </h2>
        <p class="text-gray-600 mt-4 text-lg max-w-2xl mx-auto">
          Au-delà des économies d'énergie, l'ITE apporte de nombreux bénéfices au quotidien et dans la durée.
        </p>
      </div>

      <!-- Mobile / Tablette : carousel -->
      <style>#av-root{--per-page:1}@media(min-width:640px){#av-root{--per-page:2}}</style>
      <div id="av-root" class="relative lg:hidden">
        <button id="av-prev" aria-label="Précédent"
          class="absolute -left-3 sm:-left-5 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full bg-white shadow-md border border-gray-200 flex items-center justify-center text-[#1E4B8C] hover:bg-[#1E4B8C] hover:text-white transition-colors duration-200">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="av-next" aria-label="Suivant"
          class="absolute -right-3 sm:-right-5 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full bg-white shadow-md border border-gray-200 flex items-center justify-center text-[#1E4B8C] hover:bg-[#1E4B8C] hover:text-white transition-colors duration-200">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
        <div class="overflow-hidden">
          <div id="av-track" class="flex" style="transition: transform 0.45s ease; will-change: transform;">
            {avantages.map(item => (
              <div style="width: calc(100% / var(--per-page)); flex-shrink: 0; padding: 0 8px; box-sizing: border-box;">
                <div class="bg-white rounded-2xl p-7 shadow-sm border border-gray-100 group hover:border-[#1E4B8C]/20 hover:shadow-md transition-all duration-300 h-full">
                  <div class="w-14 h-14 bg-[#E8F0FB] group-hover:bg-[#1E4B8C] rounded-xl flex items-center justify-center text-[#1E4B8C] group-hover:text-white transition-colors duration-300 mb-5">
                    <Fragment set:html={item.icon} />
                  </div>
                  <span class="block font-bold text-[#1E4B8C] text-base mb-3" style="font-family:'Montserrat',sans-serif;">{item.titre}</span>
                  <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div id="av-dots" class="flex justify-center gap-2 mt-6"></div>
      </div>

      <!-- Desktop : grille 3 colonnes -->
      <div class="hidden lg:grid lg:grid-cols-3 gap-6">
        {avantages.map((item, i) => (
          <div class={`bg-white rounded-2xl p-7 shadow-sm border border-gray-100 group hover:border-[#1E4B8C]/20 hover:shadow-md transition-all duration-300 ${i === 4 ? 'lg:col-start-2' : ''}`}>
            <div class="w-14 h-14 bg-[#E8F0FB] group-hover:bg-[#1E4B8C] rounded-xl flex items-center justify-center text-[#1E4B8C] group-hover:text-white transition-colors duration-300 mb-5">
              <Fragment set:html={item.icon} />
            </div>
            <h3 class="font-bold text-[#1E4B8C] text-base mb-3" style="font-family:'Montserrat',sans-serif;">{item.titre}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       POURQUOI CONESA
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Texte -->
        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Votre artisan de confiance</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 mb-8 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Votre partenaire de confiance pour l'isolation thermique extérieure dans le Tarn
          </h2>
          <div class="space-y-4 text-gray-600 leading-relaxed mb-10">
            <p>Faire appel à Conesa, c'est bénéficier de l'accompagnement d'une entreprise familiale reconnue dans le Tarn pour son sérieux et son savoir-faire.</p>
            <p>Depuis plusieurs générations, nous réalisons des travaux de rénovation de façade et d'isolation thermique extérieure adaptés aux besoins de chaque habitation.</p>
            <p>Grâce à nos certifications RGE et Qualibat, nous garantissons des prestations conformes aux exigences actuelles en matière de rénovation énergétique et vous donnons accès aux aides financières disponibles.</p>
          </div>
          <a href="#contact" class="inline-flex items-center gap-2 bg-[#1E4B8C] hover:bg-[#153566] text-white font-bold px-10 py-4 rounded-xl transition-colors duration-200">
            Demander un devis gratuit
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- Engagements -->
        <div class="bg-[#1E4B8C] rounded-3xl text-white p-8 lg:p-10">
          <h3 class="font-bold text-xl mb-8" style="font-family:'Montserrat',sans-serif;">Nos engagements</h3>
          <ul class="space-y-4">
            {engagements.map(e => (
              <li class="flex items-center gap-4">
                <span class="w-6 h-6 bg-[#E8650A] rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
                <span class="text-blue-100 font-medium">{e}</span>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       ÉTAPES DU CHANTIER
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Notre méthode</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Les étapes d'un chantier d'isolation thermique extérieure
        </h2>
        <p class="text-gray-600 mt-4 text-lg max-w-2xl mx-auto">
          Chaque projet est unique. Nous suivons un processus rigoureux pour garantir des résultats durables.
        </p>
      </div>

      <!-- Mobile / tablette : carousel JS -->
      <style>#et-root{--per-page:1}@media(min-width:640px){#et-root{--per-page:2}}</style>
      <div id="et-root" class="relative lg:hidden">
        <button id="et-prev" aria-label="Précédent"
          class="absolute -left-3 sm:-left-5 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full bg-white shadow-md border border-gray-200 flex items-center justify-center text-[#1E4B8C] hover:bg-[#1E4B8C] hover:text-white transition-colors duration-200">
