        if (!avDotsEl) return;
        avDotsEl.innerHTML = '';
        const total = avMaxIdx() + 1;
        for (let i = 0; i < total; i++) {
          const btn = document.createElement('button');
          btn.className = i === avCurrent
            ? 'av-dot w-6 h-2.5 rounded-full transition-all duration-300 bg-[#1E4B8C]'
