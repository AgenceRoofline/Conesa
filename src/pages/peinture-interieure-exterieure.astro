  const getCardWidth = () => {
    const card = scroll?.querySelector<HTMLElement>('[class*="snap-start"]');
    if (!card || !scroll) return 300;
    const gap = parseInt(getComputedStyle(scroll).gap) || 20;
    return card.offsetWidth + gap;
  };

  document.getElementById('prest-prev')?.addEventListener('click', () => {
    scroll?.scrollBy({ left: -getCardWidth(), behavior: 'smooth' });
  });
  document.getElementById('prest-next')?.addEventListener('click', () => {
    scroll?.scrollBy({ left: getCardWidth(), behavior: 'smooth' });
  });

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const idx = Number(dot.dataset.dot);
      scroll?.scrollTo({ left: idx * getCardWidth(), behavior: 'smooth' });
    });
  });

  scroll?.addEventListener('scroll', () => {
    if (!scroll) return;
    const idx = Math.round(scroll.scrollLeft / getCardWidth());
    dots.forEach((d, i) => {
      d.classList.toggle('w-6', i === idx);
      d.classList.toggle('w-2', i !== idx);
      d.classList.toggle('bg-[#1E4B8C]', i === idx);
      d.classList.toggle('bg-gray-300', i !== idx);
    });
  }, { passive: true });

  // ── FAQ accordion ──────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
    const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger')!;
    const body    = item.querySelector<HTMLElement>('.faq-body')!;
    const icon    = item.querySelector<SVGElement>('.faq-icon')!;

    trigger.addEventListener('click', () => {
      const isOpen = item.dataset.open === 'true';
      document.querySelectorAll<HTMLElement>('.faq-item').forEach(other => {
        other.dataset.open = 'false';
        const b  = other.querySelector<HTMLElement>('.faq-body')!;
        const ic = other.querySelector<SVGElement>('.faq-icon')!;
        b.style.maxHeight = '0';
        ic.style.transform = '';
        ic.style.color = '';
      });
      if (!isOpen) {
        item.dataset.open = 'true';
        body.style.maxHeight = body.scrollHeight + 'px';
        icon.style.transform = 'rotate(180deg)';
        icon.style.color = '#E8650A';
      }
    });
  });
</script>
