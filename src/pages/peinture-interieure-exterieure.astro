---
import BaseLayout from '../layouts/BaseLayout.astro';
import ZonesIntervention from '../components/ZonesIntervention.astro';

const prestations = [
  {
    badge: "Intérieur",
    titre: "Peinture des murs & plafonds",
    desc: "Rénovation des pièces de vie, chambres, cuisines et couloirs. Correction des imperfections, application uniforme pour un résultat net et homogène sur tous types de supports.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
    badgeColor: "blue",
  },
  {
    badge: "Intérieur",
    titre: "Préparation des supports",
    desc: "Rebouchage, ponçage, lissage et impression avant toute application. Une préparation rigoureuse des surfaces garantit l'adhérence et la durabilité du résultat final.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>`,
    badgeColor: "blue",
  },
  {
    badge: "Décoration",
    titre: "Finitions & effets décoratifs",
    desc: "Peintures mates, satinées, velours ou brillantes selon vos préférences. Enduits décoratifs, papiers peints panoramiques et textures pour des intérieurs uniques et personnalisés.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>`,
    badgeColor: "orange",
  },
  {
    badge: "Décoration",
    titre: "Conseil couleurs & personnalisation",
    desc: "Accompagnement dans le choix des teintes, harmonies et matières pour créer des espaces à votre image. Chaque projet est unique, chaque intérieur mérite une approche sur mesure.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>`,
    badgeColor: "orange",
  },
  {
    badge: "Extérieur",
    titre: "Peinture de façade",
    desc: "Application de peintures haute performance résistantes aux UV et aux intempéries. Rafraîchissement esthétique et protection renforcée des murs extérieurs pour plusieurs années.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>`,
    badgeColor: "blue",
  },
  {
    badge: "Extérieur",
    titre: "Protection & rénovation des supports",
    desc: "Reprise des anciens revêtements, traitement avant application, sous-couches d'accrochage. Finitions durables résistant à l'exposition solaire, au gel et à l'humidité.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>`,
    badgeColor: "blue",
  },
];

const signaux = [
  {
    titre: "Peinture qui s'écaille ou se cloque",
    desc: "L'écaillage et le cloquage signalent une peinture en fin de vie ou un problème d'humidité sous-jacent. Une reprise s'impose avant que les surfaces ne se dégradent davantage.",
    type: "Intérieur",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>`,
  },
  {
    titre: "Couleurs ternies ou jaunies",
    desc: "Sous l'effet du soleil et du temps, les teintes perdent leur éclat. Un rafraîchissement restitue immédiatement la luminosité et modernise l'ensemble de la pièce.",
    type: "Intérieur",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707"/>`,
  },
  {
    titre: "Taches d'humidité ou moisissures",
    desc: "Auréoles, taches brunes ou moisissures indiquent une infiltration ou un problème de condensation. Au-delà de l'aspect, c'est la qualité de l'air intérieur qui est en jeu.",
    type: "Intérieur & Extérieur",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>`,
  },
  {
    titre: "Façade décolorée ou peinture extérieure dégradée",
    desc: "Une façade ternie, fissurée ou dont la peinture se détache nuit à l'esthétique et à la protection du bâti. Un rafraîchissement régulier préserve les supports.",
    type: "Extérieur",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
];

const avantages = [
  {
    titre: "Un rendu esthétique durable",
    desc: "Des peintures de qualité professionnelle conservent leur éclat bien plus longtemps que les produits grand public. Vos surfaces restent propres, uniformes et agréables à vivre.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>`,
    color: "orange",
  },
  {
    titre: "Des finitions soignées au détail",
    desc: "Raccords invisibles, angles nets, surface uniforme. Nos artisans maîtrisent les techniques d'application pour un résultat net, sans coulures ni manques.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
    color: "blue",
  },
  {
    titre: "Une meilleure tenue dans le temps",
    desc: "La préparation des supports, le choix des produits adaptés et les techniques d'application garantissent une adhérence et une durabilité bien supérieures à un travail amateur.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
    color: "orange",
  },
  {
    titre: "Un accompagnement personnalisé",
    desc: "Conseils sur les teintes, finitions et matières selon votre espace et vos préférences. Nous vous aidons à créer un intérieur qui vous ressemble.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>`,
    color: "blue",
  },
];

const etapes = [
  { num: "01", titre: "Visite et analyse du projet", desc: "Évaluation des surfaces à traiter, identification des pathologies (humidité, écaillage, fissures légères) et discussion sur vos souhaits de teintes et finitions." },
  { num: "02", titre: "Conseil couleurs & finitions", desc: "Présentation des peintures, teintes et effets décoratifs adaptés à votre espace. Nous vous aidons à choisir ce qui correspond à votre style et aux contraintes techniques." },
  { num: "03", titre: "Préparation des surfaces", desc: "Rebouchage, ponçage, lissage et impression des supports. Étape fondamentale pour garantir une bonne adhérence et un résultat durable dans le temps." },
  { num: "04", titre: "Application des peintures", desc: "Application en plusieurs couches selon les règles de l'art, avec les outils adaptés à chaque surface. Sols et menuiseries protégés avant toute intervention." },
  { num: "05", titre: "Contrôle qualité & réception", desc: "Vérification minutieuse du résultat, levée des réserves et remise en état des abords. Chantier rendu propre, conforme à vos attentes." },
];

const engagements = [
  "Plus de 55 ans d'expérience en peinture et décoration",
  "Entreprise familiale et équipes locales dans le Tarn",
  "Certification RGE et Qualibat",
  "Devis gratuit, détaillé et sans engagement",
  "Garantie décennale sur les travaux réalisés",
  "Conseil personnalisé couleurs et finitions",
  "Interlocuteur unique pour tout votre chantier",
];

const villes = ["Albi", "Gaillac", "Castres", "Graulhet", "Lavaur", "Carmaux", "Mazamet", "Saint-Sulpice"];

const villesLinks: Record<string, string> = {
  "Albi": "/villes/albi",
  "Gaillac": "/villes/gaillac",
  "Castres": "/villes/castres",
  "Graulhet": "/villes/graulhet",
};

const faqs = [
  {
    q: "Quelle est la durée de vie d'une peinture intérieure ?",
    a: "Une peinture intérieure professionnelle dure en moyenne 8 à 15 ans selon l'exposition de la pièce, les produits utilisés et l'entretien. Les pièces humides (salle de bain, cuisine) nécessitent des peintures spécifiques et peuvent demander un rafraîchissement plus fréquent.",
  },
  {
    q: "Quelle peinture choisir pour une pièce humide ?",
    a: "Pour les salles de bain et cuisines, il faut opter pour des peintures spéciales 'pièces humides', formulées pour résister à la vapeur d'eau, aux projections et aux moisissures. Elles contiennent des agents fongicides et offrent une meilleure imperméabilité. Nos artisans vous conseillent sur le produit le mieux adapté.",
  },
  {
    q: "Faut-il préparer les murs avant de peindre ?",
    a: "Oui, la préparation des supports est indispensable. Rebouchage des trous et fissures, ponçage des zones abîmées, lissage si nécessaire et application d'une sous-couche d'impression. Sans cette étape, la peinture risque de mal adhérer et de s'écailler prématurément.",
  },
  {
    q: "Quelle différence entre peinture mate et satinée ?",
    a: "La peinture mate offre un aspect velouté qui absorbe la lumière et masque mieux les imperfections — idéale pour les séjours et chambres. La satinée est légèrement brillante, résistante aux nettoyages, adaptée aux pièces humides et aux zones de passage. Le velours est une finition intermédiaire très appréciée pour son rendu élégant.",
  },
  {
    q: "Quand refaire une peinture extérieure ?",
    a: "En général, une peinture extérieure se refait tous les 8 à 12 ans. Certains signes justifient une intervention plus tôt : écaillage, cloquage, décollement, décoloration marquée ou fissures superficielles. L'exposition aux UV et aux intempéries accélère le vieillissement des façades exposées.",
  },
  {
    q: "Combien coûtent des travaux de peinture ?",
    a: "Le coût varie selon la surface, l'état des murs et le type de finition choisi. En général : entre 15 et 35 €/m² pour une peinture intérieure, entre 25 et 60 €/m² pour une peinture extérieure. Contactez-nous pour un devis gratuit et personnalisé adapté à votre chantier.",
  },
  {
    q: "Combien de temps durent les travaux ?",
    a: "Pour une pièce ou un appartement, comptez 1 à 3 jours selon la surface et la préparation nécessaire. Pour une maison complète ou une façade extérieure, la durée est généralement de 3 à 7 jours. Un calendrier précis vous est communiqué dès l'établissement du devis.",
  },
  {
    q: "Comment obtenir un devis ?",
    a: "Remplissez notre formulaire de contact, appelez-nous au 05 63 54 16 97 ou envoyez-nous un email. Un artisan Conesa se déplace gratuitement pour évaluer vos surfaces et vous remettre un devis détaillé, sans engagement de votre part.",
  },
];

const jsonLdService = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Peinture intérieure et extérieure",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Conesa",
    "telephone": "+33563541697",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Albi",
      "postalCode": "81000",
      "addressCountry": "FR"
    }
  },
  "areaServed": { "@type": "AdministrativeArea", "name": "Tarn" },
  "description": "Travaux de peinture intérieure, extérieure et décoration dans le Tarn. Conseils, finitions soignées et devis gratuit avec Conesa.",
  "url": "https://conesa-renovation.fr/peinture-interieure-exterieure"
});

const jsonLdBreadcrumb = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://conesa-renovation.fr/" },
    { "@type": "ListItem", "position": 2, "name": "Peinture intérieure et extérieure", "item": "https://conesa-renovation.fr/peinture-interieure-exterieure" }
  ]
});

const jsonLdFaq = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
});
---

<BaseLayout
  title="Peinture intérieure et extérieure dans le Tarn | Conesa"
  description="Travaux de peinture intérieure, extérieure et décoration dans le Tarn. Conseils, finitions soignées et devis gratuit avec Conesa."
>
  <script is:inline slot="head" type="application/ld+json" set:html={jsonLdService} />
  <script is:inline slot="head" type="application/ld+json" set:html={jsonLdBreadcrumb} />
  <script is:inline slot="head" type="application/ld+json" set:html={jsonLdFaq} />

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[#0A1E3D]" style="padding-top: 200px; padding-bottom: 96px;">
    <img
      src={encodeURI("/images/Page peinture interieure exterieure/Hero peinture intérieure extérieure.png")}
      alt="Peinture intérieure et extérieure dans le Tarn — Conesa"
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
      fetchpriority="high"
      onerror="this.style.display='none'"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,30,61,0.92) 0%, rgba(30,75,140,0.78) 60%, rgba(10,30,61,0.72) 100%);"></div>
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="absolute top-0 left-0 w-1 h-full bg-[#E8650A] opacity-60"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/50 text-sm mb-8" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-white transition-colors">Accueil</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span class="text-white/80">Peinture intérieure &amp; extérieure</span>
      </nav>

      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 text-sm font-medium text-white mb-8">
          <span class="w-2 h-2 bg-[#E8650A] rounded-full"></span>
          Entreprise familiale dans le Tarn depuis 1969
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-[3rem] font-extrabold text-white leading-[1.1] mb-6" style="font-family:'Montserrat',sans-serif;">
          Peinture intérieure<br>&amp; extérieure
          <span class="text-[#E8650A]"> dans le Tarn</span>
        </h1>
        <p class="text-blue-100 text-lg leading-relaxed mb-10 max-w-xl">
          De la rénovation de vos pièces de vie aux façades extérieures, Conesa vous accompagne dans tous vos projets de peinture et de décoration dans tout le département du Tarn.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="#contact" class="inline-flex items-center justify-center gap-2 bg-[#E8650A] hover:bg-orange-700 text-white font-bold px-8 py-4 rounded-xl transition-all duration-200 hover:scale-105 shadow-lg shadow-orange-900/30">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Demander un devis gratuit
          </a>
          <a href="tel:0563541697" class="inline-flex items-center justify-center gap-2 border-2 border-white/30 text-white hover:bg-white/10 font-semibold px-8 py-4 rounded-xl transition-all duration-200">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            05 63 54 16 97
          </a>
        </div>
        <div class="flex items-center gap-4">
          <img src="/images/labels/Logo-RGE.png" alt="RGE Qualibat" class="h-11 w-auto bg-white rounded-lg p-1 shadow" loading="lazy" decoding="async" onerror="this.style.display='none'"/>
          <span class="text-blue-100 text-sm">Certifié RGE &amp; Qualibat — Devis gratuit sous 24 h</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       POURQUOI RÉNOVER — image à gauche, texte à droite
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Image + encarts -->
        <div>
          <div class="relative rounded-2xl overflow-hidden shadow-2xl" style="min-height:340px;">
            <img
              src={encodeURI("/images/Page peinture interieure exterieure/Peinture intérieur et extérieure.png")}
              alt="Peinture intérieure et extérieure — Conesa, entreprise familiale dans le Tarn"
              class="w-full h-full object-cover object-center absolute inset-0"
              loading="lazy"
              decoding="async"
              onerror="this.style.display='none'"
            />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(10,30,61,0.45) 0%, rgba(10,30,61,0.08) 45%, transparent 100%);"></div>
          </div>
          <div class="relative z-10 -mt-9 flex items-center justify-center gap-3 flex-wrap px-6">
            {[
              { val: "55+", label: "ans d'expérience" },
              { val: "Int. & Ext.", label: "peinture complète" },
            ].map(item => (
              <div class="bg-[#1E4B8C]/80 backdrop-blur-md border border-white/20 rounded-xl px-5 py-3 text-center shadow-xl min-w-[110px]">
                <p class="text-xl font-extrabold text-white leading-none mb-1" style="font-family:'Montserrat',sans-serif;">{item.val}</p>
                <p class="text-blue-200 text-xs font-medium">{item.label}</p>
              </div>
            ))}
            <div class="bg-[#E8650A]/85 backdrop-blur-md border border-white/20 rounded-xl px-5 py-3 text-center shadow-xl min-w-[110px]">
              <p class="text-xl font-extrabold text-white leading-none mb-1" style="font-family:'Montserrat',sans-serif;">Devis</p>
              <p class="text-orange-100 text-xs font-medium">gratuit sous 24 h</p>
            </div>
          </div>
        </div>

        <!-- Texte -->
        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Pourquoi rénover ?</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 mb-6 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Pourquoi rénover<br>les peintures de votre habitation ?
          </h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            Avec le temps, les peintures perdent de leur éclat, les couleurs se ternissent et certaines surfaces présentent des traces d'usure ou d'humidité. Rénover les peintures, c'est moderniser son espace, protéger durablement les supports et valoriser son patrimoine.
          </p>
          <ul class="space-y-3">
            {[
              "Moderniser son intérieur et améliorer l'ambiance des pièces",
              "Protéger les murs et plafonds contre l'usure et l'humidité",
              "Préserver les façades face aux agressions extérieures",
              "Valoriser son patrimoine immobilier",
              "Apporter une véritable plus-value esthétique à l'habitation",
              "Exprimer sa personnalité à travers les couleurs et matières",
            ].map(item => (
              <li class="flex items-start gap-3 text-gray-700 text-sm">
                <span class="w-5 h-5 rounded-full bg-[#E8650A] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
                {item}
              </li>
