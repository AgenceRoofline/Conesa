  </section>

  <script>
  (function () {
    const TOTAL   = 6;
    const track   = document.getElementById('ac-track')   as HTMLElement | null;
    const prevBtn = document.getElementById('ac-prev')    as HTMLButtonElement | null;
    const nextBtn = document.getElementById('ac-next')    as HTMLButtonElement | null;
    const dotsEl  = document.getElementById('ac-dots')    as HTMLElement | null;
    const root    = document.getElementById('ac-root')    as HTMLElement | null;
    if (!track) return;

    let current = 0;
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    function perPage(): number {
      if (window.innerWidth >= 1024) return 3;
      if (window.innerWidth >= 640)  return 2;
      return 1;
    }

    function maxIdx(): number { return Math.max(0, TOTAL - perPage()); }

    function goTo(idx: number): void {
      current = Math.max(0, Math.min(idx, maxIdx()));
      if (track) track.style.transform = `translateX(-${current * (100 / perPage())}%)`;
      syncDots();
      syncArrows();
    }

    function syncDots(): void {
      if (!dotsEl) return;
      Array.from(dotsEl.querySelectorAll<HTMLButtonElement>('.ac-dot')).forEach((d, i) => {
        if (i === current) {
          d.className = 'ac-dot w-6 h-2.5 rounded-full transition-all duration-300 bg-[#1E4B8C]';
        } else {
          d.className = 'ac-dot w-2.5 h-2.5 rounded-full transition-all duration-300 bg-gray-300 hover:bg-gray-400';
        }
      });
    }

    function syncArrows(): void {
      if (prevBtn) prevBtn.disabled = current === 0;
      if (nextBtn) nextBtn.disabled = current === maxIdx();
    }

    function buildDots(): void {
      if (!dotsEl) return;
      dotsEl.innerHTML = '';
      const total = maxIdx() + 1;
      for (let i = 0; i < total; i++) {
        const btn = document.createElement('button');
        btn.className = 'ac-dot w-2.5 h-2.5 rounded-full transition-all duration-300 bg-gray-300';
        btn.setAttribute('aria-label', `Avis ${i + 1}`);
        btn.addEventListener('click', () => { goTo(i); resetAuto(); });
        dotsEl.appendChild(btn);
      }
      syncDots();
    }

    function resetAuto(): void {
      if (autoTimer) clearInterval(autoTimer);
      autoTimer = setInterval(() => goTo(current < maxIdx() ? current + 1 : 0), 5000);
    }

    prevBtn?.addEventListener('click', () => { goTo(current - 1); resetAuto(); });
    nextBtn?.addEventListener('click', () => { goTo(current + 1); resetAuto(); });
    root?.addEventListener('mouseenter', () => { if (autoTimer) clearInterval(autoTimer); });
    root?.addEventListener('mouseleave', resetAuto);
    window.addEventListener('resize', () => {
      if (current > maxIdx()) current = maxIdx();
      buildDots();
      goTo(current);
    });

    buildDots();
    goTo(0);
    resetAuto();

    let acTouchX = 0;
    track?.addEventListener('touchstart', (e) => { acTouchX = e.touches[0].clientX; }, { passive: true });
    track?.addEventListener('touchend', (e) => {
      const delta = acTouchX - e.changedTouches[0].clientX;
      if (Math.abs(delta) > 50) { delta > 0 ? goTo(current + 1) : goTo(current - 1); resetAuto(); }
    }, { passive: true });

    const readMoreBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.ac-read-more'));

    readMoreBtns.forEach(btn => {
      const textEl = btn.previousElementSibling as HTMLElement | null;
      if (!textEl) return;
      if (textEl.scrollHeight <= textEl.clientHeight + 2) {
        btn.style.visibility = 'hidden';
        return;
      }
      btn.addEventListener('click', () => {
        const isExpanded = btn.dataset.expanded === 'true';

        readMoreBtns.forEach(other => {
          if (other === btn) return;
          const otherText = other.previousElementSibling as HTMLElement | null;
          if (!otherText || other.dataset.expanded !== 'true') return;
          other.dataset.expanded = 'false';
          otherText.style.maxHeight = '5.2rem';
          other.textContent = 'Lire plus';
        });

        btn.dataset.expanded = isExpanded ? 'false' : 'true';
        textEl.style.maxHeight = isExpanded ? '5.2rem' : textEl.scrollHeight + 'px';
        btn.textContent = isExpanded ? 'Lire plus' : 'Lire moins';
      });
    });
  })();
  </script>

  <ZonesIntervention />

  <!-- ══════════════════════════════════════
       FAQ
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Questions fréquentes</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Tout ce que vous devez savoir
        </h2>
        <p class="text-gray-600 mt-4 text-lg">
          Retrouvez les réponses aux questions les plus posées sur nos prestations, aides et délais.
        </p>
      </div>

      <div class="border-t border-gray-200">
        {faqs.map(faq => (
          <div class="faq-item border-b border-gray-200">
            <h3 class="m-0 font-normal">
              <button
                class="faq-trigger w-full flex items-center justify-between gap-6 py-5 px-1 text-left rounded-sm"
                style="transition: background 1s ease;"
              >
                <span class="faq-question font-semibold text-[#1E4B8C] text-base leading-snug" style="font-family:'Montserrat',sans-serif;">
                  {faq.q}
                </span>
                <svg
                  class="faq-icon shrink-0 w-5 h-5 text-gray-400"
                  style="transition: transform 0.45s ease, color 0.3s ease;"
                  fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
            </h3>
            <div class="faq-body overflow-hidden" style="max-height:0; transition: max-height 0.45s ease;">
              <p class="pb-6 pt-1 px-1 text-gray-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
      const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger')!;
      const body    = item.querySelector<HTMLElement>('.faq-body')!;
      const icon    = item.querySelector<SVGElement>('.faq-icon')!;

      trigger.addEventListener('click', () => {
        const isOpen = item.dataset.open === 'true';

        document.querySelectorAll<HTMLElement>('.faq-item').forEach(other => {
          other.dataset.open = 'false';
          const b = other.querySelector<HTMLElement>('.faq-body')!;
          const ic = other.querySelector<SVGElement>('.faq-icon')!;
          b.style.maxHeight = '0';
          ic.style.transform = '';
          ic.style.color = '';
        });

        if (!isOpen) {
          item.dataset.open = 'true';
          body.style.maxHeight = body.scrollHeight + 'px';
          icon.style.transform = 'rotate(180deg)';
          icon.style.color = '#E8650A';
        }
      });
    });
  </script>

