        <button id="ac-prev" aria-label="Avis précédent" class="absolute top-1/2 -translate-y-1/2 left-0 w-10 h-10 bg-white border-2 border-gray-200 rounded-full shadow flex items-center justify-center text-[#1E4B8C] hover:bg-[#1E4B8C] hover:text-white hover:border-[#1E4B8C] transition-all duration-200 disabled:opacity-30 disabled:cursor-not-allowed">
