          href="https://www.google.com/maps/place/Conesa+SARL/@43.9325239,2.1252347,12523m/data=!3m1!1e3!4m12!1m2!2m1!1sconesa+albi!3m8!1s0x12addd59965d7957:0xc75c2ab3d822a74d!8m2!3d43.952706!4d2.1512801!9m1!1b1!15sCgtjb25lc2EgYWxiaZIBB3BhaW50ZXLgAQA!16s%2Fg%2F1vf_2r_d?entry=ttu&g_ep=EgoyMDI2MDYwMS4wIKXMDSoASAFQAw%3D%3D"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border-2 border-[#1E4B8C] text-[#1E4B8C] hover:bg-[#1E4B8C] hover:text-white font-semibold text-sm px-6 py-3 rounded-xl transition-all duration-200"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
          </svg>
          Laisser mon avis Google
        </a>
