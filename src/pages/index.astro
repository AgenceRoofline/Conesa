---

<BaseLayout
  title="Isolation & Rénovation dans le Tarn"
  description="Isolation thermique extérieure, ravalement de façade et rénovation dans le Tarn. Entreprise familiale certifiée RGE depuis 1969. Devis gratuit."
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Conesa",
    "image": "https://conesa-renovation.fr/images/Logo/Logo-Conesa.svg",
    "description": "Entreprise familiale de rénovation et isolation thermique extérieure dans le Tarn (81) depuis 1969. Certifiée RGE et Qualibat.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "31 Petit Chemin des Broucouniès",
      "addressLocality": "Albi",
      "postalCode": "81000",
      "addressRegion": "Occitanie",
      "addressCountry": "FR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 43.9527,
      "longitude": 2.1513
    },
    "telephone": "+33563541697",
    "email": "conesa81@wanadoo.fr",
    "url": "https://conesa-renovation.fr",
    "foundingDate": "1969",
    "priceRange": "€€",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.6",
      "ratingCount": "50",
      "bestRating": "5",
      "worstRating": "1"
    },
    "areaServed": [
      { "@type": "City", "name": "Albi" },
      { "@type": "City", "name": "Gaillac" },
      { "@type": "City", "name": "Castres" },
      { "@type": "City", "name": "Graulhet" },
      { "@type": "AdministrativeArea", "name": "Tarn" }
    ],
    "sameAs": [
      "https://www.facebook.com/sarl.conesa/"
    ]
  })} />
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": { "@type": "Answer", "text": faq.a }
    }))
  })} />

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[#0A1E3D]" style="min-height:100vh;display:flex;align-items:center;">
    <img
      src="/images/Page accueil/hero-accueil.png"
      alt="Chantier de rénovation et isolation thermique extérieure dans le Tarn — Conesa"
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
      fetchpriority="high"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,30,61,0.88) 0%, rgba(30,75,140,0.72) 55%, rgba(10,30,61,0.60) 100%);"></div>
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 28px 28px;"></div>

    <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-36 pb-20 lg:pt-44 lg:pb-28">
      <div class="grid lg:grid-cols-[3fr_2fr] gap-16 items-center">

        <div class="text-white">
          <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 text-sm font-medium mb-8">
            <span class="w-2 h-2 bg-[#E8650A] rounded-full animate-pulse"></span>
            Entreprise familiale dans le Tarn depuis 1969
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[3.2rem] font-extrabold leading-[1.1] mb-6" style="font-family:'Montserrat',sans-serif;">
            Isolation Thermique Extérieure,
            <br>Façade & Rénovation
            <br><span class="text-[#E8650A]">dans le Tarn</span>
          </h1>

          <p class="text-blue-100 text-lg leading-relaxed mb-10 max-w-xl">
            Depuis plus de 55 ans, Conesa accompagne les particuliers dans leurs projets d'isolation extérieure, rénovation de façade et entretien de l'habitat dans tout le département du Tarn.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mb-12">
            <a href="#contact" class="inline-flex items-center justify-center gap-3 bg-[#E8650A] hover:bg-orange-700 text-white font-bold px-8 py-4 rounded-xl transition-all duration-200 hover:scale-105 shadow-lg shadow-orange-900/30">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              Demander un devis gratuit
            </a>
            <a href="tel:0563541697" class="inline-flex items-center justify-center gap-3 border-2 border-white/30 text-white hover:bg-white/10 font-semibold px-8 py-4 rounded-xl transition-all duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Être rappelé
            </a>
          </div>
        </div>

        <div class="hidden lg:block"></div>

      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="bg-[#E8650A]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {stats.map((s) => (
          <div class="text-center text-white">
            <p class="text-3xl font-extrabold leading-none" style="font-family:'Montserrat',sans-serif;">{s.value}</p>
            <p class="text-orange-100 text-sm mt-1">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       PRÉSENTATION DE L'ENTREPRISE
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Entreprise familiale depuis 1969</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 mb-6 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Une entreprise familiale au service de votre habitat depuis plus de 55 ans
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Depuis plus de 55 ans, Conesa accompagne les particuliers, professionnels et collectivités dans leurs projets de rénovation et d'amélioration de l'habitat dans tout le Tarn. Entreprise familiale implantée à Albi, nous intervenons sur des travaux de façade, d'isolation thermique extérieure, de peinture, de revêtements de sols, d'entretien de toiture et de remise en état après sinistre.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
