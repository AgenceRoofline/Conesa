    .pp-zoom.pp-active {
      transform: scale(1.05);
      z-index: 10;
      cursor: default;
      box-shadow: 0 24px 64px rgba(0,0,0,0.18);
    }
    .pp-zoom.pp-inactive {
      filter: blur(3px);
      opacity: 0.5;
      z-index: 0;
    }
  </style>

  <script>
  (function () {
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.pp-zoom'));
    const defaultActive = document.getElementById('pp-part');
    if (!defaultActive) return;

    cards.forEach(c => c.classList.remove('pp-active', 'pp-inactive'));
    defaultActive.classList.add('pp-active');
    cards.filter(c => c !== defaultActive).forEach(c => c.classList.add('pp-inactive'));

    cards.forEach(card => {
      card.addEventListener('click', () => {
        cards.forEach(c => c.classList.remove('pp-active', 'pp-inactive'));
        card.classList.add('pp-active');
        cards.filter(c => c !== card).forEach(c => c.classList.add('pp-inactive'));
      });
    });
  })();
  </script>

