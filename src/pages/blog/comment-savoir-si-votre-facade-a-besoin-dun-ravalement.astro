---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqs = [
  {
    q: "À quelle fréquence faut-il ravaler une façade ?",
    a: "En général, un ravalement de façade est recommandé tous les 10 à 15 ans, selon les matériaux et l'exposition du bâtiment. Un entretien régulier peut prolonger ce délai.",
  },
  {
    q: "Une fissure sur une façade est-elle forcément grave ?",
    a: "Pas forcément. Les microfissures liées au vieillissement naturel sont courantes. En revanche, des fissures qui s'élargissent, traversantes ou accompagnées d'humidité intérieure nécessitent un diagnostic professionnel rapide.",
  },
  {
    q: "Peut-on repeindre une façade sans la rénover complètement ?",
    a: "Oui, si l'état du support le permet. Une simple peinture de façade peut suffire lorsque le revêtement est encore sain. En cas d'enduit dégradé ou de fissures importantes, une rénovation complète est préférable pour garantir la durabilité.",
  },
  {
    q: "Comment éliminer les mousses sur une façade ?",
    a: "Un nettoyage professionnel par hydrogommage ou traitement chimique est recommandé. L'application d'un produit hydrofuge après le nettoyage limite leur réapparition.",
  },
  {
    q: "Quel est le prix d'un ravalement de façade ?",
    a: "Le coût dépend de la superficie, de l'état de la façade et des prestations nécessaires. Contactez-nous pour un devis gratuit et personnalisé adapté à votre habitation.",
  },
  {
    q: "Faut-il une autorisation pour ravaler sa façade ?",
    a: "Dans certaines communes ou zones protégées, une déclaration préalable de travaux peut être exigée. Votre mairie vous informera des démarches à effectuer selon votre situation.",
  },
  {
    q: "Une façade dégradée peut-elle provoquer des infiltrations ?",
    a: "Oui. Des fissures, un enduit détérioré ou des mousses non traitées peuvent favoriser la pénétration de l'eau dans les murs et provoquer des dégâts à l'intérieur du logement.",
  },
  {
    q: "Comment obtenir un devis pour rénover ma façade ?",
    a: "Remplissez notre formulaire de contact ou appelez-nous directement. Nous vous recontactons sous 24h pour organiser une visite et établir un devis gratuit sur mesure.",
  },
];

const currentHref = "/blog/comment-savoir-si-votre-facade-a-besoin-dun-ravalement";
const articles = [
  {
    href: "/blog/isolation-interieure-ou-exterieure",
    categorie: "Isolation",
    titre: "Isolation intérieure ou extérieure : quelle solution choisir ?",
    description: "Comparez l'isolation thermique par l'intérieur et par l'extérieur : avantages, performances, coûts et aides disponibles pour bien choisir.",
    image: "/images/blog/Isolation-intérieure-ou-extérieure/hero isolation-interieure-exterieure.png",
    badge: "bg-[#E8F0FB] text-[#1E4B8C]",
  },
  {
    href: "/blog/demoussage-toiture-pourquoi-ne-pas-attendre",
    categorie: "Toiture",
    titre: "Démoussage de toiture : pourquoi ne faut-il pas attendre ?",
    description: "Mousses, lichens, infiltrations… Découvrez pourquoi un entretien régulier de votre toiture évite des réparations bien plus coûteuses.",
    image: "/images/blog/Démoussage-de-toiture/Hero Démoussage de toiture.png",
    badge: "bg-orange-50 text-[#E8650A]",
  },
  {
    href: "/blog/renovation-energetique-plus-value-maison",
    categorie: "Rénovation",
    titre: "Comment la rénovation énergétique valorise votre maison ?",
    description: "Isolation, façade, DPE : comment les travaux de rénovation améliorent votre confort quotidien et augmentent la valeur immobilière de votre bien.",
    image: "/images/blog/valoriser-votre-maison/Hero valoriser votre maison.png",
    badge: "bg-[#E8F0FB] text-[#1E4B8C]",
  },
  {
    href: "/blog/comment-savoir-si-votre-facade-a-besoin-dun-ravalement",
    categorie: "Façade",
    titre: "Comment savoir si votre façade a besoin d'un ravalement ?",
    description: "Fissures, mousses, enduit dégradé, humidité : apprenez à reconnaître les signes qui indiquent qu'un ravalement de façade s'impose.",
    image: "/images/blog/façade-a-besoin-d-un-ravalement/Hero façade a besoin d'un ravalement.png",
    badge: "bg-orange-50 text-[#E8650A]",
  },
];
const autresArticles = articles.filter(a => a.href !== currentHref).slice(0, 3);

const signes = [
  {
    titre: "Fissures et microfissures",
    desc: "Même minimes, elles peuvent favoriser la pénétration de l'eau. Les fissures qui s'élargissent ou sont traversantes méritent une attention immédiate.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  },
  {
    titre: "Mousses, algues et traces noires",
    desc: "Ces dépôts retiennent l'humidité et dégradent progressivement les revêtements. Ils sont souvent le signe d'une façade qui a perdu ses propriétés imperméabilisantes.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>`,
  },
  {
    titre: "Enduit qui s'effrite ou se décolle",
    desc: "Un enduit qui farinage, cloque ou se détache traduit un vieillissement avancé du revêtement. Une intervention permet d'éviter des réparations plus lourdes.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
  },
  {
    titre: "Traces d'humidité sur les murs",
    desc: "Des auréoles ou zones sombres sur la façade indiquent une perte d'étanchéité. Sans intervention, l'humidité peut s'infiltrer durablement dans les matériaux.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
  },
  {
    titre: "Façade ternie ou décolorée",
    desc: "Même sans désordre technique, une façade vieillie nuit à l'image du bien. Un ravalement améliore l'esthétique tout en renforçant la protection du bâtiment.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>`,
  },
];
---

<BaseLayout
  title="Comment savoir si votre façade a besoin d'un ravalement ? | Conesa"
  description="Fissures, mousses, humidité, enduit dégradé : découvrez les signes qui indiquent qu'un ravalement de façade devient nécessaire dans le Tarn."
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Comment savoir si votre façade a besoin d'un ravalement ?",
    "description": "Fissures, mousses, humidité, enduit dégradé : découvrez les signes qui indiquent qu'un ravalement de façade devient nécessaire.",
    "author": { "@type": "Organization", "name": "Conesa" },
    "publisher": { "@type": "Organization", "name": "Conesa", "url": "https://conesa-renovation.fr" },
    "url": "https://conesa-renovation.fr/blog/comment-savoir-si-votre-facade-a-besoin-dun-ravalement",
    "mainEntityOfPage": "https://conesa-renovation.fr/blog/comment-savoir-si-votre-facade-a-besoin-dun-ravalement"
  })} />
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": { "@type": "Answer", "text": faq.a }
    }))
  })} />

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="relative bg-[#0A1E3D] pt-36 pb-16 lg:pt-44 lg:pb-20">
    <img
      src={encodeURI("/images/blog/façade-a-besoin-d-un-ravalement/Hero façade a besoin d'un ravalement.png")}
      alt="Ravalement de façade dans le Tarn — Conesa"
      class="absolute inset-0 w-full h-full object-cover object-center"
      fetchpriority="high"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,30,61,0.88) 0%, rgba(30,75,140,0.72) 55%, rgba(10,30,61,0.60) 100%);"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <a href="/blog" class="text-blue-300 hover:text-white transition-colors text-sm">Blog</a>
          <span class="text-blue-400">/</span>
          <span class="text-blue-200 text-sm">Façade</span>
        </div>
        <span class="inline-block bg-orange-50 text-[#E8650A] text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full mb-5">Façade</span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-6" style="font-family:'Montserrat',sans-serif;">
          Comment savoir si votre façade a besoin d'un ravalement ?
        </h1>
        <p class="text-blue-100 text-lg leading-relaxed max-w-2xl">
          Exposée aux intempéries et aux variations climatiques, votre façade se dégrade naturellement avec le temps. Certains signes indiquent qu'il est temps d'agir — avant que les dégâts ne s'aggravent.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       IMAGE + RÔLE DE LA FAÇADE
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div class="rounded-2xl overflow-hidden shadow-xl bg-gray-100 order-2 lg:order-1" style="aspect-ratio:4/3;">
          <img
            src={encodeURI("/images/blog/façade-a-besoin-d-un-ravalement/Ravalement de façade.png")}
            alt="Ravalement de façade dans le Tarn — Conesa"
            class="w-full h-full object-cover"
            fetchpriority="high"
            onerror="this.parentElement.style.background='#E8F0FB'"
          />
        </div>

        <div class="order-1 lg:order-2">
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Le rôle de votre façade</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 mb-5 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Bien plus qu'un simple revêtement esthétique
          </h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            La façade est la première protection de votre habitation contre les agressions extérieures. Au-delà de l'esthétique, elle joue un rôle essentiel dans la durabilité du bâtiment et sa valeur immobilière.
          </p>
          <div class="space-y-3">
            {[
              "Protection contre les infiltrations d'eau et l'humidité",
              "Participation à l'isolation thermique du logement",
              "Préservation de la structure du bâtiment dans le temps",
              "Valorisation du bien immobilier sur le marché",
            ].map(point => (
              <div class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-[#E8650A] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-gray-700 text-sm">{point}</span>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       5 SIGNES D'ALERTE
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Les signaux à surveiller</span>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          5 signes qui indiquent qu'un ravalement s'impose
        </h2>
        <p class="text-gray-600 mt-4 leading-relaxed">
          Certaines dégradations sont purement esthétiques, d'autres peuvent avoir des conséquences structurelles. Voici comment les identifier.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {signes.map((s, i) => (
          <div class={`bg-white rounded-2xl p-7 flex flex-col gap-4 ${i === 4 ? 'lg:col-start-2' : ''}`}>
            <div class="w-12 h-12 bg-[#E8F0FB] rounded-xl flex items-center justify-center text-[#1E4B8C] shrink-0">
              <Fragment set:html={s.icon} />
            </div>
            <div>
              <h3 class="font-bold text-[#1E4B8C] mb-2" style="font-family:'Montserrat',sans-serif;">{s.titre}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       RISQUES D'ATTENDRE + SOLUTIONS
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-start">

        <!-- Risques -->
        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Pourquoi ne pas attendre</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 mb-6 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Les risques d'une façade laissée sans entretien
          </h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            Reporter un ravalement peut transformer un entretien courant en travaux lourds et coûteux. Les dégradations s'aggravent progressivement et peuvent finir par toucher la structure même du bâtiment.
          </p>
          <div class="space-y-4">
            {[
              { titre: "Aggravation des fissures", desc: "Les fissures non traitées s'élargissent avec les cycles gel/dégel et les mouvements du bâtiment." },
              { titre: "Infiltrations d'eau", desc: "Une façade dégradée perd son étanchéité. L'eau pénètre dans les murs et peut causer des dégâts intérieurs." },
              { titre: "Coût des réparations en hausse", desc: "Un simple entretien préventif coûte bien moins cher qu'une rénovation structurelle d'urgence." },
              { titre: "Perte de valeur du bien", desc: "Une façade en mauvais état impacte directement l'image et la valeur immobilière de votre logement." },
            ].map(item => (
              <div class="flex gap-4 p-4 rounded-xl border border-red-100 bg-red-50">
                <svg class="w-5 h-5 text-red-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                <div>
                  <p class="font-semibold text-gray-800 text-sm mb-0.5">{item.titre}</p>
                  <p class="text-gray-600 text-sm">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Solutions -->
        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Nos interventions</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 mb-6 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Les solutions adaptées à chaque situation
          </h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            Selon l'état de votre façade, plusieurs types d'interventions sont possibles — du simple entretien préventif à la rénovation complète.
          </p>
          <div class="space-y-4">
            {[
              { titre: "Nettoyage et traitement préventif", desc: "Pour une façade encore saine : élimination des mousses, algues et salissures, puis application d'un hydrofuge." },
              { titre: "Réparation des fissures et enduits", desc: "Traitement ciblé des zones dégradées, ragréage et application d'un nouvel enduit de finition." },
              { titre: "Ravalement complet", desc: "Décapage, traitement du support, application d'un enduit neuf et finition : la façade retrouve son étanchéité et son esthétique." },
              { titre: "Isolation thermique par l'extérieur", desc: "Combiner la rénovation de façade avec une isolation extérieure pour améliorer le confort et les performances énergétiques." },
            ].map(item => (
              <div class="flex gap-4 p-4 rounded-xl border border-gray-100 bg-[#F0F5FC]">
                <div class="w-5 h-5 rounded-full bg-[#E8650A] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-[#1E4B8C] text-sm mb-0.5">{item.titre}</p>
                  <p class="text-gray-600 text-sm">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       ANCRAGE LOCAL + CTA
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Intervention locale</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 mb-5 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Ravalement de façade dans le Tarn : faites appel à un professionnel
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Les conditions climatiques du Tarn — humidité, ensoleillement, variations de température — ont une influence directe sur l'état des façades. Une évaluation par un professionnel permet d'identifier précisément les travaux nécessaires.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            Nos équipes interviennent à <strong class="text-[#1E4B8C]">Albi, Gaillac, Castres, Graulhet</strong> et dans l'ensemble du département pour diagnostiquer et rénover les façades de vos habitations.
          </p>
          <div class="flex flex-wrap gap-2">
            {["Albi", "Gaillac", "Castres", "Graulhet", "Tarn (81)"].map(v => (
              <span class="bg-white text-[#1E4B8C] border border-[#1E4B8C]/20 text-sm font-medium px-3 py-1.5 rounded-lg">{v}</span>
            ))}
          </div>
        </div>

        <div class="bg-[#1E4B8C] rounded-3xl p-10 relative overflow-hidden">
          <div class="absolute inset-0 opacity-[0.05]" style="background-image:repeating-linear-gradient(45deg,#fff 0,#fff 1px,transparent 0,transparent 50%);background-size:30px 30px;"></div>
          <div class="relative">
            <p class="text-blue-200 text-sm font-semibold uppercase tracking-widest mb-3">Diagnostic gratuit</p>
            <h3 class="text-2xl font-extrabold text-white mb-4 leading-tight" style="font-family:'Montserrat',sans-serif;">
              Votre façade montre des signes d'usure ?
            </h3>
            <p class="text-blue-100 text-sm leading-relaxed mb-8">
              Nos experts évaluent l'état de votre façade et vous proposent la solution adaptée : entretien préventif, réparation ciblée ou ravalement complet.
            </p>
            <div class="flex flex-col gap-3">
              <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-[#E8650A] hover:bg-orange-700 text-white font-bold px-6 py-3.5 rounded-xl transition-all duration-200 hover:scale-105">
                Demander un devis gratuit
              </a>
              <a href="tel:0563541697" class="inline-flex items-center justify-center gap-2 border border-white/30 text-white hover:bg-white/10 font-medium px-6 py-3.5 rounded-xl transition-colors text-sm">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                05 63 54 16 97
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       FAQ
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Questions fréquentes</span>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Tout savoir sur le ravalement de façade
        </h2>
      </div>

      <div class="border-t border-gray-200">
        {faqs.map(faq => (
          <div class="faq-item border-b border-gray-200">
            <h3 class="m-0 font-normal">
              <button class="faq-trigger w-full flex items-center justify-between gap-6 py-5 px-1 text-left">
                <span class="faq-question font-semibold text-[#1E4B8C] text-base leading-snug" style="font-family:'Montserrat',sans-serif;">
                  {faq.q}
                </span>
                <svg class="faq-icon shrink-0 w-5 h-5 text-gray-400" style="transition: transform 0.45s ease, color 0.3s ease;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
            </h3>
            <div class="faq-body overflow-hidden" style="max-height:0; transition: max-height 0.45s ease;">
              <p class="pb-6 pt-1 px-1 text-gray-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
      const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger')!;
      const body    = item.querySelector<HTMLElement>('.faq-body')!;
      const icon    = item.querySelector<SVGElement>('.faq-icon')!;
      trigger.addEventListener('click', () => {
        const isOpen = item.dataset.open === 'true';
        document.querySelectorAll<HTMLElement>('.faq-item').forEach(other => {
          other.dataset.open = 'false';
          (other.querySelector<HTMLElement>('.faq-body')!).style.maxHeight = '0';
          const ic = other.querySelector<SVGElement>('.faq-icon')!;
          ic.style.transform = '';
          ic.style.color = '';
        });
        if (!isOpen) {
          item.dataset.open = 'true';
          body.style.maxHeight = body.scrollHeight + 'px';
          icon.style.transform = 'rotate(180deg)';
          icon.style.color = '#E8650A';
        }
      });
    });
  </script>

  <!-- ══════════════════════════════════════
       AUTRES ARTICLES
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-16 bg-[#F0F5FC]">
