---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqs = [
  {
    q: "Une rénovation énergétique augmente-t-elle réellement la valeur d'une maison ?",
    a: "Oui. Les études immobilières montrent qu'une maison mieux classée au DPE se vend généralement dans de meilleures conditions. L'amélioration du confort, la réduction des charges et l'attractivité visuelle contribuent à valoriser le bien sur le marché.",
  },
  {
    q: "Quels travaux apportent la meilleure plus-value immobilière ?",
    a: "L'isolation thermique extérieure, la rénovation de façade et l'amélioration de la toiture figurent parmi les travaux les plus valorisants. Ils améliorent simultanément le DPE, le confort et l'aspect esthétique du bien.",
  },
  {
    q: "L'isolation thermique extérieure améliore-t-elle le DPE ?",
    a: "Oui, significativement. En réduisant les déperditions de chaleur par les murs, l'ITE permet souvent de passer d'une classe énergivore à une classe plus performante, ce qui améliore directement l'attractivité du bien.",
  },
  {
    q: "Les acheteurs regardent-ils le diagnostic de performance énergétique ?",
    a: "De plus en plus, oui. Face à la hausse du coût de l'énergie, le DPE est devenu un critère de décision important. Les logements classés F ou G sont considérés comme des « passoires thermiques » et subissent une décote sur le marché.",
  },
  {
    q: "Quelles aides existent pour financer une rénovation énergétique ?",
    a: "MaPrimeRénov', les CEE (Certificats d'Économies d'Énergie), l'Éco-PTZ et la TVA à 5,5 % sont les principaux dispositifs. Faire appel à une entreprise certifiée RGE comme Conesa est obligatoire pour y accéder.",
  },
  {
    q: "Une façade rénovée augmente-t-elle la valeur d'un bien ?",
    a: "Oui. La façade est la première impression d'une maison. Une façade propre et rénovée améliore l'image du bien, rassure les acheteurs sur son état général et contribue à sa valorisation globale.",
  },
  {
    q: "Combien de temps faut-il pour rentabiliser des travaux d'isolation ?",
    a: "Le retour sur investissement dépend des travaux réalisés, des aides obtenues et des économies générées. L'ITE permet généralement de réduire la facture de chauffage de 20 à 30 %, ce qui accélère le retour sur investissement sur le long terme.",
  },
  {
    q: "Comment obtenir un devis pour un projet de rénovation énergétique dans le Tarn ?",
    a: "Remplissez notre formulaire de contact ou appelez-nous directement. Nous vous recontactons sous 24h pour organiser une visite et établir un devis gratuit sur mesure adapté à votre habitation.",
  },
];

const leviers = [
  {
    titre: "Isolation thermique extérieure",
    desc: "Supprime les ponts thermiques, réduit la facture énergétique de 20 à 30 % et améliore le DPE. La solution la plus performante pour valoriser une maison.",
    badge: "Impact fort",
    badgeColor: "bg-[#E8650A] text-white",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/></svg>`,
  },
  {
    titre: "Rénovation de façade",
    desc: "Première impression décisive pour les acheteurs. Une façade propre et rénovée valorise l'image du bien et rassure sur son état d'entretien.",
    badge: "Impact fort",
    badgeColor: "bg-[#E8650A] text-white",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
  },
  {
    titre: "Entretien et réfection de toiture",
    desc: "La toiture représente 25 à 30 % des déperditions thermiques. Son entretien préserve la valeur du bien et rassure sur l'étanchéité du logement.",
    badge: "Impact modéré",
    badgeColor: "bg-[#E8F0FB] text-[#1E4B8C]",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/></svg>`,
  },
  {
    titre: "Amélioration du DPE",
    desc: "Passer d'une classe énergivore à une classe performante peut ouvrir à la location et éviter une décote lors d'une vente. Un critère de plus en plus surveillé.",
    badge: "Impact fort",
    badgeColor: "bg-[#E8650A] text-white",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  },
];

const travaux = [
  { travaux: "Isolation thermique extérieure", dpe: "A/B",  economies: "20–30 %", roi: "Excellent" },
  { travaux: "Ravalement de façade",           dpe: "+",    economies: "—",       roi: "Fort" },
  { travaux: "Isolation de toiture",           dpe: "A/B",  economies: "15–25 %", roi: "Très bon" },
  { travaux: "Démoussage & entretien toiture", dpe: "—",    economies: "—",       roi: "Préventif" },
  { travaux: "Remplacement menuiseries",       dpe: "+",    economies: "10–15 %", roi: "Bon" },
];

const currentHref = "/blog/renovation-energetique-plus-value-maison";
const articles = [
  {
    href: "/blog/isolation-interieure-ou-exterieure",
    categorie: "Isolation",
    titre: "Isolation intérieure ou extérieure : quelle solution choisir ?",
    description: "Comparez l'isolation thermique par l'intérieur et par l'extérieur : avantages, performances, coûts et aides disponibles pour bien choisir.",
    image: "/images/blog/Isolation-intérieure-ou-extérieure/hero isolation-interieure-exterieure.png",
    badge: "bg-[#E8F0FB] text-[#1E4B8C]",
  },
  {
    href: "/blog/demoussage-toiture-pourquoi-ne-pas-attendre",
    categorie: "Toiture",
    titre: "Démoussage de toiture : pourquoi ne faut-il pas attendre ?",
    description: "Mousses, lichens, infiltrations… Découvrez pourquoi un entretien régulier de votre toiture évite des réparations bien plus coûteuses.",
    image: "/images/blog/Démoussage-de-toiture/Hero Démoussage de toiture.png",
    badge: "bg-orange-50 text-[#E8650A]",
  },
  {
    href: "/blog/renovation-energetique-plus-value-maison",
    categorie: "Rénovation",
    titre: "Comment la rénovation énergétique valorise votre maison ?",
    description: "Isolation, façade, DPE : comment les travaux de rénovation améliorent votre confort quotidien et augmentent la valeur immobilière de votre bien.",
    image: "/images/blog/valoriser-votre-maison/Hero valoriser votre maison.png",
    badge: "bg-[#E8F0FB] text-[#1E4B8C]",
  },
  {
    href: "/blog/comment-savoir-si-votre-facade-a-besoin-dun-ravalement",
    categorie: "Façade",
    titre: "Comment savoir si votre façade a besoin d'un ravalement ?",
    description: "Fissures, mousses, enduit dégradé, humidité : apprenez à reconnaître les signes qui indiquent qu'un ravalement de façade s'impose.",
    image: "/images/blog/façade-a-besoin-d-un-ravalement/Hero façade a besoin d'un ravalement.png",
    badge: "bg-orange-50 text-[#E8650A]",
  },
];
const autresArticles = articles.filter(a => a.href !== currentHref).slice(0, 3);
---

<BaseLayout
  title="Comment la rénovation énergétique valorise votre maison ? | Conesa"
  description="Découvrez comment l'isolation, la rénovation de façade et les travaux énergétiques améliorent le confort de votre logement et augmentent sa valeur immobilière dans le Tarn."
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Comment la rénovation énergétique valorise votre maison ?",
    "description": "Découvrez comment l'isolation, la rénovation de façade et les travaux énergétiques améliorent le confort de votre logement et augmentent sa valeur immobilière.",
    "author": { "@type": "Organization", "name": "Conesa" },
    "publisher": { "@type": "Organization", "name": "Conesa", "url": "https://conesa-renovation.fr" },
    "url": "https://conesa-renovation.fr/blog/renovation-energetique-plus-value-maison",
    "mainEntityOfPage": "https://conesa-renovation.fr/blog/renovation-energetique-plus-value-maison"
  })} />
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": { "@type": "Answer", "text": faq.a }
    }))
  })} />

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="relative bg-[#0A1E3D] pt-36 pb-16 lg:pt-44 lg:pb-20">
    <img
      src={encodeURI("/images/blog/valoriser-votre-maison/Hero valoriser votre maison.png")}
      alt="Rénovation énergétique et valorisation immobilière — Conesa Tarn"
      class="absolute inset-0 w-full h-full object-cover object-center"
      fetchpriority="high"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,30,61,0.88) 0%, rgba(30,75,140,0.72) 55%, rgba(10,30,61,0.60) 100%);"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <a href="/blog" class="text-blue-300 hover:text-white transition-colors text-sm">Blog</a>
          <span class="text-blue-400">/</span>
          <span class="text-blue-200 text-sm">Rénovation</span>
        </div>
        <span class="inline-block bg-[#E8F0FB] text-[#1E4B8C] text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full mb-5">Rénovation</span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-6" style="font-family:'Montserrat',sans-serif;">
          Comment la rénovation énergétique valorise votre maison ?
        </h1>
        <p class="text-blue-100 text-lg leading-relaxed max-w-2xl">
          Isolation, façade, DPE : la rénovation énergétique va bien au-delà des économies d'énergie. Découvrez comment ces travaux améliorent votre confort quotidien et renforcent la valeur de votre patrimoine.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       IMAGE + INTRO
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div class="rounded-2xl overflow-hidden shadow-xl bg-gray-100 order-2 lg:order-1" style="aspect-ratio:4/3;">
          <img
            src={encodeURI("/images/blog/valoriser-votre-maison/valoriser-votre-maison.png")}
            alt="Rénovation énergétique d'une maison dans le Tarn — Conesa"
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
            onerror="this.parentElement.style.background='#E8F0FB'"
          />
        </div>

        <div class="order-1 lg:order-2">
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Un investissement rentable</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 mb-5 leading-tight" style="font-family:'Montserrat',sans-serif;">
            La performance énergétique, un critère clé sur le marché immobilier
          </h2>
          <p class="text-gray-600 leading-relaxed mb-5">
            Face à la hausse du coût de l'énergie, les acheteurs sont de plus en plus attentifs au Diagnostic de Performance Énergétique (DPE). Un logement bien classé se vend plus facilement et dans de meilleures conditions qu'une « passoire thermique ».
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            La rénovation énergétique est donc à la fois un levier de confort au quotidien et un investissement patrimonial. Isolation, façade, toiture : chaque chantier contribue à améliorer la valeur globale de votre bien.
          </p>
          <div class="grid grid-cols-2 gap-4">
            {[
              { val: "20–30 %", label: "d'économies chauffage avec l'ITE" },
              { val: "DPE +",   label: "amélioration de la classe énergie" },
              { val: "55+",     label: "ans d'expérience dans le Tarn" },
              { val: "RGE",     label: "certifié pour accéder aux aides" },
            ].map(s => (
              <div class="bg-[#F0F5FC] rounded-xl p-4">
                <p class="text-2xl font-extrabold text-[#E8650A]" style="font-family:'Montserrat',sans-serif;">{s.val}</p>
                <p class="text-gray-600 text-xs mt-1 leading-snug">{s.label}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       4 LEVIERS DE VALORISATION
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Les travaux qui valorisent</span>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          4 leviers pour améliorer la valeur de votre maison
        </h2>
        <p class="text-gray-600 mt-4 leading-relaxed">
          Tous les travaux ne se valent pas en termes d'impact sur la valeur immobilière. Voici les interventions qui font réellement la différence.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {leviers.map(levier => (
          <div class="bg-white rounded-2xl p-7 flex flex-col gap-4">
            <div class="flex items-start justify-between">
              <div class="w-12 h-12 bg-[#E8F0FB] rounded-xl flex items-center justify-center text-[#1E4B8C] shrink-0">
                <Fragment set:html={levier.icon} />
              </div>
              <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${levier.badgeColor}`}>{levier.badge}</span>
            </div>
            <h3 class="font-bold text-[#1E4B8C] leading-snug" style="font-family:'Montserrat',sans-serif;">{levier.titre}</h3>
            <p class="text-gray-600 text-sm leading-relaxed flex-1">{levier.desc}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       TABLEAU ROI + AIDES
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-start">

        <!-- Tableau ROI -->
        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Prioriser les bons travaux</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 mb-8 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Quel retour sur investissement selon les travaux ?
          </h2>
          <div class="rounded-2xl border border-gray-100 overflow-hidden shadow-sm">
            <div class="grid grid-cols-3 bg-[#1E4B8C] text-white text-xs font-semibold px-5 py-3.5">
              <span>Travaux</span>
              <span class="text-center">Impact DPE</span>
              <span class="text-center">Retour invest.</span>
            </div>
            {travaux.map((row, i) => (
              <div class={`grid grid-cols-3 px-5 py-3.5 text-sm gap-2 items-center ${i % 2 === 0 ? 'bg-white' : 'bg-[#F8F9FA]'}`}>
                <span class="font-medium text-[#1E4B8C] text-xs leading-snug">{row.travaux}</span>
                <span class="text-center text-xs text-gray-500">{row.dpe}</span>
                <span class={`text-center text-xs font-semibold ${row.roi === 'Excellent' || row.roi === 'Fort' ? 'text-[#E8650A]' : row.roi === 'Très bon' ? 'text-[#1E4B8C]' : 'text-gray-500'}`}>{row.roi}</span>
              </div>
            ))}
          </div>
          <p class="text-xs text-gray-400 mt-4">* Estimations indicatives. Les résultats varient selon le logement et les conditions d'exécution.</p>
        </div>

        <!-- Aides -->
        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Réduire le coût du projet</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 mb-8 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Les aides pour financer votre rénovation
          </h2>
          <div class="space-y-4">
            {[
              { aide: "MaPrimeRénov'", couleur: "bg-[#E8F0FB] text-[#1E4B8C]", desc: "Subvention de l'État selon les revenus et le type de travaux. Peut couvrir une part significative du montant des travaux éligibles." },
              { aide: "CEE", couleur: "bg-orange-50 text-[#E8650A]", desc: "Certificats d'Économies d'Énergie versés par les fournisseurs d'énergie pour les travaux d'isolation et de rénovation." },
              { aide: "Éco-PTZ", couleur: "bg-[#E8F0FB] text-[#1E4B8C]", desc: "Prêt à taux zéro pour financer des travaux de rénovation énergétique sans avancer les fonds." },
              { aide: "TVA à 5,5 %", couleur: "bg-orange-50 text-[#E8650A]", desc: "Taux de TVA réduit applicable sur les travaux de rénovation énergétique réalisés par une entreprise RGE." },
            ].map(item => (
              <div class="flex gap-4 p-5 rounded-xl border border-gray-100">
                <span class={`text-xs font-bold px-3 py-1.5 rounded-lg shrink-0 h-fit ${item.couleur}`}>{item.aide}</span>
                <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
          <div class="mt-6 p-4 rounded-xl bg-[#F0F5FC] border border-[#1E4B8C]/10">
            <p class="text-sm text-[#1E4B8C] font-medium">
              <span class="font-bold">Certifié RGE</span>, Conesa vous permet d'accéder à l'ensemble de ces dispositifs et vous accompagne dans les démarches de financement.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       LOCAL TARN + CTA
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Intervention locale</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 mb-5 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Valoriser votre patrimoine dans le Tarn
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Dans le Tarn, de nombreuses habitations — maisons de village, maisons de maître, pavillons — présentent un fort potentiel d'amélioration énergétique. Le climat local, avec ses hivers froids et ses étés chauds, rend l'isolation particulièrement pertinente.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            Nos équipes interviennent depuis plus de 55 ans à <strong class="text-[#1E4B8C]">Albi, Gaillac, Castres, Graulhet</strong> et dans l'ensemble du département pour accompagner les propriétaires dans leurs projets de rénovation énergétique.
          </p>
          <div class="flex flex-wrap gap-2">
            {["Albi", "Gaillac", "Castres", "Graulhet", "Tarn (81)"].map(v => (
              <a href={`/villes/${v.toLowerCase().normalize("NFD").replace(/[̀-ͯ]/g, "").replace(/\s.*/, "")}`} class="bg-white text-[#1E4B8C] border border-[#1E4B8C]/20 hover:bg-[#1E4B8C] hover:text-white text-sm font-medium px-3 py-1.5 rounded-lg transition-all duration-150">{v}</a>
            ))}
          </div>
        </div>

        <div class="bg-[#1E4B8C] rounded-3xl p-10 relative overflow-hidden">
          <div class="absolute inset-0 opacity-[0.05]" style="background-image:repeating-linear-gradient(45deg,#fff 0,#fff 1px,transparent 0,transparent 50%);background-size:30px 30px;"></div>
          <div class="absolute bottom-0 right-0 w-40 h-40 bg-[#E8650A] opacity-10 rounded-tl-full"></div>
          <div class="relative">
            <span class="inline-block bg-[#E8650A]/20 text-[#E8650A] border border-[#E8650A]/30 rounded-full px-3 py-1 text-xs font-semibold mb-4">
              Devis gratuit & sans engagement
            </span>
            <h3 class="text-2xl font-extrabold text-white mb-4 leading-tight" style="font-family:'Montserrat',sans-serif;">
              Vous souhaitez améliorer les performances de votre maison ?
            </h3>
            <p class="text-blue-100 text-sm leading-relaxed mb-8">
              Isolation thermique extérieure, rénovation de façade ou entretien de toiture : nos experts étudient votre projet et vous proposent la solution adaptée à votre habitation et à votre budget.
            </p>
            <div class="flex flex-col gap-3">
              <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-[#E8650A] hover:bg-orange-700 text-white font-bold px-6 py-3.5 rounded-xl transition-all duration-200 hover:scale-105">
                Demander un devis gratuit
              </a>
              <a href="tel:0563541697" class="inline-flex items-center justify-center gap-2 border border-white/30 text-white hover:bg-white/10 font-medium px-6 py-3.5 rounded-xl transition-colors text-sm">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                05 63 54 16 97
