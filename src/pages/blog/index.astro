---
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = [
  {
    href: "/blog/isolation-interieure-ou-exterieure",
    categorie: "Isolation",
    titre: "Isolation intérieure ou extérieure : quelle solution choisir ?",
    description: "Comparez l'isolation thermique par l'intérieur et par l'extérieur : avantages, performances, coûts et aides disponibles pour bien choisir.",
    image: "/images/blog/Isolation-intérieure-ou-extérieure/hero isolation-interieure-exterieure.png",
    badge: "bg-[#E8F0FB] text-[#1E4B8C]",
  },
  {
    href: "/blog/demoussage-toiture-pourquoi-ne-pas-attendre",
    categorie: "Toiture",
    titre: "Démoussage de toiture : pourquoi ne faut-il pas attendre ?",
    description: "Mousses, lichens, infiltrations… Découvrez pourquoi un entretien régulier de votre toiture évite des réparations bien plus coûteuses.",
    image: "/images/blog/Démoussage-de-toiture/Hero Démoussage de toiture.png",
    badge: "bg-orange-50 text-[#E8650A]",
  },
  {
    href: "/blog/renovation-energetique-plus-value-maison",
    categorie: "Rénovation",
    titre: "Comment la rénovation énergétique valorise votre maison ?",
    description: "Isolation, façade, DPE : comment les travaux de rénovation améliorent votre confort quotidien et augmentent la valeur immobilière de votre bien.",
    image: "/images/blog/valoriser-votre-maison/Hero valoriser votre maison.png",
    badge: "bg-[#E8F0FB] text-[#1E4B8C]",
  },
  {
    href: "/blog/comment-savoir-si-votre-facade-a-besoin-dun-ravalement",
    categorie: "Façade",
    titre: "Comment savoir si votre façade a besoin d'un ravalement ?",
    description: "Fissures, mousses, enduit dégradé, humidité : apprenez à reconnaître les signes qui indiquent qu'un ravalement de façade s'impose.",
    image: "/images/blog/façade-a-besoin-d-un-ravalement/Hero façade a besoin d'un ravalement.png",
    badge: "bg-orange-50 text-[#E8650A]",
  },
];

const faqs = [
  {
    q: "Quels travaux permettent de réduire les consommations énergétiques ?",
    a: "L'isolation thermique des murs, de la toiture et le remplacement des équipements énergivores figurent parmi les travaux les plus efficaces pour réduire les consommations d'énergie.",
  },
  {
    q: "L'isolation thermique extérieure est-elle adaptée aux maisons anciennes ?",
    a: "Oui, l'ITE constitue souvent une solution performante pour améliorer le confort et limiter les déperditions énergétiques des maisons anciennes.",
  },
  {
    q: "Quand faut-il envisager un ravalement de façade ?",
    a: "Des fissures, des traces d'humidité, des mousses ou un enduit dégradé peuvent indiquer qu'un ravalement devient nécessaire. Un diagnostic professionnel permet d'évaluer précisément l'état de la façade.",
  },
  {
    q: "À quelle fréquence faut-il entretenir sa toiture ?",
    a: "Une inspection régulière et un entretien préventif permettent de préserver durablement la couverture et d'éviter les réparations importantes. La fréquence dépend de l'environnement et de l'exposition de la toiture.",
  },
  {
    q: "Comment obtenir un devis pour des travaux de rénovation dans le Tarn ?",
    a: "Vous pouvez contacter directement Conesa via le formulaire de contact présent sur le site. Nous vous recontactons sous 24h pour étudier votre projet.",
  },
];
---

<BaseLayout
  title="Conseils rénovation, isolation et façade dans le Tarn | Blog Conesa"
  description="Retrouvez nos conseils d'experts sur l'isolation thermique, la rénovation de façade, l'entretien de toiture et la rénovation énergétique dans le Tarn."
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": { "@type": "Answer", "text": faq.a }
    }))
  })} />

  <!-- ══════════════════════════════════════
       HERO BLOG
  ══════════════════════════════════════ -->
  <section class="bg-[#1E4B8C] pt-36 pb-16 lg:pt-44 lg:pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <span class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 text-sm font-medium text-white mb-6">
          <span class="w-2 h-2 bg-[#E8650A] rounded-full"></span>
          Entreprise familiale dans le Tarn depuis 1969
        </span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-6" style="font-family:'Montserrat',sans-serif;">
          Conseils et actualités<br><span class="text-[#E8650A]">rénovation dans le Tarn</span>
        </h1>
        <p class="text-blue-100 text-lg leading-relaxed">
          Bienvenue sur le blog Conesa — votre espace dédié aux conseils en rénovation, isolation thermique extérieure, entretien de façade, toiture et amélioration énergétique de l'habitat dans le Tarn.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       GRILLE ARTICLES
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="mb-12">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Nos articles</span>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Tous nos conseils pour votre habitat
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {articles.map((article) => (
          <a href={article.href} class="group bg-white rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col">
            <div class="h-48 bg-gray-100 overflow-hidden">
              <img
                src={encodeURI(article.image)}
                alt={article.titre}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
                onerror="this.parentElement.style.background='#E8F0FB'"
              />
            </div>
            <div class="p-6 flex flex-col flex-1">
              <span class={`inline-block self-start text-xs font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full mb-4 ${article.badge}`}>
                {article.categorie}
              </span>
              <h3 class="font-bold text-[#1E4B8C] text-base leading-snug mb-3 group-hover:text-[#E8650A] transition-colors" style="font-family:'Montserrat',sans-serif;">
                {article.titre}
              </h3>
              <p class="text-gray-600 text-sm leading-relaxed flex-1">{article.description}</p>
              <div class="flex items-center gap-2 text-[#E8650A] font-semibold text-sm mt-5 group-hover:gap-3 transition-all duration-150">
                Lire l'article
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       TEXTE SEO
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">

        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Notre expertise</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 mb-6 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Nos conseils pour réussir vos travaux de rénovation
          </h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>Entreprendre des travaux de rénovation représente un investissement important. Qu'il s'agisse d'améliorer le confort thermique de votre logement, de réduire vos consommations énergétiques ou de valoriser votre patrimoine immobilier, chaque projet mérite une réflexion approfondie.</p>
            <p>L'isolation thermique extérieure, la rénovation de façade ou encore l'entretien régulier de la toiture permettent d'améliorer durablement les performances d'une habitation tout en préservant son esthétique et sa valeur.</p>
            <p>Grâce à nos articles, découvrez les avantages des différentes solutions de rénovation, les erreurs à éviter, les aides financières existantes et les critères à prendre en compte avant de lancer vos travaux.</p>
          </div>
        </div>

        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Pourquoi nous ?</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 mb-6 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Des conseils issus de 55 ans d'expérience terrain
          </h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>Chaque habitation possède ses propres caractéristiques. L'âge du bâtiment, son exposition, les matériaux utilisés ou encore son niveau d'isolation influencent directement les solutions à privilégier.</p>
            <p>Nos équipes interviennent depuis plusieurs décennies sur des projets d'isolation thermique extérieure, de rénovation de façade et d'amélioration énergétique dans tout le département du Tarn.</p>
            <p>Les informations partagées dans ce blog s'appuient sur cette expérience terrain afin de vous proposer des contenus utiles, concrets et régulièrement mis à jour.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       FAQ
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-[#F0F5FC]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Questions fréquentes</span>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Tout ce que vous devez savoir
        </h2>
      </div>

      <div class="border-t border-gray-200">
        {faqs.map(faq => (
          <div class="faq-item border-b border-gray-200">
            <h3 class="m-0 font-normal">
              <button class="faq-trigger w-full flex items-center justify-between gap-6 py-5 px-1 text-left rounded-sm">
                <span class="faq-question font-semibold text-[#1E4B8C] text-base leading-snug" style="font-family:'Montserrat',sans-serif;">
                  {faq.q}
                </span>
                <svg class="faq-icon shrink-0 w-5 h-5 text-gray-400" style="transition: transform 0.45s ease, color 0.3s ease;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
            </h3>
            <div class="faq-body overflow-hidden" style="max-height:0; transition: max-height 0.45s ease;">
              <p class="pb-6 pt-1 px-1 text-gray-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
      const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger')!;
      const body    = item.querySelector<HTMLElement>('.faq-body')!;
      const icon    = item.querySelector<SVGElement>('.faq-icon')!;

      trigger.addEventListener('click', () => {
        const isOpen = item.dataset.open === 'true';
        document.querySelectorAll<HTMLElement>('.faq-item').forEach(other => {
          other.dataset.open = 'false';
          const b  = other.querySelector<HTMLElement>('.faq-body')!;
          const ic = other.querySelector<SVGElement>('.faq-icon')!;
          b.style.maxHeight = '0';
          ic.style.transform = '';
          ic.style.color = '';
        });
        if (!isOpen) {
          item.dataset.open = 'true';
          body.style.maxHeight = body.scrollHeight + 'px';
          icon.style.transform = 'rotate(180deg)';
          icon.style.color = '#E8650A';
        }
      });
    });
  </script>

  <!-- ══════════════════════════════════════
       CTA FINAL
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="bg-[#1E4B8C] rounded-3xl p-12 lg:p-16 relative overflow-hidden">
        <div class="absolute inset-0 opacity-[0.05]" style="background-image:repeating-linear-gradient(45deg,#fff 0,#fff 1px,transparent 0,transparent 50%);background-size:30px 30px;"></div>
        <div class="absolute bottom-0 right-0 w-48 h-48 bg-[#E8650A] opacity-10 rounded-tl-full"></div>
        <div class="relative">
          <span class="inline-block bg-[#E8650A]/20 text-[#E8650A] border border-[#E8650A]/30 rounded-full px-4 py-1.5 text-sm font-semibold mb-6">
            Devis gratuit & sans engagement
          </span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-6 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Vous avez un projet de rénovation<br>dans le Tarn ?
          </h2>
          <p class="text-blue-200 text-lg leading-relaxed mb-10 max-w-xl mx-auto">
            Nos équipes sont à votre disposition pour étudier votre projet et vous proposer des solutions adaptées à votre habitation.
          </p>
          <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-[#E8650A] hover:bg-orange-700 text-white font-bold px-10 py-4 rounded-xl transition-all duration-200 hover:scale-105 shadow-lg">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              Demander un devis gratuit
            </a>
            <a href="tel:0563541697" class="inline-flex items-center justify-center gap-2 border-2 border-white/30 text-white hover:bg-white/10 font-semibold px-10 py-4 rounded-xl transition-all duration-200">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Nous appeler
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
