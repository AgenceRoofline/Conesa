---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqs = [
  {
    q: "Quelle est la différence entre isolation intérieure et extérieure ?",
    a: "L'isolation intérieure (ITI) consiste à poser l'isolant sur la face interne des murs, tandis que l'isolation extérieure (ITE) enveloppe le bâtiment d'une couche isolante continue à l'extérieur. L'ITE supprime davantage de ponts thermiques et ne réduit pas la surface habitable.",
  },
  {
    q: "L'isolation extérieure est-elle plus performante ?",
    a: "Dans la plupart des cas, oui. L'ITE offre de meilleures performances grâce à la suppression quasi totale des ponts thermiques et au maintien de l'inertie thermique des murs. Elle améliore également le confort en été comme en hiver.",
  },
  {
    q: "Perd-on de la surface habitable avec l'isolation intérieure ?",
    a: "Oui. L'isolation intérieure réduit légèrement la surface de chaque pièce, de quelques centimètres selon l'épaisseur de l'isolant posé. L'isolation extérieure ne présente pas cet inconvénient.",
  },
  {
    q: "Quelles aides existent pour financer les travaux d'isolation ?",
    a: "Plusieurs aides sont disponibles : MaPrimeRénov', les CEE (Certificats d'Économies d'Énergie), l'Éco-PTZ et la TVA à taux réduit (5,5 %). Étant certifié RGE, Conesa vous permet d'accéder à ces dispositifs.",
  },
  {
    q: "Combien coûte une isolation thermique extérieure ?",
    a: "Le coût varie selon la surface, le type d'isolant et les finitions choisies. Comptez généralement entre 100 et 200 €/m² posé, aides déduites. Contactez-nous pour un devis gratuit et personnalisé.",
  },
  {
    q: "Peut-on rénover sa façade en même temps que l'isolation extérieure ?",
    a: "Oui, c'est même l'un des grands avantages de l'ITE. Les travaux d'isolation et de rénovation de façade sont réalisés simultanément, ce qui permet de combiner performance énergétique et amélioration esthétique en une seule intervention.",
  },
  {
    q: "Quelle solution choisir pour une maison ancienne ?",
    a: "L'isolation thermique extérieure est souvent la solution la plus adaptée pour les maisons anciennes, car elle permet de traiter l'ensemble de l'enveloppe du bâtiment sans travaux intérieurs invasifs. Un diagnostic professionnel est recommandé pour évaluer précisément les solutions les plus adaptées.",
  },
  {
    q: "Comment obtenir un devis pour des travaux d'isolation dans le Tarn ?",
    a: "Remplissez notre formulaire de contact ou appelez-nous directement. Nous vous recontactons sous 24h pour organiser une visite et établir un devis gratuit sur mesure.",
  },
];

const comparatif = [
  { critere: "Performances thermiques",  iti: "Bonnes",              ite: "Excellentes",      avantage: "ite" },
  { critere: "Ponts thermiques",         iti: "Partiellement traités", ite: "Quasi éliminés",   avantage: "ite" },
  { critere: "Surface habitable",        iti: "Légèrement réduite",  ite: "Inchangée",         avantage: "ite" },
  { critere: "Aspect extérieur",         iti: "Conservé",            ite: "Rénové",            avantage: "both" },
  { critere: "Coût initial",             iti: "Plus accessible",     ite: "Plus élevé",        avantage: "iti" },
  { critere: "Travaux intérieurs",       iti: "Oui (invasifs)",      ite: "Non",               avantage: "ite" },
  { critere: "Valorisation du bien",     iti: "Modérée",             ite: "Forte",             avantage: "ite" },
];

const currentHref = "/blog/isolation-interieure-ou-exterieure";
const articles = [
  {
    href: "/blog/isolation-interieure-ou-exterieure",
    categorie: "Isolation",
    titre: "Isolation intérieure ou extérieure : quelle solution choisir ?",
    description: "Comparez l'isolation thermique par l'intérieur et par l'extérieur : avantages, performances, coûts et aides disponibles pour bien choisir.",
    image: "/images/blog/Isolation-intérieure-ou-extérieure/hero isolation-interieure-exterieure.png",
    badge: "bg-[#E8F0FB] text-[#1E4B8C]",
  },
  {
    href: "/blog/demoussage-toiture-pourquoi-ne-pas-attendre",
    categorie: "Toiture",
    titre: "Démoussage de toiture : pourquoi ne faut-il pas attendre ?",
    description: "Mousses, lichens, infiltrations… Découvrez pourquoi un entretien régulier de votre toiture évite des réparations bien plus coûteuses.",
    image: "/images/blog/Démoussage-de-toiture/Hero Démoussage de toiture.png",
    badge: "bg-orange-50 text-[#E8650A]",
  },
  {
    href: "/blog/renovation-energetique-plus-value-maison",
    categorie: "Rénovation",
    titre: "Comment la rénovation énergétique valorise votre maison ?",
    description: "Isolation, façade, DPE : comment les travaux de rénovation améliorent votre confort quotidien et augmentent la valeur immobilière de votre bien.",
    image: "/images/blog/valoriser-votre-maison/Hero valoriser votre maison.png",
    badge: "bg-[#E8F0FB] text-[#1E4B8C]",
  },
  {
    href: "/blog/comment-savoir-si-votre-facade-a-besoin-dun-ravalement",
    categorie: "Façade",
    titre: "Comment savoir si votre façade a besoin d'un ravalement ?",
    description: "Fissures, mousses, enduit dégradé, humidité : apprenez à reconnaître les signes qui indiquent qu'un ravalement de façade s'impose.",
    image: "/images/blog/façade-a-besoin-d-un-ravalement/Hero façade a besoin d'un ravalement.png",
    badge: "bg-orange-50 text-[#E8650A]",
  },
];
const autresArticles = articles.filter(a => a.href !== currentHref).slice(0, 3);
---

<BaseLayout
  title="Isolation intérieure ou extérieure : quelle solution choisir ? | Conesa"
  description="Comparez l'isolation intérieure et l'isolation thermique extérieure : avantages, inconvénients, performances, coûts et aides disponibles dans le Tarn."
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Isolation intérieure ou extérieure : quelle solution choisir ?",
    "description": "Comparez l'isolation intérieure et l'isolation thermique extérieure : avantages, inconvénients, performances, coûts et aides disponibles.",
    "author": { "@type": "Organization", "name": "Conesa" },
    "publisher": { "@type": "Organization", "name": "Conesa", "url": "https://conesa-renovation.fr" },
    "url": "https://conesa-renovation.fr/blog/isolation-interieure-ou-exterieure",
    "mainEntityOfPage": "https://conesa-renovation.fr/blog/isolation-interieure-ou-exterieure"
  })} />
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": { "@type": "Answer", "text": faq.a }
    }))
  })} />

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="relative bg-[#0A1E3D] pt-36 pb-16 lg:pt-44 lg:pb-20">
    <img
      src={encodeURI("/images/blog/Isolation-intérieure-ou-extérieure/hero isolation-interieure-exterieure.png")}
      alt="Isolation thermique extérieure — Conesa Tarn"
      class="absolute inset-0 w-full h-full object-cover object-center"
      fetchpriority="high"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,30,61,0.88) 0%, rgba(30,75,140,0.72) 55%, rgba(10,30,61,0.60) 100%);"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <a href="/blog" class="text-blue-300 hover:text-white transition-colors text-sm">Blog</a>
          <span class="text-blue-400">/</span>
          <span class="text-blue-200 text-sm">Isolation</span>
        </div>
        <span class="inline-block bg-[#E8F0FB] text-[#1E4B8C] text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full mb-5">Isolation</span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-6" style="font-family:'Montserrat',sans-serif;">
          Isolation intérieure ou extérieure : quelle solution choisir pour votre maison ?
        </h1>
        <p class="text-blue-100 text-lg leading-relaxed max-w-2xl">
          ITI ou ITE ? Les deux solutions améliorent le confort thermique, mais leurs performances, leurs contraintes et leurs impacts ne sont pas les mêmes. Voici tout ce qu'il faut savoir avant de se décider.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       IMAGE + INTRO
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div class="rounded-2xl overflow-hidden shadow-xl bg-gray-100 order-2 lg:order-1" style="aspect-ratio:4/3;">
          <img
            src={encodeURI("/images/blog/Isolation-intérieure-ou-extérieure/isolation-interieure-exterieure.png")}
            alt="Isolation thermique extérieure d'une maison dans le Tarn — Conesa"
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
            onerror="this.parentElement.style.background='#E8F0FB'"
          />
        </div>

        <div class="order-1 lg:order-2">
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Bien choisir son isolation</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 mb-5 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Deux solutions, un même objectif : réduire vos pertes de chaleur
          </h2>
          <p class="text-gray-600 leading-relaxed mb-5">
            Lorsqu'un logement présente des pertes de chaleur importantes, l'isolation des murs devient une priorité. Deux techniques existent : l'isolation thermique par l'intérieur (ITI) et l'isolation thermique par l'extérieur (ITE).
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            Bien qu'elles poursuivent le même objectif, leur mise en œuvre, leurs performances et leurs impacts sur le bâtiment sont très différents. Le choix dépend de votre logement, de votre budget et de vos objectifs à long terme.
          </p>
          <div class="space-y-3">
            {[
              "Améliorer le confort thermique hiver comme été",
              "Réduire vos factures d'énergie durablement",
              "Valoriser votre bien immobilier",
              "Accéder aux aides financières (MaPrimeRénov', CEE...)",
            ].map(point => (
              <div class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-[#E8650A] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <span class="text-gray-700 text-sm">{point}</span>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       ITI vs ITE — DEUX CARTES
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Les deux solutions</span>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Isolation intérieure et extérieure : comment ça fonctionne ?
        </h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-8">

        <!-- ITI -->
        <div class="bg-white rounded-2xl p-8 flex flex-col gap-6">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-[#E8F0FB] flex items-center justify-center text-[#1E4B8C] shrink-0">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest">ITI</p>
              <h3 class="font-bold text-[#1E4B8C] text-lg" style="font-family:'Montserrat',sans-serif;">Isolation par l'intérieur</h3>
            </div>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed">
            L'isolant est posé sur la face intérieure des murs extérieurs. Adapté aux rénovations partielles ou aux bâtiments dont la façade ne peut pas être modifiée.
          </p>
          <div class="space-y-3">
            <p class="text-xs font-semibold text-[#1E4B8C] uppercase tracking-widest">Avantages</p>
            {[
              "Coût initial plus accessible",
              "Réalisable progressivement, pièce par pièce",
              "Façade conservée à l'identique",
              "Adapté aux contraintes architecturales",
            ].map(p => (
              <div class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span class="text-gray-600 text-sm">{p}</span>
              </div>
            ))}
          </div>
          <div class="space-y-3">
            <p class="text-xs font-semibold text-[#E8650A] uppercase tracking-widest">Limites</p>
            {[
              "Légère réduction de la surface habitable",
              "Travaux intérieurs invasifs",
              "Ponts thermiques partiellement traités",
              "Performances énergétiques limitées",
            ].map(p => (
              <div class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-orange-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"/></svg>
                <span class="text-gray-600 text-sm">{p}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- ITE -->
        <div class="bg-[#1E4B8C] rounded-2xl p-8 flex flex-col gap-6 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-[#E8650A] opacity-10 rounded-bl-full"></div>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center text-white shrink-0">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/></svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-blue-300 uppercase tracking-widest">ITE — Notre expertise</p>
              <h3 class="font-bold text-white text-lg" style="font-family:'Montserrat',sans-serif;">Isolation par l'extérieur</h3>
            </div>
          </div>
          <p class="text-blue-100 text-sm leading-relaxed">
            Une couche continue d'isolant enveloppe le bâtiment par l'extérieur. Solution la plus performante pour améliorer durablement l'efficacité énergétique d'une maison tout en rénovant la façade.
          </p>
          <div class="space-y-3">
            <p class="text-xs font-semibold text-[#E8650A] uppercase tracking-widest">Avantages</p>
            {[
              "Suppression quasi totale des ponts thermiques",
              "Surface habitable inchangée",
              "Façade rénovée simultanément",
              "Meilleur confort été comme hiver",
              "Forte valorisation du bien immobilier",
            ].map(p => (
              <div class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-green-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span class="text-blue-100 text-sm">{p}</span>
              </div>
            ))}
          </div>
          <div class="space-y-3">
            <p class="text-xs font-semibold text-white/60 uppercase tracking-widest">Limite</p>
            {[
              "Investissement initial plus important",
              "Modification de l'aspect extérieur du bâtiment",
            ].map(p => (
              <div class="flex items-start gap-2.5">
                <svg class="w-4 h-4 text-blue-300 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"/></svg>
                <span class="text-blue-200 text-sm">{p}</span>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       TABLEAU COMPARATIF
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Comparatif</span>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          ITI vs ITE : quel bilan par critère ?
        </h2>
      </div>

      <div class="rounded-2xl border border-gray-100 overflow-hidden shadow-sm">
        <div class="grid grid-cols-3 bg-[#1E4B8C] text-white text-sm font-semibold px-6 py-4">
          <span>Critère</span>
          <span class="text-center">Isolation intérieure (ITI)</span>
          <span class="text-center text-[#E8650A]">Isolation extérieure (ITE)</span>
        </div>
        {comparatif.map((row, i) => (
          <div class={`grid grid-cols-3 px-6 py-4 text-sm gap-4 ${i % 2 === 0 ? 'bg-white' : 'bg-[#F8F9FA]'}`}>
            <span class="font-medium text-[#1E4B8C]">{row.critere}</span>
            <span class={`text-center ${row.avantage === 'iti' ? 'text-green-600 font-semibold' : 'text-gray-500'}`}>{row.iti}</span>
            <span class={`text-center ${row.avantage === 'ite' || row.avantage === 'both' ? 'text-[#E8650A] font-semibold' : 'text-gray-500'}`}>{row.ite}</span>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       QUAND CHOISIR + AIDES + LOCAL
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-start">

        <!-- Quand choisir quoi -->
        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Adapter la solution à votre projet</span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 mb-8 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Quelle solution pour votre situation ?
          </h2>

          <div class="space-y-6">
            <div class="bg-white rounded-2xl p-6">
              <h3 class="font-bold text-[#1E4B8C] mb-3" style="font-family:'Montserrat',sans-serif;">Privilégiez l'ITI si…</h3>
              <ul class="space-y-2">
                {[
                  "Votre budget est limité à court terme",
                  "La façade doit être conservée (bâtiment classé, copropriété)",
                  "Vous souhaitez rénover pièce par pièce",
                  "Vous êtes en appartement (murs mitoyens non concernés)",
                ].map(p => (
                  <li class="flex items-start gap-2.5 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-[#1E4B8C] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                    {p}
                  </li>
                ))}
              </ul>
            </div>

            <div class="bg-[#1E4B8C] rounded-2xl p-6">
              <h3 class="font-bold text-white mb-3" style="font-family:'Montserrat',sans-serif;">Privilégiez l'ITE si…</h3>
              <ul class="space-y-2">
                {[
                  "Vous recherchez les meilleures performances énergétiques",
                  "Votre façade est vieillissante ou dégradée",
                  "Vous voulez éviter les travaux intérieurs",
                  "Vous souhaitez valoriser durablement votre bien",
                  "Vous voulez accéder aux aides maximales (RGE obligatoire)",
                ].map(p => (
                  <li class="flex items-start gap-2.5 text-sm text-blue-100">
                    <svg class="w-4 h-4 text-[#E8650A] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    {p}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <!-- Aides + Local + CTA -->
        <div class="space-y-6">
          <div class="bg-white rounded-2xl p-7">
            <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Financer vos travaux</span>
            <h3 class="text-xl font-extrabold text-[#1E4B8C] mt-2 mb-4" style="font-family:'Montserrat',sans-serif;">Les aides disponibles</h3>
            <div class="space-y-3">
              {[
                { aide: "MaPrimeRénov'", desc: "Subvention de l'État selon vos revenus et le type de travaux." },
                { aide: "CEE", desc: "Certificats d'Économies d'Énergie versés par les fournisseurs d'énergie." },
                { aide: "Éco-PTZ", desc: "Prêt à taux zéro pour financer vos travaux de rénovation énergétique." },
                { aide: "TVA à 5,5 %", desc: "Taux réduit applicable sur les travaux de rénovation énergétique." },
              ].map(item => (
                <div class="flex gap-3 py-2 border-b border-gray-100 last:border-0">
                  <span class="font-bold text-[#1E4B8C] text-sm shrink-0 w-28">{item.aide}</span>
                  <span class="text-gray-600 text-sm">{item.desc}</span>
                </div>
              ))}
            </div>
            <p class="text-xs text-gray-400 mt-4">Certifié RGE, Conesa vous permet d'accéder à l'ensemble de ces dispositifs.</p>
          </div>

          <div class="bg-[#1E4B8C] rounded-2xl p-7 relative overflow-hidden">
            <div class="absolute inset-0 opacity-[0.05]" style="background-image:repeating-linear-gradient(45deg,#fff 0,#fff 1px,transparent 0,transparent 50%);background-size:30px 30px;"></div>
            <div class="relative">
              <p class="text-blue-200 text-sm font-semibold uppercase tracking-widest mb-2">Intervention locale — Tarn (81)</p>
              <h3 class="text-xl font-extrabold text-white mb-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
                Spécialiste ITE à Albi, Gaillac, Castres et dans tout le Tarn
              </h3>
              <p class="text-blue-100 text-sm leading-relaxed mb-6">
                Depuis plus de 55 ans, nos équipes réalisent des chantiers d'isolation thermique extérieure dans tout le département. Nous vous accompagnons de l'étude du projet jusqu'à la réception des travaux.
              </p>
              <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-[#E8650A] hover:bg-orange-700 text-white font-bold px-6 py-3 rounded-xl transition-all duration-200 hover:scale-105 text-sm">
                Demander un devis gratuit
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       FAQ
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Questions fréquentes</span>
        <h2 class="text-2xl sm:text-3xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Tout savoir sur l'isolation intérieure et extérieure
        </h2>
      </div>

      <div class="border-t border-gray-200">
        {faqs.map(faq => (
          <div class="faq-item border-b border-gray-200">
            <h3 class="m-0 font-normal">
              <button class="faq-trigger w-full flex items-center justify-between gap-6 py-5 px-1 text-left">
                <span class="faq-question font-semibold text-[#1E4B8C] text-base leading-snug" style="font-family:'Montserrat',sans-serif;">
                  {faq.q}
                </span>
                <svg class="faq-icon shrink-0 w-5 h-5 text-gray-400" style="transition: transform 0.45s ease, color 0.3s ease;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
            </h3>
            <div class="faq-body overflow-hidden" style="max-height:0; transition: max-height 0.45s ease;">
              <p class="pb-6 pt-1 px-1 text-gray-600 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
      const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger')!;
      const body    = item.querySelector<HTMLElement>('.faq-body')!;
      const icon    = item.querySelector<SVGElement>('.faq-icon')!;
      trigger.addEventListener('click', () => {
        const isOpen = item.dataset.open === 'true';
        document.querySelectorAll<HTMLElement>('.faq-item').forEach(other => {
          other.dataset.open = 'false';
          (other.querySelector<HTMLElement>('.faq-body')!).style.maxHeight = '0';
          const ic = other.querySelector<SVGElement>('.faq-icon')!;
          ic.style.transform = '';
          ic.style.color = '';
        });
        if (!isOpen) {
          item.dataset.open = 'true';
          body.style.maxHeight = body.scrollHeight + 'px';
          icon.style.transform = 'rotate(180deg)';
          icon.style.color = '#E8650A';
        }
      });
    });
  </script>

  <!-- ══════════════════════════════════════
