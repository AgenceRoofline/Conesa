          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {autresArticles.map((article) => (
          <a href={article.href} class="group bg-white rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col">
            <div class="h-48 bg-gray-100 overflow-hidden">
              <img
                src={encodeURI(article.image)}
                alt={article.titre}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
                onerror="this.parentElement.style.background='#E8F0FB'"
              />
            </div>
            <div class="p-6 flex flex-col flex-1">
              <span class={`inline-block self-start text-xs font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full mb-4 ${article.badge}`}>
                {article.categorie}
              </span>
              <h3 class="font-bold text-[#1E4B8C] text-base leading-snug mb-3 group-hover:text-[#E8650A] transition-colors" style="font-family:'Montserrat',sans-serif;">
                {article.titre}
              </h3>
              <p class="text-gray-600 text-sm leading-relaxed flex-1">{article.description}</p>
              <div class="flex items-center gap-2 text-[#E8650A] font-semibold text-sm mt-5 group-hover:gap-3 transition-all duration-150">
                Lire l'article
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </div>
