---
import BaseLayout from '../layouts/BaseLayout.astro';
import ZonesIntervention from '../components/ZonesIntervention.astro';

const services = [
  {
    id: "facade",
    picto: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
    label: "Ravalement de façade",
    teaser: "Nettoyage, traitement des fissures, enduits et protection hydrofuge.",
  },
  {
    id: "peinture",
    picto: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>`,
    label: "Peinture intérieure & extérieure",
    teaser: "Finitions soignées, enduits décoratifs et protection des surfaces.",
  },
  {
    id: "toiture",
    picto: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v9a1 1 0 001 1h4v-5h4v5h4a1 1 0 001-1v-9"/></svg>`,
    label: "Entretien de toiture",
    teaser: "Démoussage, hydrofuge et entretien préventif pour protéger votre toit.",
  },
  {
    id: "sols",
    picto: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>`,
    label: "Revêtements de sols",
    teaser: "Pose de sols souples, PVC, parquets stratifiés et revêtements décoratifs.",
  },
  {
    id: "sinistre",
    picto: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    label: "Travaux après sinistre",
    teaser: "Remise en état rapide et coordonnée après dégât des eaux ou incendie.",
  },
];

const engagements = [
  "Plus de 55 ans d'expérience",
  "Entreprise familiale locale",
  "Certifications RGE et Qualibat",
  "Accompagnement personnalisé",
  "Solutions adaptées à chaque projet",
  "Devis gratuit & sans engagement",
  "Intervention dans tout le Tarn",
];

const faqs = [
  {
    q: "Réalisez-vous plusieurs types de travaux sur un même chantier ?",
    a: "Oui, c'est l'un des atouts majeurs de Conesa. Grâce à la diversité de nos compétences, nous pouvons intervenir simultanément sur la façade, la peinture, la toiture ou les sols. Vous bénéficiez d'un interlocuteur unique pour l'ensemble de votre projet, ce qui simplifie la coordination et limite les délais.",
  },
  {
    q: "Intervenez-vous dans tout le Tarn ?",
    a: "Oui, nos équipes se déplacent dans l'ensemble du département du Tarn (81) : Albi, Gaillac, Castres, Graulhet, Carmaux, Lavaur, Réalmont, Mazamet, Saint-Sulpice et leurs communes environnantes. N'hésitez pas à nous contacter pour vérifier notre disponibilité dans votre secteur.",
  },
  {
    q: "Proposez-vous des devis gratuits ?",
    a: "Oui, le devis est entièrement gratuit et sans engagement. Après une visite sur site pour évaluer l'état des surfaces et comprendre vos attentes, nous vous remettons un devis détaillé. Nous vous répondons sous 24h.",
  },
  {
    q: "Quel est le délai moyen d'intervention ?",
    a: "Le délai dépend de la nature et de l'ampleur des travaux. Pour un rafraîchissement de peinture ou un entretien de toiture, nous pouvons généralement intervenir sous 2 à 4 semaines. Pour des projets plus complets, un planning précis vous est communiqué dès l'établissement du devis.",
  },
  {
    q: "Comment se déroule un projet de rénovation ?",
    a: "Après votre prise de contact, nous organisons une visite sur site pour étudier votre projet. Nous établissons ensuite un devis détaillé et un planning de chantier. Les travaux sont réalisés par nos équipes avec un suivi régulier. En fin de chantier, nous procédons à une réception des travaux pour s'assurer de votre entière satisfaction.",
  },
  {
    q: "Travaillez-vous avec des particuliers et des professionnels ?",
    a: "Oui, Conesa intervient aussi bien pour des particuliers que pour des professionnels (copropriétés, commerces, bâtiments tertiaires). Nos équipes s'adaptent aux contraintes spécifiques de chaque type de chantier.",
  },
  {
    q: "Réalisez-vous les travaux après un dégât des eaux ?",
    a: "Oui. Après un sinistre (dégât des eaux, incendie, intempéries), nous intervenons rapidement pour la remise en état des murs, la réfection des peintures et les réparations nécessaires. Nous pouvons également vous accompagner dans le suivi du dossier auprès de votre assureur.",
  },
  {
    q: "Quels types de revêtements de sols proposez-vous ?",
    a: "Nous proposons la pose de sols souples, de PVC, de parquets stratifiés et de revêtements décoratifs adaptés à votre usage et à votre budget. Nos équipes vous conseillent dans le choix des matériaux les plus adaptés à chaque pièce et à chaque contrainte (humidité, circulation, esthétique).",
  },
];
---

<BaseLayout
  title="Rénovation de l'Habitat dans le Tarn — Façade, Peinture, Toiture, Sols"
  description="Conesa — Entreprise de rénovation dans le Tarn depuis plus de 55 ans. Ravalement de façade, peinture, toiture, sols et travaux après sinistre. Devis gratuit."
>

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[#0A1E3D]" style="padding-top: 160px; padding-bottom: 96px;">
    <img
      src="/images/Page rénovation/Hero Rénovation.png"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
      onerror="this.style.display='none'"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,30,61,0.92) 0%, rgba(30,75,140,0.78) 60%, rgba(10,30,61,0.72) 100%);"></div>
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="absolute top-0 left-0 w-1 h-full bg-[#E8650A] opacity-60"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 text-sm font-medium text-white mb-8">
          <span class="w-2 h-2 bg-[#E8650A] rounded-full"></span>
          Entreprise familiale dans le Tarn depuis 1969
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-[3rem] font-extrabold text-white leading-[1.1] mb-6" style="font-family:'Montserrat',sans-serif;">
          Tous vos travaux de<br>rénovation
          <span class="text-[#E8650A]"> avec un seul<br>interlocuteur</span>
        </h1>
        <p class="text-blue-100 text-lg leading-relaxed mb-10 max-w-xl">
          Depuis plus de 55 ans, Conesa accompagne les particuliers et les professionnels dans leurs projets de rénovation intérieure et extérieure à travers tout le Tarn. De la façade à la toiture, en passant par la peinture, les revêtements de sols et les travaux après sinistre.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="#contact" class="inline-flex items-center justify-center gap-2 bg-[#E8650A] hover:bg-orange-700 text-white font-bold px-8 py-4 rounded-xl transition-all duration-200 hover:scale-105 shadow-lg shadow-orange-900/30">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Demander un devis gratuit
          </a>
          <a href="#prestations" class="inline-flex items-center justify-center gap-2 border-2 border-white/30 text-white hover:bg-white/10 font-semibold px-8 py-4 rounded-xl transition-all duration-200">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
            Découvrir nos prestations
          </a>
        </div>
        <div class="flex items-center gap-6 pt-8 border-t border-white/10">
          <div class="flex items-center gap-2.5">
            <img src="/images/labels/Logo-RGE.png" alt="RGE Qualibat" class="h-11 w-auto bg-white rounded-lg p-1 shadow" onerror="this.style.display='none'"/>
            <span class="text-blue-100 text-sm">Certifié RGE & Qualibat</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       INTRO — EXPERTISE COMPLÈTE
  ══════════════════════════════════════ -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Notre approche</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 mb-6 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Une expertise complète pour votre habitat
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            La rénovation d'une habitation est un projet important qui demande l'intervention de professionnels qualifiés capables de prendre en charge différents corps de métier. Qu'il s'agisse d'améliorer une façade, de rénover des peintures ou d'entretenir une toiture, chaque intervention contribue à préserver la qualité, le confort et la valeur de votre patrimoine.
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            Faire appel à un interlocuteur unique permet de simplifier le suivi des travaux, de garantir une meilleure coordination des interventions et d'assurer un résultat durable. Notre équipe vous accompagne à chaque étape, depuis l'étude de vos besoins jusqu'à la réception du chantier.
          </p>
          <div class="inline-flex items-center gap-2 bg-[#F0F5FC] text-[#1E4B8C] font-semibold text-sm px-5 py-3 rounded-xl">
            <svg class="w-4 h-4 text-[#E8650A] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            Améliorer, protéger et valoriser durablement votre bien
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          {[
            { val: "1969", label: "Année de création" },
            { val: "5", label: "domaines de compétences sous un même toit" },
            { val: "RGE", label: "& Qualibat certifié" },
            { val: "24h", label: "de délai de réponse garanti" },
          ].map(item => (
            <div class="bg-[#F0F5FC] rounded-2xl p-6 text-center">
              <p class="text-3xl font-extrabold text-[#1E4B8C] mb-2" style="font-family:'Montserrat',sans-serif;">{item.val}</p>
              <p class="text-gray-600 text-sm leading-snug">{item.label}</p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       NAVIGATION DES PRESTATIONS
  ══════════════════════════════════════ -->
  <section id="prestations" class="py-20 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Nos savoir-faire</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Nos domaines d'intervention
        </h2>
        <p class="text-gray-600 mt-4 text-lg max-w-2xl mx-auto">
          Cinq métiers complémentaires pour une rénovation globale et cohérente de votre habitation.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s, i) => (
          <a
            href={`#${s.id}`}
            class={`group bg-white rounded-2xl p-7 shadow-sm border border-gray-100 hover:border-[#1E4B8C]/20 hover:shadow-md transition-all duration-300 flex flex-col gap-4 ${i === 4 ? 'sm:col-span-2 lg:col-span-1 lg:col-start-2' : ''}`}
          >
            <div class="w-14 h-14 bg-[#E8F0FB] group-hover:bg-[#1E4B8C] rounded-xl flex items-center justify-center text-[#1E4B8C] group-hover:text-white transition-colors duration-300">
              <Fragment set:html={s.picto} />
            </div>
            <div>
              <h3 class="font-bold text-[#1E4B8C] text-base mb-2" style="font-family:'Montserrat',sans-serif;">{s.label}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{s.teaser}</p>
            </div>
            <span class="inline-flex items-center gap-1 text-[#E8650A] font-semibold text-sm mt-auto">
              En savoir plus
              <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       RAVALEMENT DE FAÇADE
  ══════════════════════════════════════ -->
  <section id="facade" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">

        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Façade</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 mb-4 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Ravalement et rénovation de façade
          </h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            La façade est l'un des éléments les plus exposés de votre habitation. Au fil du temps, les intempéries, la pollution, l'humidité et les variations de température peuvent altérer son apparence et fragiliser les matériaux. Afin de préserver l'esthétique et la durabilité de votre bien, nous réalisons différents travaux de rénovation adaptés à l'état de votre façade.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
            {[
              { title: "Ravalement de façade", desc: "Remet en état les murs extérieurs tout en redonnant un aspect propre et harmonieux." },
              { title: "Nettoyage & traitement", desc: "Élimine mousses, algues et traces de pollution pour retrouver une façade saine." },
              { title: "Traitement des fissures", desc: "Réparations ciblées pour éviter les infiltrations et retrouver un support sain." },
              { title: "Enduits & finitions", desc: "Améliore l'esthétique tout en assurant une protection efficace des murs extérieurs." },
              { title: "Peinture de protection", desc: "Rafraîchit l'apparence et renforce la résistance aux agressions climatiques." },
            ].map(item => (
              <div class="bg-[#F0F5FC] rounded-xl p-4 border border-[#E8F0FB]">
                <h4 class="font-bold text-[#1E4B8C] text-sm mb-1" style="font-family:'Montserrat',sans-serif;">{item.title}</h4>
                <p class="text-gray-500 text-xs leading-snug">{item.desc}</p>
              </div>
            ))}
          </div>
          <a href="#contact" class="inline-flex items-center gap-2 bg-[#1E4B8C] hover:bg-[#153566] text-white font-bold px-8 py-4 rounded-xl transition-colors duration-200">
            Découvrir nos solutions de façade
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <div class="relative rounded-2xl overflow-hidden min-h-[480px] h-full flex items-center">
          <img src="/images/Page rénovation/Ravalement de façade.png" alt="Ravalement de façade" class="absolute inset-0 w-full h-full object-cover" onerror="this.style.display='none'"/>
          <div class="absolute inset-0 bg-[#0A1E3D]/75"></div>
          <div class="relative p-8 w-full">
            <h3 class="font-bold text-white mb-6 text-lg" style="font-family:'Montserrat',sans-serif;">Nos interventions sur façade</h3>
            <ul class="space-y-3">
              {[
                "Ravalement de façade",
                "Nettoyage haute performance",
                "Traitement des fissures",
                "Réparation des supports",
                "Application d'enduits",
                "Protection hydrofuge",
              ].map(item => (
                <li class="flex items-center gap-3 text-white/90">
                  <span class="w-5 h-5 bg-[#E8650A] rounded-full flex items-center justify-center shrink-0">
                    <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       PEINTURE
  ══════════════════════════════════════ -->
  <section id="peinture" class="py-20 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">

        <div class="relative rounded-2xl overflow-hidden min-h-[480px] h-full flex items-center lg:order-1">
          <img src="/images/Page rénovation/Peinture intérieur et extérieure.png" alt="Peinture intérieure et extérieure" class="absolute inset-0 w-full h-full object-cover" onerror="this.style.display='none'"/>
          <div class="absolute inset-0 bg-[#0A1E3D]/75"></div>
          <div class="relative p-8 w-full">
            <h3 class="font-bold text-white mb-6 text-lg" style="font-family:'Montserrat',sans-serif;">Nos prestations de peinture</h3>
            <ul class="space-y-3">
              {[
                "Peinture intérieure",
                "Peinture extérieure",
                "Décoration & enduits décoratifs",
                "Revêtements muraux",
                "Protection des façades",
                "Remise en peinture après travaux",
              ].map(item => (
                <li class="flex items-center gap-3 text-white/90">
                  <span class="w-5 h-5 bg-[#E8650A] rounded-full flex items-center justify-center shrink-0">
                    <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="lg:order-2">
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Peinture</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 mb-4 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Peinture intérieure et extérieure
          </h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            La peinture joue un rôle essentiel dans l'ambiance, la protection et la valorisation d'un bâtiment. Que ce soit pour rénover un intérieur, moderniser une façade ou personnaliser vos espaces, nous vous accompagnons dans le choix des couleurs, des matériaux et des finitions les plus adaptées à votre projet.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
            {[
              { title: "Peinture intérieure", desc: "Rénove murs et plafonds pour redonner un nouveau souffle à votre intérieur." },
              { title: "Peinture extérieure", desc: "Revêtements spéciaux pour une protection durable face aux intempéries et aux UV." },
              { title: "Décoration & personnalisation", desc: "Enduits décoratifs, effets de matières et coloris pour des espaces qui vous ressemblent." },
              { title: "Revêtements muraux", desc: "Solutions variées pour habiller vos murs et créer des ambiances uniques." },
            ].map(item => (
              <div class="bg-white rounded-xl p-4 border border-gray-100">
                <h4 class="font-bold text-[#1E4B8C] text-sm mb-1" style="font-family:'Montserrat',sans-serif;">{item.title}</h4>
                <p class="text-gray-500 text-xs leading-snug">{item.desc}</p>
              </div>
            ))}
          </div>
          <a href="#contact" class="inline-flex items-center gap-2 bg-[#1E4B8C] hover:bg-[#153566] text-white font-bold px-8 py-4 rounded-xl transition-colors duration-200">
            Découvrir nos prestations de peinture
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       TOITURE
  ══════════════════════════════════════ -->
  <section id="toiture" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">

        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Toiture</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 mb-4 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Entretien et nettoyage de toiture
