<script>
  document.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
    const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger')!;
    const body    = item.querySelector<HTMLElement>('.faq-body')!;
    const icon    = item.querySelector<SVGElement>('.faq-icon')!;

    trigger.addEventListener('click', () => {
      const isOpen = item.dataset.open === 'true';

      document.querySelectorAll<HTMLElement>('.faq-item').forEach(other => {
        other.dataset.open = 'false';
        const b  = other.querySelector<HTMLElement>('.faq-body')!;
        const ic = other.querySelector<SVGElement>('.faq-icon')!;
        b.style.maxHeight = '0';
        ic.style.transform = '';
        ic.style.color = '';
      });

      if (!isOpen) {
        item.dataset.open = 'true';
        body.style.maxHeight = body.scrollHeight + 'px';
        icon.style.transform = 'rotate(180deg)';
        icon.style.color = '#E8650A';
      }
    });
  });
</script>
