---
import BaseLayout from '../layouts/BaseLayout.astro';
import ZonesIntervention from '../components/ZonesIntervention.astro';

const prestations = [
  {
    titre: "Nettoyage de façade",
    desc: "Élimination des salissures, mousses, lichens et traces de pollution par nettoyage haute ou basse pression selon les supports. Première étape indispensable avant tout traitement.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
  },
  {
    titre: "Réparation des fissures",
    desc: "Diagnostic des fissures (microfissures, fissures d'enduit ou structurelles), traitement adapté à chaque pathologie et rebouchage pour éviter les infiltrations d'eau.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>`,
  },
  {
    titre: "Réfection des enduits",
    desc: "Rénovation complète ou partielle des enduits dégradés : farinage, cloquage, décollement. Application d'enduits de finition adaptés au support pour retrouver une façade saine et homogène.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>`,
  },
  {
    titre: "Peinture extérieure",
    desc: "Application de peintures de façade haute performance, résistantes aux UV et aux intempéries. Rafraîchit l'aspect esthétique tout en renforçant la protection des supports.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>`,
  },
  {
    titre: "Traitement hydrofuge",
    desc: "Application d'un traitement hydrofuge en finition pour imperméabiliser les murs, repousser l'eau de pluie et limiter la réapparition de mousses et d'algues.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>`,
  },
];

const signes = [
  {
    titre: "Fissures sur les murs extérieurs",
    desc: "Les microfissures et fissures d'enduit peuvent paraître anodines mais laissent l'humidité s'infiltrer progressivement. Non traitées, elles fragilisent le support et peuvent évoluer vers des désordres plus importants.",
  },
  {
    titre: "Enduit qui se décolle ou s'effrite",
    desc: "Le farinage, le cloquage ou le décollement de l'enduit signalent un revêtement en fin de vie. Ces pathologies résultent souvent du vieillissement naturel des matériaux ou d'une humidité persistante.",
  },
  {
    titre: "Traces d'humidité, mousses et algues",
    desc: "L'humidité, les mousses et les algues sont caractéristiques d'une façade perméable à l'eau. En plus de dégrader l'esthétique, elles retiennent l'humidité et accélèrent la détérioration du support.",
  },
  {
    titre: "Façade ternie ou vieillissante",
    desc: "Une façade décolorée, tachée ou simplement ancienne nuit à l'aspect général de votre habitation et à sa valorisation immobilière. Un ravalement redonné un aspect neuf, durable et soigné.",
  },
];

const avantages = [
  {
    titre: "Une maison mieux protégée",
    desc: "Un enduit sain et un traitement hydrofuge à jour constituent une barrière efficace contre les intempéries, l'humidité et le gel. Votre façade protège durablement les murs porteurs.",
  },
  {
    titre: "Une esthétique retrouvée",
    desc: "Le ravalement redonne à votre habitation un aspect propre, cohérent et soigné. Un simple rafraîchissement de peinture peut transformer l'impression générale d'un bien.",
  },
  {
    titre: "Une meilleure valorisation immobilière",
    desc: "Une façade en bon état est un critère de valorisation reconnu. Lors d'une revente ou d'une mise en location, l'état extérieur du bien influence directement sa perception et son prix.",
  },
  {
    titre: "Une durée de vie prolongée des murs",
    desc: "Un ravalement réalisé à temps évite l'aggravation des pathologies et repousse des travaux bien plus coûteux. C'est un investissement rentable sur le long terme.",
  },
];

const etapes = [
  { num: "01", titre: "Diagnostic de la façade", desc: "Analyse complète de l'état du support : fissures, enduit, hygrométrie, mousse. Nous évaluons les pathologies présentes et déterminons le traitement adapté." },
  { num: "02", titre: "Préparation du chantier", desc: "Mise en place des protections (bâches, garde-corps) et du matériel. Sécurisation de la zone de travail pour protéger vos abords et votre mobilier extérieur." },
  { num: "03", titre: "Réparation des supports", desc: "Traitement des fissures, reprise des zones dégradées, dépose des enduits défaillants. Nous travaillons sur un support sain avant toute application de finition." },
  { num: "04", titre: "Application des traitements et finitions", desc: "Nettoyage, traitement antimousse, application de l'enduit ou de la peinture de façade selon le support et vos choix esthétiques. Contrôle en cours d'application." },
  { num: "05", titre: "Contrôle qualité & réception", desc: "Vérification minutieuse du résultat, levée des réserves éventuelles et remise en état des abords. Nous vous remettons un chantier propre et conforme à vos attentes." },
];

const engagements = [
  "Plus de 55 ans d'expérience en rénovation extérieure",
  "Entreprise familiale et équipes locales dans le Tarn",
  "Certification RGE et Qualibat",
  "Devis gratuit, détaillé et sans engagement",
  "Garantie décennale sur les travaux réalisés",
  "Accompagnement personnalisé de A à Z",
  "Interlocuteur unique pour tout votre chantier",
];

const villes = ["Albi", "Gaillac", "Castres", "Graulhet", "Lavaur", "Carmaux", "Mazamet", "Saint-Sulpice"];

const villesLinks: Record<string, string> = {
  "Albi": "/villes/albi",
  "Gaillac": "/villes/gaillac",
  "Castres": "/villes/castres",
  "Graulhet": "/villes/graulhet",
};

const faqs = [
  {
    q: "Quand faut-il réaliser un ravalement de façade ?",
    a: "Un ravalement est recommandé tous les 10 à 15 ans en moyenne, mais certains signes justifient une intervention plus tôt : fissures visibles, enduit qui s'effrite, mousses envahissantes, humidité persistante ou simple vieillissement esthétique. Un diagnostic gratuit permet d'évaluer l'état réel de votre façade.",
  },
  {
    q: "Combien coûte un ravalement de façade ?",
    a: "Le prix varie selon la surface à traiter, l'état de la façade, les pathologies présentes et le type de finition choisie. Il faut compter en moyenne entre 40 et 100 €/m² selon les travaux. Contactez-nous pour un devis gratuit et personnalisé, adapté à votre chantier.",
  },
  {
    q: "Comment réparer une façade fissurée ?",
    a: "Tout dépend du type de fissure. Les microfissures superficielles se traitent par application d'un enduit de finition souple. Les fissures plus profondes nécessitent un diagnostic pour identifier la cause (mouvement de terrain, dilatation, humidité) avant toute réparation ciblée. Nos techniciens évaluent chaque cas lors de la visite.",
  },
  {
    q: "Une façade dégradée peut-elle provoquer des infiltrations ?",
    a: "Oui. Les fissures, les enduits poreux ou décollés et l'absence de traitement hydrofuge sont des voies d'entrée directes pour l'eau de pluie. Ces infiltrations peuvent abîmer les murs porteurs, favoriser le développement de moisissures et provoquer des dégâts à l'intérieur du logement si elles ne sont pas traitées rapidement.",
  },
  {
    q: "Quelle est la différence entre nettoyage et ravalement de façade ?",
    a: "Le nettoyage est une opération de surface : il élimine mousses, algues et salissures par lavage. Le ravalement est plus complet : il inclut le nettoyage, la réparation des supports (fissures, enduits), puis l'application d'un revêtement de finition. Le nettoyage seul peut suffire pour une façade en bon état général.",
  },
  {
    q: "Peut-on repeindre une façade ancienne sans l'enlever entièrement ?",
    a: "Oui, dans la majorité des cas. Si l'enduit existant est encore sain (bonne adhérence, pas de décollement ni de cloquage), un nettoyage suivi d'une sous-couche d'accrochage et d'une nouvelle peinture de façade suffit. Si l'enduit est trop dégradé, une reprise complète est nécessaire. Cela se détermine lors du diagnostic.",
  },
  {
    q: "Combien de temps durent les travaux de ravalement ?",
    a: "La durée dépend de la superficie et des travaux à réaliser. Pour une maison individuelle, comptez généralement 3 à 10 jours. Un chantier complet incluant réparations, enduit et peinture est plus long. Un planning précis vous est communiqué dès l'établissement du devis.",
  },
  {
    q: "Comment obtenir un devis gratuit ?",
    a: "Remplissez notre formulaire de contact, appelez-nous au 05 63 54 16 97 ou envoyez-nous un email. Un technicien Conesa se déplace gratuitement pour évaluer votre façade et vous remettre un devis détaillé, sans engagement de votre part, sous 24 h.",
  },
];

const jsonLdService = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Ravalement de façade",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Conesa",
    "telephone": "+33563541697",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Albi",
      "postalCode": "81000",
      "addressCountry": "FR"
    }
  },
  "areaServed": { "@type": "AdministrativeArea", "name": "Tarn" },
  "description": "Ravalement, nettoyage, réparation de fissures, réfection d'enduits et peinture de façade dans le Tarn.",
  "url": "https://conesa-renovation.fr/ravalement-facade"
});

const jsonLdBreadcrumb = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://conesa-renovation.fr/" },
    { "@type": "ListItem", "position": 2, "name": "Ravalement de façade", "item": "https://conesa-renovation.fr/ravalement-facade" }
  ]
});

const jsonLdFaq = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
});
---

<BaseLayout
  title="Ravalement de façade dans le Tarn | Conesa"
  description="Rénovation, nettoyage, traitement des fissures et ravalement de façade dans le Tarn. Devis gratuit avec les experts Conesa."
>
  <script is:inline slot="head" type="application/ld+json" set:html={jsonLdService} />
  <script is:inline slot="head" type="application/ld+json" set:html={jsonLdBreadcrumb} />
  <script is:inline slot="head" type="application/ld+json" set:html={jsonLdFaq} />

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[#0A1E3D]" style="padding-top: 200px; padding-bottom: 96px;">
    <img
      src={encodeURI("/images/Page ravalement de façade/Hero Ravalement de façade.png")}
      alt="Ravalement et rénovation de façade dans le Tarn — Conesa"
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
      fetchpriority="high"
      onerror="this.style.display='none'"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(10,30,61,0.92) 0%, rgba(30,75,140,0.78) 60%, rgba(10,30,61,0.72) 100%);"></div>
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="absolute top-0 left-0 w-1 h-full bg-[#E8650A] opacity-60"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Fil d'Ariane -->
      <nav class="flex items-center gap-2 text-white/50 text-sm mb-8" aria-label="Fil d'Ariane">
        <a href="/" class="hover:text-white transition-colors">Accueil</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        <span class="text-white/80">Ravalement de façade</span>
      </nav>

      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 text-sm font-medium text-white mb-8">
          <span class="w-2 h-2 bg-[#E8650A] rounded-full"></span>
          Entreprise familiale dans le Tarn depuis 1969
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-[3rem] font-extrabold text-white leading-[1.1] mb-6" style="font-family:'Montserrat',sans-serif;">
          Ravalement et rénovation<br>de façade
          <span class="text-[#E8650A]"> dans le Tarn</span>
        </h1>
        <p class="text-blue-100 text-lg leading-relaxed mb-10 max-w-xl">
          La façade est la première protection de votre habitation. Conesa réalise vos travaux de ravalement, nettoyage, traitement des fissures et peinture extérieure dans tout le département du Tarn.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="#contact" class="inline-flex items-center justify-center gap-2 bg-[#E8650A] hover:bg-orange-700 text-white font-bold px-8 py-4 rounded-xl transition-all duration-200 hover:scale-105 shadow-lg shadow-orange-900/30">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Demander un devis gratuit
          </a>
          <a href="tel:0563541697" class="inline-flex items-center justify-center gap-2 border-2 border-white/30 text-white hover:bg-white/10 font-semibold px-8 py-4 rounded-xl transition-all duration-200">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            05 63 54 16 97
          </a>
        </div>
        <div class="flex items-center gap-4">
          <img src="/images/labels/Logo-RGE.png" alt="RGE Qualibat" class="h-11 w-auto bg-white rounded-lg p-1 shadow" loading="lazy" decoding="async" onerror="this.style.display='none'"/>
          <span class="text-blue-100 text-sm">Certifié RGE &amp; Qualibat — Devis gratuit sous 24 h</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       POURQUOI RÉNOVER SA FAÇADE
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Pourquoi rénover ?</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 mb-6 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Pourquoi rénover sa façade ?
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Une façade en mauvais état ne représente pas uniquement un problème esthétique. Les dégradations extérieures peuvent progressivement affecter la protection du bâtiment et favoriser l'apparition de désordres bien plus importants : infiltrations, humidité intérieure, dégradation des murs porteurs.
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            Rénover sa façade, c'est agir de manière préventive pour protéger durablement son patrimoine. C'est aussi améliorer l'esthétique de son habitation et valoriser son bien immobilier.
          </p>
          <ul class="space-y-3 mb-8">
            {[
              "Protéger durablement les murs extérieurs contre les intempéries",
              "Limiter les infiltrations d'eau et l'humidité intérieure",
              "Corriger les fissures avant qu'elles ne s'aggravent",
              "Prolonger la durée de vie des revêtements",
              "Améliorer l'apparence générale et valoriser le bien",
            ].map(item => (
              <li class="flex items-start gap-3 text-gray-700">
                <span class="w-5 h-5 rounded-full bg-[#E8650A] flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div>
          <!-- Image -->
          <div class="relative rounded-2xl overflow-hidden shadow-2xl" style="min-height:340px;">
            <img
              src={encodeURI("/images/Page ravalement de façade/Rénovation façade.png")}
              alt="Ravalement de façade — Conesa, entreprise familiale dans le Tarn"
              class="w-full h-full object-cover object-center absolute inset-0"
              loading="lazy"
              decoding="async"
              onerror="this.style.display='none'"
            />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(10,30,61,0.45) 0%, rgba(10,30,61,0.08) 45%, transparent 100%);"></div>
          </div>
          <!-- Encarts à cheval sur le bas de l'image -->
          <div class="relative z-10 -mt-9 flex items-center justify-center gap-3 flex-wrap px-6">
            {[
              { val: "55+", label: "ans d'expérience" },
              { val: "500+", label: "chantiers Tarn" },
            ].map(item => (
              <div class="bg-[#1E4B8C]/80 backdrop-blur-md border border-white/20 rounded-xl px-5 py-3 text-center shadow-xl min-w-[110px]">
                <p class="text-2xl font-extrabold text-white leading-none mb-1" style="font-family:'Montserrat',sans-serif;">{item.val}</p>
                <p class="text-blue-200 text-xs font-medium">{item.label}</p>
              </div>
            ))}
            <div class="bg-[#E8650A]/85 backdrop-blur-md border border-white/20 rounded-xl px-5 py-3 text-center shadow-xl min-w-[110px]">
              <p class="text-2xl font-extrabold text-white leading-none mb-1" style="font-family:'Montserrat',sans-serif;">RGE</p>
              <p class="text-orange-100 text-xs font-medium">Qualibat certifié</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       LES SIGNES
  ══════════════════════════════════════ -->
  <section class="py-8 lg:py-24 bg-[#F0F5FC]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center mb-14">
        <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Diagnostic</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-[#1E4B8C] mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
          Les signes qui indiquent<br>qu'un ravalement est nécessaire
        </h2>
        <p class="text-gray-600 mt-4 text-lg leading-relaxed">
          Votre façade parle d'elle-même. Voici les signaux d'alerte à ne pas ignorer.
        </p>
      </div>

      <div class="divide-y divide-gray-200 bg-white rounded-3xl overflow-hidden border border-gray-100 shadow-sm">
        {signes.map((s, i) => (
          <div class="flex items-start gap-6 lg:gap-10 px-7 py-8 group hover:bg-[#F8FAFF] transition-colors duration-200">
            <span
              class="shrink-0 text-7xl lg:text-8xl font-black leading-none select-none transition-colors duration-200"
              style={`font-family:'Montserrat',sans-serif; color: ${i === 0 ? 'rgba(232,101,10,0.18)' : i === 1 ? 'rgba(30,75,140,0.12)' : i === 2 ? 'rgba(232,101,10,0.15)' : 'rgba(30,75,140,0.10)'};`}
            >
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="flex-1 pt-2">
              <div class="flex items-start justify-between gap-4 mb-2">
                <h3 class="font-bold text-[#1E4B8C] text-base leading-snug" style="font-family:'Montserrat',sans-serif;">{s.titre}</h3>
                <span class="shrink-0 inline-flex items-center gap-1 bg-[#E8650A]/10 text-[#E8650A] text-xs font-semibold px-2.5 py-1 rounded-full mt-0.5">
                  <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
                  Alerte
                </span>
              </div>
              <p class="text-gray-600 text-sm leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
