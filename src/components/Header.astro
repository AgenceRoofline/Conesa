---
const nav = [
  { label: "Accueil", href: "/" },
  { label: "Isolation Extérieure", href: "/isolation", badge: true },
  {
    label: "Rénovation",
    href: "/renovation",
    dropdown: [
      { label: "Ravalement de façade", href: "/renovation#facade" },
      { label: "Peinture intérieure & extérieure", href: "/renovation#peinture" },
      { label: "Entretien de toiture", href: "/renovation#toiture" },
      { label: "Revêtements de sols", href: "/renovation#sols" },
      { label: "Travaux après sinistre", href: "/renovation#sinistre" },
    ],
  },
  { label: "L'Entreprise", href: "/entreprise" },
];

const villes = [
  { nom: "Albi", slug: "albi" },
  { nom: "Gaillac", slug: "gaillac" },
  { nom: "Castres", slug: "castres" },
  { nom: "Graulhet", slug: "graulhet" },
];
---

<!-- ═══════════════════════════════════
     HEADER CONTAINER (fixe, glisse au scroll)
═══════════════════════════════════ -->
<div id="headercontainer" class="fixed top-0 left-0 right-0 z-50" style="transition: transform 0.6s ease-in-out;">

<!-- Pré-header -->
<div id="preheader" class="bg-[#1E4B8C] text-white">
  <div class=" mx-auto px-4 sm:px-6 lg:px-8 py-2 flex items-center gap-4">

    <p class="hidden md:block text-blue-200 text-xs mr-auto">
      Entreprise familiale dans le Tarn depuis 1969 — RGE &amp; Qualibat
    </p>

    <div class="flex items-center gap-3 sm:gap-4 ml-auto md:ml-0">

      <!-- Téléphone -->
      <a href="tel:0563541697" class="flex items-center gap-1.5 text-blue-100 hover:text-white transition-colors text-xs">
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <span>05 63 54 16 97</span>
      </a>

      <span class="text-blue-500">|</span>

      <!-- Email -->
      <a href="mailto:conesa81@wanadoo.fr" class="flex items-center gap-1.5 text-blue-100 hover:text-white transition-colors text-xs">
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <span class="hidden sm:inline">conesa81@wanadoo.fr</span>
        <span class="sm:hidden">Email</span>
      </a>

      <span class="text-blue-500">|</span>

      <!-- Facebook -->
      <a href="https://www.facebook.com/sarl.conesa/" target="_blank" rel="noopener noreferrer" aria-label="Facebook Conesa" class="text-blue-100 hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </a>

      <span class="text-blue-500">|</span>

      <!-- Devis gratuit -->
      <a href="#contact" class="inline-flex items-center gap-1.5 bg-[#E8650A] hover:bg-orange-700 text-white font-semibold text-xs px-3 py-1.5 rounded-md transition-colors">
        Devis gratuit
      </a>

    </div>
  </div>
</div>

<!-- Bulle -->
<div class="px-3 sm:px-5 lg:px-8 py-2">
  <header class="max-w-7xl mx-auto rounded-2xl border border-white/40 shadow-xl shadow-black/15"
          style="background: rgba(255,255,255,0.68); backdrop-filter: blur(22px); -webkit-backdrop-filter: blur(22px);">
    <div class="flex items-center justify-between h-16 px-5 gap-6">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <img src="/images/Logo/Logo-Conesa.png" alt="Conesa" class="h-12 w-auto" onerror="this.style.display='none'"/>

      </a>

      <!-- Nav desktop -->
      <nav class="hidden lg:flex items-center gap-0.5 flex-1 justify-center">
        {nav.map(item => (
          item.dropdown ? (
            <div class="relative group">
              <a href={item.href} class="flex items-center gap-1 px-4 py-2 rounded-xl text-gray-600 hover:text-[#1E4B8C] hover:bg-[#E8F0FB] font-medium text-sm transition-all duration-150">
                {item.label}
                <svg class="w-3.5 h-3.5 text-gray-400 group-hover:text-[#1E4B8C] group-hover:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </a>
              <!-- Dropdown -->
              <div class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-64 rounded-xl shadow-xl border border-gray-100 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible translate-y-1 group-hover:translate-y-0 transition-all duration-200 z-50"
                   style="background:rgba(255,255,255,0.97); backdrop-filter:blur(10px);">
                <div class="absolute -top-1.5 left-1/2 -translate-x-1/2 w-3 h-3 bg-white border-l border-t border-gray-100 rotate-45"></div>
                {item.dropdown.map(sub => (
                  <a href={sub.href} class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-600 hover:text-[#1E4B8C] hover:bg-[#E8F0FB] transition-colors mx-1 rounded-lg">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#E8650A] shrink-0"></span>
                    {sub.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class={`flex items-center gap-1.5 px-4 py-2 rounded-xl font-medium text-sm transition-all duration-150 ${item.badge ? 'text-[#1E4B8C] bg-[#E8F0FB] hover:bg-[#1E4B8C] hover:text-white' : 'text-gray-600 hover:text-[#1E4B8C] hover:bg-[#E8F0FB]'}`}
            >
              
              {item.label}
            </a>
          )
        ))}
      </nav>

      <!-- Droite : icône villes + burger nav -->
      <div class="flex items-center gap-2 shrink-0">

        <!-- Bouton villes -->
        <button
          id="villes-toggle"
          aria-label="Voir nos zones d'intervention"
          title="Nos villes"
          class="flex items-center gap-2 px-3 py-2 rounded-xl border border-gray-200 text-gray-600 hover:text-[#1E4B8C] hover:border-[#1E4B8C]/30 hover:bg-[#E8F0FB] transition-all duration-150 text-sm font-medium"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span class="hidden sm:inline text-xs">Nos villes</span>
          <svg id="villes-chevron" class="w-3 h-3 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>

        <!-- Burger nav mobile -->
        <button
          id="menu-toggle"
          aria-label="Menu"
          class="lg:hidden flex items-center justify-center w-10 h-10 rounded-xl border border-gray-200 text-gray-600 hover:text-[#1E4B8C] hover:bg-[#E8F0FB] transition-all duration-150"
        >
          <svg id="icon-menu" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>

      </div>
    </div>

    <!-- Panel villes (sous le header, intégré dans la bulle) -->
    <div id="villes-panel" class="hidden border-t border-gray-100 px-5 py-4">
      <p class="text-xs text-gray-400 uppercase tracking-widest font-semibold mb-3">Zones d'intervention</p>
      <div class="flex flex-wrap gap-2">
        {villes.map(v => (
          <a
            href={`/villes/${v.slug}`}
            class="flex items-center gap-1.5 bg-[#E8F0FB] hover:bg-[#1E4B8C] text-[#1E4B8C] hover:text-white text-sm font-medium px-3 py-1.5 rounded-lg transition-all duration-150"
          >
            <svg class="w-3 h-3 text-[#E8650A] shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            {v.nom}
          </a>
        ))}
      </div>
    </div>

    <!-- Menu nav mobile -->
    <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 px-4 py-4">
      <nav class="flex flex-col gap-1">
        {nav.map(item => (
          item.dropdown ? (
            <details class="group">
              <summary class="flex items-center justify-between gap-2 py-2.5 px-3 rounded-xl text-gray-600 hover:text-[#1E4B8C] hover:bg-[#E8F0FB] font-medium text-sm cursor-pointer list-none transition-colors">
                {item.label}
                <svg class="w-3.5 h-3.5 text-gray-400 group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <div class="ml-3 mt-1 flex flex-col gap-0.5 border-l-2 border-[#E8F0FB] pl-3">
                {item.dropdown.map(sub => (
                  <a href={sub.href} class="flex items-center gap-2 py-2 px-2 text-sm text-gray-500 hover:text-[#1E4B8C] rounded-lg hover:bg-[#E8F0FB] transition-colors">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#E8650A] shrink-0"></span>
                    {sub.label}
                  </a>
                ))}
              </div>
            </details>
          ) : (
            <a
              href={item.href}
              class={`flex items-center gap-2 py-2.5 px-3 rounded-xl font-medium text-sm transition-colors ${item.badge ? 'text-[#1E4B8C] bg-[#E8F0FB]' : 'text-gray-600 hover:text-[#1E4B8C] hover:bg-[#E8F0FB]'}`}
            >
              {item.badge && <svg class="w-3 h-3 text-[#E8650A]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>}
              {item.label}
            </a>
          )
        ))}
      </nav>
    </div>

  </header>
</div>

</div><!-- /#headercontainer -->

<script>
  // Menu nav mobile
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconMenu   = document.getElementById('icon-menu');
  const iconClose  = document.getElementById('icon-close');

  menuToggle?.addEventListener('click', () => {
    const hidden = mobileMenu?.classList.toggle('hidden');
    iconMenu?.classList.toggle('hidden', !hidden);
    iconClose?.classList.toggle('hidden', !!hidden);
    // Ferme le panel villes si ouvert
    villesPanel?.classList.add('hidden');
    villesChevron?.classList.remove('rotate-180');
  });

  // Panel villes
  const villesToggle  = document.getElementById('villes-toggle');
  const villesPanel   = document.getElementById('villes-panel');
  const villesChevron = document.getElementById('villes-chevron');

  villesToggle?.addEventListener('click', () => {
    const hidden = villesPanel?.classList.toggle('hidden');
    villesChevron?.classList.toggle('rotate-180', !hidden);
    // Ferme le menu nav si ouvert
    mobileMenu?.classList.add('hidden');
    iconMenu?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
  });

  // Fermer en cliquant ailleurs
  document.addEventListener('click', (e) => {
    const header = document.querySelector('header');
    if (header && !header.contains(e.target as Node)) {
      villesPanel?.classList.add('hidden');
      villesChevron?.classList.remove('rotate-180');
      mobileMenu?.classList.add('hidden');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    }
  });

  // Cacher le pré-header au scroll (translateY)
  const headercontainer = document.getElementById('headercontainer') as HTMLElement | null;
  const preheader = document.getElementById('preheader') as HTMLElement | null;

  if (headercontainer && preheader) {
    let lastScrollTop = 0;

    window.addEventListener('scroll', function () {
      const currentScroll = window.scrollY;
      const preheaderH = preheader.offsetHeight;

      if (currentScroll > lastScrollTop) {
        headercontainer.style.transform = `translateY(-${preheaderH}px)`;
      } else if (currentScroll === 0) {
        headercontainer.style.transform = 'translateY(0)';
      }

      lastScrollTop = currentScroll <= 0 ? 0 : currentScroll;
    }, { passive: true });
  }
</script>
