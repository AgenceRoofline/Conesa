---
const nav = [
  { label: "Isolation", href: "/isolation" },
  { label: "Façade", href: "/renovation#facade" },
  { label: "Peinture", href: "/renovation#peinture" },
  { label: "Toiture", href: "/renovation#toiture" },
  { label: "Sols", href: "/renovation#sols" },
  { label: "Après sinistre", href: "/renovation#sinistre" },
  { label: "Qui sommes-nous ?", href: "/entreprise", offset: true },
];

const villes = [
  { nom: "Albi", slug: "albi" },
  { nom: "Gaillac", slug: "gaillac" },
  { nom: "Castres", slug: "castres" },
  { nom: "Graulhet", slug: "graulhet" },
];
---

<!-- ═══════════════════════════════════
     HEADER CONTAINER (fixe, glisse au scroll)
═══════════════════════════════════ -->
<div id="headercontainer" class="fixed top-0 left-0 right-0 z-50" style="transition: transform 0.6s ease-in-out;">

<!-- Pré-header -->
<div id="preheader" class="bg-[#1E4B8C] text-white">
  <div class="mx-auto px-4 sm:px-6 lg:px-8 py-2 flex items-center justify-between gap-4">

    <!-- Gauche : téléphone + email -->
    <div class="flex items-center gap-3 sm:gap-4">

      <!-- Téléphone -->
      <a href="tel:0563541697" class="flex items-center gap-1.5 text-white hover:text-white/80 transition-colors text-xs">
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        <span>05 63 54 16 97</span>
      </a>

      <span class="text-blue-300">|</span>

      <!-- Email -->
      <a href="mailto:conesa81@wanadoo.fr" class="flex items-center gap-1.5 text-white hover:text-white/80 transition-colors text-xs">
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <span class="hidden sm:inline">conesa81@wanadoo.fr</span>
        <span class="sm:hidden">Email</span>
      </a>

    </div>

    <!-- Droite : texte entreprise (lg) + Facebook + Devis -->
    <div class="flex items-center gap-3 sm:gap-4">

      <!-- RGE + note Google — desktop uniquement -->
      <div class="hidden lg:flex items-center gap-2">
        <img src="/images/labels/Logo-RGE.png" alt="RGE Qualibat" class="h-5 w-auto bg-white rounded p-0.5" loading="lazy" decoding="async" onerror="this.style.display='none'"/>
        <span class="text-white/80 text-xs">Certifié RGE &amp; Qualibat</span>
      </div>

      <span class="hidden lg:block text-blue-300">|</span>

      <a href="/#avis" class="hidden lg:flex items-center gap-1 hover:text-white/60 transition-colors">
        {[1,2,3,4,5].map(() => (
          <svg class="w-3 h-3 fill-yellow-400" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        ))}
        <span class="text-white/80 text-xs ml-1">4,6/5 Google</span>
      </a>

      <span class="hidden lg:block text-blue-300">|</span>

      <!-- Facebook -->
      <a href="https://www.facebook.com/sarl.conesa/" target="_blank" rel="noopener noreferrer" aria-label="Facebook Conesa" class="text-white hover:text-white/80 transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </a>

      <span class="text-blue-300">|</span>

      <!-- Devis gratuit -->
      <a href="#contact" class="inline-flex items-center gap-1.5 bg-[#E8650A] hover:bg-orange-700 text-white font-semibold text-xs px-3 py-1.5 rounded-md transition-colors">
        Devis gratuit
      </a>

    </div>

  </div>
</div>

<!-- Header pleine largeur -->
<div>
  <header class="w-full bg-white shadow-sm border-b border-gray-100">
    <div class="max-w-screen-2xl mx-auto flex items-center justify-between h-[70px] md:h-[90px] lg:h-[110px] px-8 gap-6">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <img
          src="/images/Logo/Logo-Conesa.svg"
          alt="Conesa"
          class="h-[60px] md:h-[80px] lg:h-[100px] w-auto"
          onerror="this.style.display='none'"
        />
      </a>

      <!-- Nav desktop -->
      <nav class="hidden lg:flex items-center gap-0.5 flex-1 justify-center">
        {nav.map(item => (
          <a
            href={item.href}
            class={item.offset
              ? 'ml-6 px-4 py-2 rounded-xl font-medium text-base text-[#1E4B8C] border border-[#1E4B8C]/30 hover:text-white hover:bg-[#1E4B8C] hover:border-[#1E4B8C] transition-all duration-150'
              : 'px-4 py-2 rounded-xl font-medium text-base text-[#1E4B8C] hover:text-[#E8650A] hover:bg-[#E8F0FB] transition-all duration-150'}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Droite : icône villes + burger nav -->
      <div class="flex items-center gap-2 shrink-0">

        <!-- Bouton villes -->
        <button
          id="villes-toggle"
          aria-label="Voir nos zones d'intervention"
          title="Nos villes"
          class="flex items-center gap-2 px-3 py-2 rounded-xl border border-gray-200 text-gray-600 hover:text-[#1E4B8C] hover:border-[#1E4B8C]/30 hover:bg-[#E8F0FB] transition-all duration-150 text-sm font-medium"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span class="hidden sm:inline text-xs">Nos villes</span>
          <svg id="villes-chevron" class="w-3 h-3 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>

        <!-- Burger nav mobile -->
        <button
          id="menu-toggle"
          aria-label="Menu"
          class="lg:hidden flex items-center justify-center w-10 h-10 rounded-xl border border-gray-200 text-gray-600 hover:text-[#1E4B8C] hover:bg-[#E8F0FB] transition-all duration-150"
        >
          <svg id="icon-menu" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>

      </div>
    </div>

    <!-- Panel villes (sous le header, intégré dans la bulle) -->
    <div id="villes-panel" class="hidden border-t border-gray-100 px-8 py-4 max-w-screen-2xl mx-auto">
      <p class="text-xs text-gray-400 uppercase tracking-widest font-semibold mb-3">Zones d'intervention</p>
      <div class="flex flex-wrap gap-2">
        {villes.map(v => (
          <a
            href={`/villes/${v.slug}`}
            class="flex items-center gap-1.5 bg-[#E8F0FB] hover:bg-[#1E4B8C] text-[#1E4B8C] hover:text-white text-sm font-medium px-3 py-1.5 rounded-lg transition-all duration-150"
          >
            <svg class="w-3 h-3 text-[#E8650A] shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
            {v.nom}
          </a>
        ))}
      </div>
    </div>

    <!-- Menu nav mobile -->
    <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 px-8 py-4">
      <nav class="flex flex-col gap-1">
        {nav.map(item => (
          <a
            href={item.href}
            class="py-2.5 px-3 rounded-xl font-medium text-base text-[#1E4B8C] hover:text-[#E8650A] hover:bg-[#E8F0FB] transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>

  </header>
</div>

</div><!-- /#headercontainer -->

<script>
  // Menu nav mobile
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconMenu   = document.getElementById('icon-menu');
  const iconClose  = document.getElementById('icon-close');

  menuToggle?.addEventListener('click', () => {
    const hidden = mobileMenu?.classList.toggle('hidden');
    iconMenu?.classList.toggle('hidden', !hidden);
    iconClose?.classList.toggle('hidden', !!hidden);
    // Ferme le panel villes si ouvert
    villesPanel?.classList.add('hidden');
    villesChevron?.classList.remove('rotate-180');
  });

  // Panel villes
  const villesToggle  = document.getElementById('villes-toggle');
  const villesPanel   = document.getElementById('villes-panel');
  const villesChevron = document.getElementById('villes-chevron');

  villesToggle?.addEventListener('click', () => {
    const hidden = villesPanel?.classList.toggle('hidden');
    villesChevron?.classList.toggle('rotate-180', !hidden);
    // Ferme le menu nav si ouvert
    mobileMenu?.classList.add('hidden');
    iconMenu?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
  });

  // Fermer en cliquant ailleurs
  document.addEventListener('click', (e) => {
    const header = document.querySelector('header');
    if (header && !header.contains(e.target as Node)) {
      villesPanel?.classList.add('hidden');
      villesChevron?.classList.remove('rotate-180');
      mobileMenu?.classList.add('hidden');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    }
  });

  // Sous-menu mobile : flèche seule ouvre le panel
  document.querySelectorAll<HTMLButtonElement>('.mob-sub-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const wrapper = btn.closest('.mob-sub-wrapper');
      const panel   = wrapper?.querySelector('.mob-sub-panel');
      const chevron = btn.querySelector('.mob-sub-chevron');
      panel?.classList.toggle('hidden');
      chevron?.classList.toggle('rotate-180');
    });
  });

  // Cacher le pré-header au scroll (translateY)
  const headercontainer = document.getElementById('headercontainer') as HTMLElement | null;
  const preheader = document.getElementById('preheader') as HTMLElement | null;

  if (headercontainer && preheader) {
    let lastScrollTop = 0;

    window.addEventListener('scroll', function () {
      const currentScroll = window.scrollY;
      const preheaderH = preheader.offsetHeight;

      if (currentScroll > lastScrollTop) {
        headercontainer.style.transform = `translateY(-${preheaderH}px)`;
      } else if (currentScroll === 0) {
        headercontainer.style.transform = 'translateY(0)';
      }

      lastScrollTop = currentScroll <= 0 ? 0 : currentScroll;
    }, { passive: true });
  }
</script>
