---
const villes = ["Albi", "Gaillac", "Castres", "Graulhet"];
const services = [
  { label: "Isolation Thermique Extérieure", href: "/isolation" },
  { label: "Ravalement de façade", href: "/renovation#facade" },
  { label: "Peinture intérieure & extérieure", href: "/renovation#peinture" },
  { label: "Entretien de toiture", href: "/renovation#toiture" },
  { label: "Revêtements de sols", href: "/renovation#sols" },
  { label: "Travaux après sinistre", href: "/renovation#sinistre" },
];
const prestations = [
  "Isolation Thermique Extérieure (ITE)",
  "Ravalement de façade",
  "Peinture intérieure",
  "Peinture extérieure",
  "Entretien de toiture",
  "Revêtements de sols",
  "Travaux après sinistre",
  "Autre / Je ne sais pas encore",
];
---

<footer id="contact" class="bg-[#153566] text-white">

  <!-- ══════════════════════════════════════
       FORMULAIRE DE CONTACT / DEVIS
  ══════════════════════════════════════ -->
  <div class="border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid lg:grid-cols-2 gap-12 items-start">

        <!-- Infos -->
        <div>
          <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Contactez-nous</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-white mt-3 mb-5 leading-tight" style="font-family:'Montserrat',sans-serif;">
            Demandez votre<br> devis gratuit
          </h2>
          <p class="text-blue-200 text-base leading-relaxed mb-8">
            Réponse garantie sous 24h. Déplacement et devis sans engagement.
          </p>
          <ul class="space-y-4 text-blue-100 text-sm">
            <li class="flex items-center gap-3">
              <span class="w-9 h-9 bg-white/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-[#E8650A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </span>
              <a href="tel:0563541697" class="hover:text-white transition-colors">05 63 54 16 97</a>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-9 h-9 bg-white/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-[#E8650A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </span>
              <a href="mailto:conesa81@wanadoo.fr" class="hover:text-white transition-colors">conesa81@wanadoo.fr</a>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-9 h-9 bg-white/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-[#E8650A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </span>
              Albi, Tarn (81)
            </li>
          </ul>
        </div>

        <!-- Formulaire -->
        <form
          id="conesa-contact-form"
          method="POST"
          action="/contact.php"
          class="bg-white/5 border border-white/10 rounded-2xl p-6 sm:p-8 flex flex-col gap-4"
          novalidate
        >
          <!-- Honeypot anti-spam : caché aux humains, rempli par les bots -->
          <div style="display:none;" aria-hidden="true">
            <input type="text" name="website" id="cf-website" tabindex="-1" autocomplete="off" />
          </div>
          <!-- CSRF token (Double Submit Cookie) — rempli par le JS au chargement -->
          <input type="hidden" name="csrf_token" id="cf-csrf" value="" />
          <!-- Page source — pathname de la page courante, rempli par le JS -->
          <input type="hidden" name="page_source" id="cf-page-source" value="" />

          <div class="grid sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label for="cf-nom" class="text-xs font-semibold text-blue-200 uppercase tracking-wide">Prénom / Nom *</label>
              <input
                id="cf-nom" type="text" name="nom" required placeholder="Jean Dupont"
                class="bg-white/10 border border-white/20 rounded-lg px-4 py-2.5 text-sm text-white placeholder-blue-300 focus:outline-none focus:border-[#E8650A] transition-colors"
              />
              <span id="cf-nom-error" class="cf-error hidden text-red-400 text-xs mt-0.5"></span>
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="cf-telephone" class="text-xs font-semibold text-blue-200 uppercase tracking-wide">Téléphone *</label>
              <input
                id="cf-telephone" type="tel" name="telephone" required placeholder="06 XX XX XX XX"
                class="bg-white/10 border border-white/20 rounded-lg px-4 py-2.5 text-sm text-white placeholder-blue-300 focus:outline-none focus:border-[#E8650A] transition-colors"
              />
              <span id="cf-telephone-error" class="cf-error hidden text-red-400 text-xs mt-0.5"></span>
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="cf-email" class="text-xs font-semibold text-blue-200 uppercase tracking-wide">Email *</label>
            <input
              id="cf-email" type="email" name="email" required placeholder="jean@email.fr"
              class="bg-white/10 border border-white/20 rounded-lg px-4 py-2.5 text-sm text-white placeholder-blue-300 focus:outline-none focus:border-[#E8650A] transition-colors"
            />
            <span id="cf-email-error" class="cf-error hidden text-red-400 text-xs mt-0.5"></span>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label for="cf-ville" class="text-xs font-semibold text-blue-200 uppercase tracking-wide">Ville / Code postal</label>
              <input
                id="cf-ville" type="text" name="ville" placeholder="Albi, 81000"
                class="bg-white/10 border border-white/20 rounded-lg px-4 py-2.5 text-sm text-white placeholder-blue-300 focus:outline-none focus:border-[#E8650A] transition-colors"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="cf-prestation" class="text-xs font-semibold text-blue-200 uppercase tracking-wide">Type de prestation</label>
              <select
                id="cf-prestation" name="prestation"
                class="bg-[#153566] border border-white/20 rounded-lg px-4 py-2.5 text-sm text-white focus:outline-none focus:border-[#E8650A] transition-colors"
              >
                <option value="" disabled selected>Choisir...</option>
                {prestations.map(p => <option value={p}>{p}</option>)}
              </select>
              <span id="cf-prestation-error" class="cf-error hidden text-red-400 text-xs mt-0.5"></span>
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="cf-message" class="text-xs font-semibold text-blue-200 uppercase tracking-wide">Description du projet</label>
            <textarea
              id="cf-message" name="message" rows="3" placeholder="Décrivez brièvement votre projet..."
              class="bg-white/10 border border-white/20 rounded-lg px-4 py-2.5 text-sm text-white placeholder-blue-300 focus:outline-none focus:border-[#E8650A] transition-colors resize-none"
            ></textarea>
          </div>

          <!-- Message d'erreur global -->
          <div id="cf-global-error" class="hidden bg-red-500/20 border border-red-400/40 rounded-lg px-4 py-3 text-red-300 text-sm"></div>

          <!-- Message de succès -->
          <div id="cf-success" class="hidden bg-green-500/20 border border-green-400/40 rounded-xl px-5 py-4 flex items-start gap-3">
            <svg class="w-5 h-5 text-green-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div>
              <p class="text-green-300 font-semibold text-sm">Demande envoyée avec succès !</p>
              <p class="text-green-400/80 text-xs mt-0.5">Nous vous répondrons sous 24h. À très bientôt.</p>
            </div>
          </div>

          <button
            id="cf-submit"
            type="submit"
            class="w-full bg-[#E8650A] hover:bg-orange-700 text-white font-bold py-3 rounded-xl transition-colors duration-200 flex items-center justify-center gap-2 mt-1 disabled:opacity-60 disabled:cursor-not-allowed"
          >
            <svg id="cf-submit-icon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <svg id="cf-submit-spinner" class="w-4 h-4 animate-spin hidden" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
            </svg>
            <span id="cf-submit-label">Envoyer ma demande</span>
          </button>
          <p class="text-xs text-blue-300 text-center">Réponse sous 24h · Sans engagement</p>
        </form>

      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════
       COLONNES FOOTER
  ══════════════════════════════════════ -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="flex flex-col items-center text-center md:items-start md:text-left">
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/Logo/Logo-Conesa.png" alt="Conesa" class="h-12 w-auto" loading="lazy" decoding="async" onerror="this.style.display='none'"/>
          <p class="text-xs text-blue-200 leading-tight">Isolation & Rénovation</p>
        </div>
        <p class="text-blue-200 text-sm leading-relaxed">
          Entreprise familiale dans le Tarn depuis plus de 55 ans. Certifiée RGE et Qualibat.
        </p>
        <div class="flex items-center gap-3 mt-5">
          <img src="/images/labels/Logo-RGE.png" alt="RGE Qualibat" class="h-10 w-auto bg-white/90 rounded-lg p-1" loading="lazy" decoding="async" onerror="this.style.display='none'"/>
        </div>
      </div>

      <!-- Services — masqué sur mobile -->
      <div class="hidden md:block">
        <span class="font-bold text-sm uppercase tracking-wider mb-4" style="font-family:'Montserrat',sans-serif;">Nos prestations</span>
        <ul class="space-y-2 mt-3">
          {services.map(s => (
            <li>
              <a href={s.href} class="text-blue-200 hover:text-white text-sm transition-colors">{s.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Zones — masqué sur mobile -->
      <div class="hidden md:block">
        <span class="font-bold text-sm uppercase tracking-wider mb-4" style="font-family:'Montserrat',sans-serif;">Zones d'intervention</span>
        <ul class="space-y-2 mt-3">
          {villes.map(v => (
            <li>
              <a href={`/villes/${v.toLowerCase().replace(/\s/g, '-').normalize('NFD').replace(/[̀-ͯ]/g, '')}`} class="text-blue-200 hover:text-white text-sm transition-colors">{v}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact rapide -->
      <div class="flex flex-col items-center text-center md:items-start md:text-left">
        <span class="font-bold text-sm uppercase tracking-wider mb-4" style="font-family:'Montserrat',sans-serif;">Contact</span>
        <ul class="space-y-3 text-sm mt-3 text-blue-200">
          <li class="flex items-start gap-2 justify-center md:justify-start">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-[#E8650A]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Albi, Tarn (81)
          </li>
          <li class="flex items-center gap-2 justify-center md:justify-start">
            <svg class="w-4 h-4 shrink-0 text-[#E8650A]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:0563541697" class="hover:text-white transition-colors">05 63 54 16 97</a>
          </li>
          <li class="flex items-center gap-2 justify-center md:justify-start">
            <svg class="w-4 h-4 shrink-0 text-[#E8650A]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:conesa81@wanadoo.fr" class="hover:text-white transition-colors">conesa81@wanadoo.fr</a>
          </li>
        </ul>
        <a href="#contact" class="inline-block mt-6 bg-[#E8650A] hover:bg-orange-700 text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-colors">
          Demander un devis
        </a>
      </div>

    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row justify-between items-center gap-2 text-xs text-blue-300">
      <p>© 2026 Conesa. Tous droits réservés.</p>
      <div class="flex gap-4">
        <a href="/mentions-legales" class="hover:text-white transition-colors">Mentions légales</a>
        <a href="/politique-confidentialite" class="hover:text-white transition-colors">Confidentialité</a>
      </div>
    </div>
  </div>

</footer>

<script>
(function () {
  const form = document.getElementById('conesa-contact-form') as HTMLFormElement | null;
  if (!form) return;

  // ── CSRF : génère un token aléatoire, le pose en cookie ET dans le champ caché
  const csrfToken = Array.from(
    crypto.getRandomValues(new Uint8Array(24)),
    (b: number) => b.toString(16).padStart(2, '0')
  ).join('');
  document.cookie = `cf_token=${csrfToken}; SameSite=Strict; path=/`;
  const csrfField = document.getElementById('cf-csrf') as HTMLInputElement | null;
  if (csrfField) csrfField.value = csrfToken;

  // Page source : pathname de la page courante (ex: /, /isolation, /villes/albi)
  const pageSourceField = document.getElementById('cf-page-source') as HTMLInputElement | null;
  if (pageSourceField) pageSourceField.value = window.location.pathname;

  const nom        = document.getElementById('cf-nom')        as HTMLInputElement | null;
  const telephone  = document.getElementById('cf-telephone')  as HTMLInputElement | null;
  const email      = document.getElementById('cf-email')      as HTMLInputElement | null;
  const prestation = document.getElementById('cf-prestation') as HTMLSelectElement | null;
  const message    = document.getElementById('cf-message')    as HTMLTextAreaElement | null;

  const submitBtn     = document.getElementById('cf-submit')         as HTMLButtonElement | null;
  const submitLabel   = document.getElementById('cf-submit-label')   as HTMLElement | null;
  const submitIcon    = document.getElementById('cf-submit-icon')    as HTMLElement | null;
  const submitSpinner = document.getElementById('cf-submit-spinner') as HTMLElement | null;
  const globalError   = document.getElementById('cf-global-error')   as HTMLElement | null;
  const successBox    = document.getElementById('cf-success')        as HTMLElement | null;

  const nomRegex   = /^[\p{L}\s''\-.]{2,100}$/u;
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
  const telRegex   = /^(0|\+33)[1-9][0-9]{8}$/;

  function showError(fieldId: string, msg: string): void {
    const el = document.getElementById(fieldId + '-error');
    if (!el) return;
    el.textContent = msg;
    el.classList.remove('hidden');
    document.getElementById(fieldId)?.classList.add('border-red-400');
  }

  function clearError(fieldId: string): void {
    const el = document.getElementById(fieldId + '-error');
    if (!el) return;
    el.textContent = '';
    el.classList.add('hidden');
    document.getElementById(fieldId)?.classList.remove('border-red-400');
  }

  function validateField(field: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null): boolean {
    if (!field) return true;
    const val = field.value.trim();

    if (field === nom) {
      if (!nomRegex.test(val)) {
        showError('cf-nom', "Merci d'indiquer votre nom (2 à 100 caractères).");
        return false;
      }
      clearError('cf-nom');
    }

    if (field === telephone) {
      const clean = val.replace(/[\s.\-()]/g, '');
      if (!telRegex.test(clean)) {
        showError('cf-telephone', 'Numéro invalide (ex : 06 12 34 56 78).');
        return false;
      }
      clearError('cf-telephone');
    }

    if (field === email) {
      if (!emailRegex.test(val)) {
        showError('cf-email', 'Adresse e-mail invalide.');
        return false;
      }
      clearError('cf-email');
    }

    return true;
  }

  // Nettoyage du nom en temps réel
  nom?.addEventListener('input', function (this: HTMLInputElement) {
    this.value = this.value.replace(/[^a-zA-ZÀ-ÖØ-öø-ÿ\s''\-.]/g, '');
    clearError('cf-nom');
  });

  // Validation au blur
  ([nom, telephone, email] as (HTMLInputElement | null)[]).forEach(function (field) {
    field?.addEventListener('blur', function (this: HTMLInputElement) { validateField(this); });
  });

  // Nettoyage erreurs au focus
  ([nom, telephone, email, prestation, message] as (HTMLElement | null)[]).forEach(function (field) {
    field?.addEventListener('focus', function (this: HTMLElement) {
      clearError('cf-' + this.id.replace('cf-', ''));
    });
  });

  function setLoading(loading: boolean): void {
    if (submitBtn)     submitBtn.disabled = loading;
    if (submitLabel)   submitLabel.textContent = loading ? 'Envoi en cours...' : 'Envoyer ma demande';
    if (submitIcon)    submitIcon.classList.toggle('hidden', loading);
    if (submitSpinner) submitSpinner.classList.toggle('hidden', !loading);
  }

  form.addEventListener('submit', async function (e: Event) {
    e.preventDefault();

    let valid = true;
    valid = validateField(nom)       && valid;
    valid = validateField(telephone) && valid;
    valid = validateField(email)     && valid;
    if (!valid) return;

    globalError?.classList.add('hidden');
    setLoading(true);

    try {
      const res  = await fetch('/contact.php', { method: 'POST', body: new FormData(form) });
      const data = await res.json() as { success: boolean; errors?: Record<string, string>; message?: string };

      if (data.success) {
        form.reset();
        successBox?.classList.remove('hidden');
        submitBtn?.closest('button')?.classList.add('hidden');
        form.querySelector<HTMLElement>('.text-xs.text-blue-300')?.classList.add('hidden');
      } else if (data.errors) {
        Object.entries(data.errors).forEach(([field, msg]) => showError('cf-' + field, msg));
      } else {
        if (globalError) {
          globalError.textContent = data.message ?? "Une erreur est survenue. Merci de nous appeler au 05 63 54 16 97.";
          globalError.classList.remove('hidden');
        }
      }
    } catch {
      if (globalError) {
        globalError.textContent = "Impossible de contacter le serveur. Merci de nous appeler au 05 63 54 16 97.";
        globalError.classList.remove('hidden');
      }
    } finally {
      setLoading(false);
    }
  });
})();
</script>
