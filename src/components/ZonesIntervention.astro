---
const zones = [
  { num: "01", nom: "Albi", zone: "& l'agglomération albigeoise", slug: "albi" },
  { num: "02", nom: "Gaillac", zone: "& le vignoble gaillacois", slug: "gaillac" },
  { num: "03", nom: "Castres", zone: "& l'agglomération castraise", slug: "castres" },
  { num: "04", nom: "Graulhet", zone: "& le secteur graulhétois", slug: "graulhet" },
];
---

<section class="py-24 bg-[#1E4B8C]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="text-[#E8650A] font-semibold text-sm uppercase tracking-widest">Proximité locale</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white mt-3 leading-tight" style="font-family:'Montserrat',sans-serif;">
        Nous intervenons dans tout le Tarn
      </h2>
      <p class="text-blue-200 mt-4 text-lg leading-relaxed">
        Une présence renforcée à <strong class="text-white">Albi</strong>, <strong class="text-white">Gaillac</strong>, <strong class="text-white">Castres</strong> et <strong class="text-white">Graulhet</strong>, pour tous vos travaux de rénovation et d'isolation dans le département du Tarn (81).
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 lg:gap-20 items-start mb-12">

      <!-- Texte -->
      <div>
        <p class="text-blue-100 text-base leading-relaxed mb-5">
          Entreprise familiale implantée dans le Tarn depuis 1969, Conesa accompagne les propriétaires dans leurs projets de
          <strong class="text-white">rénovation de façade</strong>, d'<strong class="text-white">isolation thermique extérieure</strong>,
          de <strong class="text-white">peinture</strong> et d'<strong class="text-white">entretien de toiture</strong>.
        </p>
        <p class="text-blue-200 text-base leading-relaxed mb-8">
          Que vous soyez dans l'Albigeois, le Gaillacois, le Castrais ou le Graulhétois, nos équipes se déplacent jusqu'à
          vous pour réaliser votre projet avec la même exigence et le même accompagnement personnalisé.
        </p>
        <a href="#contact" class="inline-flex items-center gap-2 bg-white text-[#1E4B8C] hover:bg-gray-100 font-bold px-8 py-4 rounded-xl transition-all duration-200">
          Demander un devis gratuit
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <!-- Liste zones numérotées -->
      <div class="flex flex-col divide-y divide-white/10">
        {zones.map(z => (
          <a href={`/villes/${z.slug}`} class="group flex items-center gap-5 py-5 hover:pl-2 transition-all duration-200">
            <span class="text-[#E8650A] font-extrabold text-lg shrink-0 w-8" style="font-family:'Montserrat',sans-serif;">{z.num}</span>
            <div class="flex-1 min-w-0">
              <span class="text-white font-bold text-lg group-hover:text-[#E8650A] transition-colors duration-150">{z.nom}</span>
              <span class="text-blue-300 text-sm ml-2">{z.zone}</span>
            </div>
            <svg class="w-4 h-4 text-blue-400 group-hover:text-[#E8650A] group-hover:translate-x-1 transition-all duration-200 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        ))}
      </div>

    </div>

  </div>
</section>
