---
const slides = [
  { prestation: "Isolation Thermique Extérieure", ville: "Albi",     src: "/images/Réalisations/Isolation par l'extérieur.JPG" },
  { prestation: "Ravalement de Façade",           ville: "Gaillac",  src: "/images/Réalisations/Ravalement de façade.webp" },
  { prestation: "Peinture de Façade",             ville: "Castres",  src: "/images/Réalisations/peinture-façade.png" },
  { prestation: "Rénovation de Façade",           ville: "Graulhet", src: "/images/Réalisations/Rénovation façade.JPG" },
];
---

<div class="relative">

  <!-- Viewport du carrousel -->
  <div class="overflow-hidden rounded-2xl pb-4" id="carousel-viewport">
    <div class="flex gap-5 transition-transform duration-500 ease-in-out" id="carousel-track">
      {slides.map((slide, i) => (
        <div class="carousel-slide shrink-0 w-full sm:w-[calc(50%-10px)] lg:w-[calc(33.333%-14px)]">
          <div class="rounded-2xl overflow-hidden shadow-md bg-white group">

            <!-- Image -->
            <div class="relative overflow-hidden" style="aspect-ratio:4/3;">
              <img
                src={slide.src}
                alt={slide.prestation}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                onerror="this.closest('.relative').classList.add('bg-[#1E4B8C]/10'); this.style.display='none';"
              />
              <!-- Badge prestation -->
              <div class="absolute top-3 left-3 bg-[#E8650A] text-white text-xs font-semibold px-3 py-1 rounded-full">
                {slide.prestation}
              </div>
            </div>

            <!-- Infos -->
            <div class="p-4">
              <p class="font-semibold text-gray-800 text-sm" style="font-family:'Montserrat',sans-serif;">{slide.prestation}</p>
              <p class="text-gray-500 text-xs flex items-center gap-1 mt-0.5">
                <svg class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                {slide.ville}
              </p>
            </div>

          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Flèches -->
  <button
    id="carousel-prev"
    aria-label="Précédent"
    class="absolute -left-5 top-1/2 -translate-y-1/2 w-11 h-11 bg-white shadow-lg border border-gray-100 rounded-full flex items-center justify-center text-[#1E4B8C] hover:bg-[#1E4B8C] hover:text-white hover:border-[#1E4B8C] transition-all duration-200 z-10 disabled:opacity-30 disabled:cursor-not-allowed"
  >
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
    </svg>
  </button>

  <button
    id="carousel-next"
    aria-label="Suivant"
    class="absolute -right-5 top-1/2 -translate-y-1/2 w-11 h-11 bg-white shadow-lg border border-gray-100 rounded-full flex items-center justify-center text-[#1E4B8C] hover:bg-[#1E4B8C] hover:text-white hover:border-[#1E4B8C] transition-all duration-200 z-10 disabled:opacity-30 disabled:cursor-not-allowed"
  >
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
    </svg>
  </button>

  <!-- Dots -->
  <div class="flex justify-center gap-2 mt-8" id="carousel-dots"></div>

</div>

<script>
  const track = document.getElementById('carousel-track') as HTMLElement;
  const prevBtn = document.getElementById('carousel-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('carousel-next') as HTMLButtonElement;
  const dotsContainer = document.getElementById('carousel-dots') as HTMLElement;
  const slides = document.querySelectorAll('.carousel-slide');

  let current = 0;

  function getSlidesVisible(): number {
    if (window.innerWidth >= 1024) return 3;
    if (window.innerWidth >= 640) return 2;
    return 1;
  }

  function getMaxIndex(): number {
    return slides.length - getSlidesVisible();
  }

  function getSlideWidth(): number {
    const viewport = document.getElementById('carousel-viewport') as HTMLElement;
    const gap = 20;
    const visible = getSlidesVisible();
    return (viewport.offsetWidth - gap * (visible - 1)) / visible + gap;
  }

  function updateCarousel() {
    const offset = current * getSlideWidth();
    track.style.transform = `translateX(-${offset}px)`;
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current >= getMaxIndex();
    updateDots();
  }

  function buildDots() {
    dotsContainer.innerHTML = '';
    const total = getMaxIndex() + 1;
    for (let i = 0; i < total; i++) {
      const dot = document.createElement('button');
      dot.className = `w-2.5 h-2.5 rounded-full transition-all duration-300 ${i === current ? 'bg-[#E8650A] w-6' : 'bg-gray-300 hover:bg-gray-400'}`;
      dot.setAttribute('aria-label', `Aller au slide ${i + 1}`);
      dot.addEventListener('click', () => { current = i; updateCarousel(); });
      dotsContainer.appendChild(dot);
    }
  }

  function updateDots() {
    const dots = dotsContainer.querySelectorAll('button');
    dots.forEach((dot, i) => {
      if (i === current) {
        dot.className = 'w-6 h-2.5 rounded-full transition-all duration-300 bg-[#E8650A]';
      } else {
        dot.className = 'w-2.5 h-2.5 rounded-full transition-all duration-300 bg-gray-300 hover:bg-gray-400';
      }
    });
  }

  prevBtn.addEventListener('click', () => {
    if (current > 0) { current--; updateCarousel(); }
  });

  nextBtn.addEventListener('click', () => {
    if (current < getMaxIndex()) { current++; updateCarousel(); }
  });

  // Auto-play
  let autoplay = setInterval(() => {
    if (current < getMaxIndex()) { current++; } else { current = 0; }
    updateCarousel();
  }, 4000);

  // Pause on hover
  track.addEventListener('mouseenter', () => clearInterval(autoplay));
  track.addEventListener('mouseleave', () => {
    autoplay = setInterval(() => {
      if (current < getMaxIndex()) { current++; } else { current = 0; }
      updateCarousel();
    }, 4000);
  });

  // Swipe tactile
  let startX = 0;
  track.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', (e) => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      if (diff > 0 && current < getMaxIndex()) { current++; }
      else if (diff < 0 && current > 0) { current--; }
      updateCarousel();
    }
  });

  // Recalcul au resize
  window.addEventListener('resize', () => {
    if (current > getMaxIndex()) current = getMaxIndex();
    buildDots();
    updateCarousel();
  });

  buildDots();
  updateCarousel();
</script>
